WP_BASE_URL=https://example.wpenginepowered.com
WORDPRESS_API_URL=https://example.wpenginepowered.com/graphql
WP_AUTH_BASIC=username:password
# Local-only secret for syncing draft Astro endpoints during local builds.
WP_DRAFT_ACCESS_SECRET=replace-with-a-long-random-secret
WP_IMAGE_ALLOW_HOSTS=example.wpenginepowered.com
GF_CONSUMER_KEY=ck_replace_me
GF_CONSUMER_SECRET=cs_replace_me
EDGEWISE_API_TOKEN=replace-with-edgewise-bearer-token
EDGEWISE_PROJECT_ID=replace-with-edgewise-project-id
EDGEWISE_DEBUG=0
EDGEWISE_SOURCE=
AVESDO=
AVESDO_DEBUG=
PUBLIC_CN_MENU_DEBUG=0
GITHUB=ghp_replace_me
GITHUB_REPOSITORY=owner/repo
WP_WEBHOOK_SECRET=replace-with-a-long-random-secret
