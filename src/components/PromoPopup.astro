---
// src/components/PromoPopup.astro
import specials from "../content/wp/specials.json";
import { getWpImage } from "../lib/wp/get-wp-image.js";

const activeSpecial = specials && specials.length > 0 ? specials[0] : null;

// Guard clauses
if (!activeSpecial || !activeSpecial.image) return;

// ---------------------------------------------------------
// SHOW_ON LOGIC (Server-Side)
// ---------------------------------------------------------
const { show_on } = activeSpecial;

if (show_on && Array.isArray(show_on) && show_on.length > 0) {
  const currentPath = Astro.url.pathname;
  let currentSlug = currentPath === "/" ? "home" : currentPath.replace(/^\/|\/$/g, "");
  const isMatch = show_on.some((page) => page.slug === currentSlug);

  if (!isMatch) return;
}
// ---------------------------------------------------------

const { title, text, show_once, image } = activeSpecial;

// Resolve the main image using your helper
const resolvedImage = getWpImage(image.sizes.intch_med);

// LOGIC: Prefer the specific 1000px WebP ('intch_med') for this modal size.
// If not found, fall back to the helper's result, then the raw URL.
const imageUrl = 
  resolvedImage || 
  image.sizes?.intch_med ||
  image.url;



const imageAlt = image.alt || title;
const popupId = `promo-${image.id}`;
---

<div 
  id="promo-popup-container" 
  class="promo-popup-backdrop hidden"
  data-popup-id={popupId}
  data-show-once={show_once.toString()}
>
  <div class="promo-popup-modal">
    <button id="promo-close" class="close-btn" aria-label="Close popup">
      <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="1" stroke-linecap="round" stroke-linejoin="round"><line x1="18" y1="6" x2="6" y2="18"></line><line x1="6" y1="6" x2="18" y2="18"></line></svg>
    </button>

    <div class="popup-image-wrapper">
      <img src={imageUrl} alt={imageAlt} loading="eager" />
      
      <div class="image-overlay"></div>
    </div>
    
    <div class="popup-content">
      {title && <h3 class="antiga lilblur">{title}</h3>}
      {text && <div class="popup-text figure max-w-[23em]" set:html={text} />}
    </div>
  </div>
</div>

<style lang="scss">
  .popup-text :global(p) {
    margin-bottom: 1.25rem;
  } 
  /* 1. BACKDROP */
  .promo-popup-backdrop {
    position: fixed;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    z-index: 9999;
    display: flex;
    align-items: center;
    justify-content: center;
    
    background: rgba(0, 0, 0, 0.6);
    backdrop-filter: blur(4px);
    
    opacity: 0;
    visibility: hidden;
    pointer-events: none;
    
    transition: opacity 1.6s ease, visibility 1.6s ease;
    will-change: opacity, visibility;

    &.active {
      opacity: 1;
      visibility: visible;
      pointer-events: auto;

      .promo-popup-modal {
        mask-position: 0% 0%; 
        transform: translateY(0) scale(1);
      }
    }

    &.hidden {
      display: none;
    }
  }

  /* 2. MODAL CONTAINER */
  .promo-popup-modal {
    /* Set a reasonable max width for the image */
    width: 90%;
    max-width: 800px; 
    height: 70vh;
    max-height: 600px;
    position: relative;
    border-radius: 4px;
    box-shadow: 0 25px 50px -12px rgba(0, 0, 0, 0.25);
    overflow: hidden;
    background: #000; /* Fallback */

    /* The Mask Animation */
    mask-image: linear-gradient(135deg, black 30%, transparent 70%);
    mask-size: 450% 450%;
    mask-repeat: no-repeat;
    mask-position: 130% 130%; /* Start Hidden */

    transform: translateY(5px) scale(0.99);
    will-change: mask-position, transform;
    transition: 
      mask-position 3.4s cubic-bezier(0.22, 1, 0.36, 1), 
      transform 1s cubic-bezier(0.22, 1, 0.36, 1);
  }

  /* IMAGE WRAPPER */
  .popup-image-wrapper {
    position: relative;
    width: 100%;
    height: 100%;
    
    img {
      display: block;
      width: 100%;
      height: 100%;
      object-fit: cover;
    }
  }

  /* 50% BLACK OVERLAY */
  .image-overlay {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background: rgba(0, 0, 0, 0.65);
    z-index: 1;
  }

  /* CLOSE BUTTON */
  .close-btn {
    position: absolute;
    top: 15px;
    right: 15px;
    background: transparent;
    border: none;
    padding: 0;
    cursor: pointer;
    z-index: 10;
    transition: transform 0.2s ease;

    &:hover {
      transform: scale(1.1);
    }
  }

  /* CONTENT OVERLAY */
  .popup-content {
    position: absolute;
    bottom: 0;
    left: 0;
    width: 100%;
    z-index: 5; /* Above overlay */
    padding: 2.5rem 2.5rem 4.5rem 2.5rem;
    
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: flex-end;
    text-align: center;
    color: white;

    h3.antiga {
      margin: 0;
      margin-bottom: 1.5rem;
      font-size: 4.5rem;
      line-height: 1;
      font-weight: normal;
      color: white;
    }

    .popup-text.figure {
      font-size: 1.75rem;
      line-height: 1.4;
      color: rgba(255, 255, 255, 0.9);
      
      :global(a) {
        color: white;
        text-decoration: underline;
        text-underline-offset: 4px;
      }
    }
  }
</style>

<script>
  if (!window._sessionPopupsSeen) {
    window._sessionPopupsSeen = new Set();
  }

  function initPopup() {
    const container = document.getElementById('promo-popup-container');
    if (!container) return;

    // Reset state
    container.classList.add('hidden');
    container.classList.remove('active');

    const closeBtn = document.getElementById('promo-close');
    const popupId = container.dataset.popupId;
    const showOnce = container.dataset.showOnce === 'true'; 
    const storageKey = `popup_seen_${popupId}`;

    let shouldBlock = false;

    if (showOnce) {
      if (localStorage.getItem(storageKey)) shouldBlock = true;
    } else {
      if (window._sessionPopupsSeen.has(popupId)) shouldBlock = true;
    }

    if (shouldBlock) {
      container.remove();
      return;
    }

    if (!showOnce) {
      window._sessionPopupsSeen.add(popupId);
    }

    // Show
    container.classList.remove('hidden');
    void container.offsetWidth; 

    setTimeout(() => {
        container.classList.add('active');
    }, 1000); 

    // Hide
    const closePopup = () => {
      container.classList.remove('active');
      setTimeout(() => {
        container.classList.add('hidden');
        if (showOnce) localStorage.setItem(storageKey, 'true');
      }, 1600); 
    };

    closeBtn?.addEventListener('click', closePopup);
    container.addEventListener('click', (e) => {
      if (e.target === container) closePopup();
    });
  }

  document.addEventListener('astro:page-load', initPopup);
</script>