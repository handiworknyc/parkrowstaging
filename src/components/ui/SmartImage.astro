---
// src/components/ui/SmartImage.astro
import fs from "node:fs";
import path from "node:path";
import { createHash } from "node:crypto";

interface ImagesMap {
  xl?: string;
  large?: string;
  med?: string | false;
  small?: string | false;
}

interface Props {
  images: ImagesMap;
  sizes?: string;
  alt?: string;
  imgClass?: string;
  critical?: boolean;
  fetchpriority?: "auto" | "high" | "low";
  useSrcSet?: boolean;
  forceSize?: "xl" | "large" | "med" | "small";
}

const {
  images,
  sizes = "(max-width: 1200px) 40vw, 100vw",
  alt = "",
  imgClass = "",
  critical = false,
  fetchpriority = critical ? "high" : "auto",
  useSrcSet = true,
  forceSize,
} = Astro.props as Props;

/* --------------------------------------------------------------------------
   HELPER: Get Local Path
-------------------------------------------------------------------------- */
function getLocalPath(url: string | undefined | false): string | null {
  if (!url || typeof url !== "string") return null;
  if (url.startsWith("/")) return url; 

  try {
    let processUrl = url;

    // 1. STRIP .webp if it is a double extension
    if (processUrl.toLowerCase().endsWith('.webp')) {
      const withoutWebp = processUrl.slice(0, -5);
      const extBefore = path.extname(withoutWebp);
      if (['.jpg', '.jpeg', '.png'].includes(extBefore.toLowerCase())) {
          processUrl = withoutWebp;
      }
    }

    // 2. Generate Hash from CLEANED URL
    const hash = createHash("md5").update(processUrl).digest("hex").slice(0, 8);
    
    // 3. Extract filename parts from CLEANED url
    const urlObj = new URL(processUrl);
    const basename = path.basename(urlObj.pathname); 
    const ext = path.extname(basename); 
    const nameWithoutExt = path.basename(basename, ext); 

    // 4. Sanitize
    const cleanName = nameWithoutExt.replace(/[^a-z0-9-_]/gi, "-").toLowerCase();

    // 5. Append .webp to jpg/png
    let finalExt = ext;
    if (['.jpg', '.jpeg', '.png'].includes(ext.toLowerCase())) {
        finalExt = `${ext}.webp`;
    }

    // 6. Final Filename
    const filename = `${cleanName}-${hash}${finalExt}`;
    
    return `/img-cache/${filename}`;

  } catch (err) {
    console.warn(`[SmartImage] Error calculating path for ${url}`);
    return url;
  }
}

/* --------------------------------------------------------------------------
   1. RESOLVE ALL PATHS
-------------------------------------------------------------------------- */
const xl = getLocalPath(images?.xl);
const lg = getLocalPath(images?.large);
const md = getLocalPath(images?.med);
const sm = getLocalPath(images?.small);

/* --------------------------------------------------------------------------
   2. BUILD SRCSET
-------------------------------------------------------------------------- */
const allCandidates = [
  { url: xl, w: "1700w" },
  { url: lg, w: "1400w" },
  { url: md, w: "1000w" },
  { url: sm, w: "600w" }
];

const validCandidates = allCandidates.filter(c => c.url);

const generatedSrcSet = validCandidates.length > 0 
  ? validCandidates.map(c => `${c.url} ${c.w}`).join(", ") 
  : undefined;

/* --------------------------------------------------------------------------
   3. DETERMINE PRIMARY SRC
-------------------------------------------------------------------------- */
let srcToUse: string | null = null;

if (forceSize) {
  if (forceSize === "xl") srcToUse = xl;
  else if (forceSize === "large") srcToUse = lg;
  else if (forceSize === "med") srcToUse = md;
  else if (forceSize === "small") srcToUse = sm;
} else {
  srcToUse = xl || lg || md || sm || null;
}

/* --------------------------------------------------------------------------
   CONFIG
-------------------------------------------------------------------------- */
const loading = "eager";
const decoding = critical ? "sync" : "async";
const className = ["hw-lazy-img", imgClass].filter(Boolean).join(" ");

const finalSrcSet = (useSrcSet && !forceSize) ? generatedSrcSet : undefined;

// Unique ID for critical script targeting
const imgId = critical ? `crit-img-${Math.random().toString(36).slice(2, 8)}` : undefined;
---

{srcToUse && (
  <>
    <img
      id={imgId}
      src={srcToUse}
      srcset={finalSrcSet}
      sizes={finalSrcSet ? sizes : undefined}
      alt={alt}
      class={className}
      loading={loading}
      decoding={decoding}
      fetchpriority={fetchpriority}
    />

	{critical && (
	<script is:inline define:vars={{ imgId }}>
		(function() {
		const img = document.getElementById(imgId);
		if (!img) return;

		function setLoaded() {
			// Frame 1: Browser paints opacity: 0
			requestAnimationFrame(() => {
			requestAnimationFrame(() => {
				img.classList.add('lazy-loaded');
				
					console.log('CRITICAL LOADED');
					// 🚀 FIRE GLOBAL EVENT
					window.dispatchEvent(
						new CustomEvent('critImgLoaded', {
							detail: {
							id: imgId,
							src: img.currentSrc || img.src,
							width: img.naturalWidth,
							height: img.naturalHeight
							}
						})
					);
			});
			});
		}

		if (img.complete && img.naturalWidth > 0) {
			setLoaded();
		} else {
			if ('decode' in img) {
			img.decode()
				.then(setLoaded)
				.catch(() => { img.onload = setLoaded; });
			} else {
			img.onload = setLoaded;
			}
		}
		})();
	</script>
	)}


  </>
)}