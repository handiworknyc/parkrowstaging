---
/**
 * SmartImage.astro — outputs a single <img>.
 *
 * Props:
 *  - images: { xl?: string; large?: string; med?: string|false; small?: string|false }
 *  - sizes?: string                    (default '(max-width: 1200px) 40vw, 100vw')
 *  - alt?: string
 *  - imgClass?: string
 *  - critical?: boolean
 *  - crossorigin?: ''|'anonymous'|'use-credentials'
 *  - fetchpriority?: 'auto'|'high'|'low'
 */

interface ImagesMap {
  xl?: string;
  large?: string;
  med?: string | false;
  small?: string | false;
}

interface Props {
  images: ImagesMap;
  sizes?: string;
  alt?: string;
  imgClass?: string;
  critical?: boolean;
  crossorigin?: '' | 'anonymous' | 'use-credentials';
  fetchpriority?: 'auto' | 'high' | 'low';
}

const {
  images,
  sizes = '(max-width: 1200px) 40vw, 100vw',
  alt = '',
  imgClass = '',
  critical = false,
  crossorigin,
  fetchpriority = critical ? 'high' : 'low',
} = Astro.props as Props;


/* -------------------------------------------------------
 * URL HELPERS
 * -----------------------------------------------------*/

// Always append .webp unless already present
function toWebP(url: string | null): string | null {
  if (!url) return null;
  if (url.endsWith('.webp')) return url;
  return url + '.webp';
}


/* -------------------------------------------------------
 * BUILD SRCSET
 * -----------------------------------------------------*/

type SrcItem = { url: string; w: number };
const parts: SrcItem[] = [];

const xl = toWebP(images?.xl || null);
const lg = toWebP(images?.large || null);
const md =
  images?.med === false
    ? null
    : toWebP(typeof images?.med === 'string' ? images.med : null);

const sm =
  images?.small === false
    ? null
    : toWebP(typeof images?.small === 'string' ? images.small : null);

// Build srcset with fixed widths
if (xl) parts.push({ url: xl, w: 1700 });
if (lg) parts.push({ url: lg, w: 1400 });
if (md) parts.push({ url: md, w: 1000 });
if (sm) parts.push({ url: sm, w: 600 });

const srcsetAttr = parts.map((p) => `${p.url} ${p.w}w`).join(', ');

// Primary = highest available
const primary = parts.length ? parts[0].url : (xl || lg || md || sm || '');


/* -------------------------------------------------------
 * FINAL ATTRS
 * -----------------------------------------------------*/

const loading = critical ? 'eager' : 'lazy';
const decoding = critical ? 'sync' : 'async';

const className = ['hw-lazy-img', imgClass].filter(Boolean).join(' ');

const baseAttrs = {
  alt,
  loading,
  decoding,
  fetchpriority,
  ...(crossorigin ? { crossorigin } : {}),
};
---

<img
  class={className}
  src={primary}
  srcset={srcsetAttr}
  sizes={sizes}
  {...baseAttrs}
/>
