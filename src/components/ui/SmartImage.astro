---
interface ImagesMap {
  xl?: string;
  large?: string;
  med?: string | false;
  small?: string | false;
}

interface Props {
  images: ImagesMap;
  sizes?: string;
  alt?: string;
  imgClass?: string;
  critical?: boolean;
  crossorigin?: '' | 'anonymous' | 'use-credentials';
  fetchpriority?: 'auto' | 'high' | 'low';

  useSrcSet?: boolean;
  forceSize?: 'xl' | 'large' | 'med' | 'small';
}

const {
  images,
  sizes = '(max-width: 1200px) 40vw, 100vw',
  alt = '',
  imgClass = '',
  critical = false,
  crossorigin,
  fetchpriority = critical ? 'high' : 'low',

  useSrcSet = true,
  forceSize
} = Astro.props as Props;

function toWebP(url: string | null): string | null {
  if (!url) return null;
  return url.endsWith('.webp') ? url : url + '.webp';
}

const xl = toWebP(images?.xl || null);
const lg = toWebP(images?.large || null);
const md = images?.med === false ? null : toWebP(typeof images?.med === 'string' ? images.med : null);
const sm = images?.small === false ? null : toWebP(typeof images?.small === 'string' ? images.small : null);

/* ---------- FORCE SIZE PRIMARY ---------- */
const forcedPrimary =
  forceSize === 'xl' ? xl :
  forceSize === 'large' ? lg :
  forceSize === 'med' ? md :
  forceSize === 'small' ? sm :
  null;

/* ---------- NORMAL SRCSET BUILD ---------- */
const parts = [];
if (xl) parts.push({ url: xl, w: 1700 });
if (lg) parts.push({ url: lg, w: 1400 });
if (md) parts.push({ url: md, w: 1000 });
if (sm) parts.push({ url: sm, w: 600 });

const srcsetAttr = parts.map((p) => `${p.url} ${p.w}w`).join(', ');
const defaultPrimary = parts.length ? parts[0].url : (xl || lg || md || sm || '');

const primary = forcedPrimary || defaultPrimary;

const loading = critical ? 'eager' : 'lazy';
const decoding = critical ? 'sync' : 'async';

const className = ['hw-lazy-img', imgClass].filter(Boolean).join(' ');

const baseAttrs = {
  alt,
  loading,
  decoding,
  fetchpriority,
  ...(crossorigin ? { crossorigin } : {}),
};
---

{/** ===============================
    CASE 1 — forceSize -> NO SRCSET
    =============================== */}
{forcedPrimary && (
  <img
    class={className}
    src={primary}
    {...baseAttrs}
  />
)}

{/** ===============================
    CASE 2 — useSrcSet = false
    =============================== */}
{!forcedPrimary && !useSrcSet && (
  <img
    class={className}
    src={primary}
    {...baseAttrs}
  />
)}

{/** ===============================
    CASE 3 — normal responsive image
    =============================== */}
{!forcedPrimary && useSrcSet && (
  <img
    class={className}
    src={primary}
    srcset={srcsetAttr}
    sizes={sizes}
    {...baseAttrs}
  />
)}
