---
import fs from "node:fs";
import path from "node:path";
import { createHash } from "node:crypto";
import { Image } from "astro:assets";

interface ImagesMap {
  xl?: string;
  large?: string;
  med?: string | false;
  small?: string | false;
}

interface Props {
  images: ImagesMap;
  sizes?: string;
  alt?: string;
  imgClass?: string;
  critical?: boolean;
  fetchpriority?: "auto" | "high" | "low";
  useSrcSet?: boolean;
  forceSize?: "xl" | "large" | "med" | "small";
}

const {
  images,
  sizes = "(max-width: 1200px) 40vw, 100vw",
  alt = "",
  imgClass = "",
  critical = false,
  fetchpriority = critical ? "high" : "low",
  useSrcSet = true,
  forceSize,
} = Astro.props as Props;

/* --------------------------------------------------------------------------
   HELPER: Download & Cache Protected Images
   1. Checks if image exists in public/img-cache/
   2. If not, fetches it using WP_AUTH_BASIC headers
   3. Returns the local path (bypassing the 401 error)
-------------------------------------------------------------------------- */
async function cacheImage(url: string | undefined | false): Promise<string | null> {
  if (!url || typeof url !== "string") return null;
  if (url.startsWith("/")) return url; // Already local

  try {
    // Generate a clean filename based on the URL hash
    const hash = createHash("md5").update(url).digest("hex");
    const ext = path.extname(url).split("?")[0] || ".jpg";
    const filename = `${hash}${ext}`;

    // Paths
    const publicDir = path.join(process.cwd(), "public", "img-cache");
    const filePath = path.join(publicDir, filename);
    const webPath = `/img-cache/${filename}`;

    // Return immediately if cached
    if (fs.existsSync(filePath)) {
      return webPath;
    }

    // Ensure directory exists
    if (!fs.existsSync(publicDir)) {
      fs.mkdirSync(publicDir, { recursive: true });
    }

    // Prepare Auth Headers
    const headers: Record<string, string> = {};
    const authEnv = import.meta.env.WP_AUTH_BASIC; // "demo:12345a"
    
    if (authEnv) {
      const token = Buffer.from(authEnv).toString("base64");
      headers["Authorization"] = `Basic ${token}`;
    }

    // Fetch and Save
    console.log(`[SmartImage] Downloading: ${url}`);
    const res = await fetch(url, { headers });
    
    if (!res.ok) {
      console.warn(`[SmartImage] Failed to fetch ${url}: ${res.status}`);
      return url; // Fallback to original if fetch fails
    }

    const buffer = await res.arrayBuffer();
    fs.writeFileSync(filePath, Buffer.from(buffer));

    return webPath;

  } catch (err) {
    console.warn(`[SmartImage] Error caching ${url}`, err);
    return url;
  }
}

/* --------------------------------------------------------------------------
   PROCESS ALL IMAGES
-------------------------------------------------------------------------- */
const xl = await cacheImage(images?.xl);
const lg = await cacheImage(images?.large);
const md = await cacheImage(images?.med);
const sm = await cacheImage(images?.small);

// Select the source based on props
let srcToUse: string | null = null;

if (forceSize) {
  if (forceSize === "xl") srcToUse = xl;
  else if (forceSize === "large") srcToUse = lg;
  else if (forceSize === "med") srcToUse = md;
  else if (forceSize === "small") srcToUse = sm;
} else {
  srcToUse = xl || lg || md || sm || null;
}

/* --------------------------------------------------------------------------
   CONFIG
-------------------------------------------------------------------------- */
const loading = critical ? "eager" : "lazy";
const decoding = critical ? "sync" : "async";
const className = ["hw-lazy-img", imgClass].filter(Boolean).join(" ");
---

{/* NOTE: We use standard <img> for the local cached files because 
    Astro's <Image> optimization on /public files is limited. 
    This ensures the 401 error is gone and the image loads reliably.
*/}

{srcToUse && (
  <img
    src={srcToUse}
    alt={alt}
    class={className}
    sizes={useSrcSet && !forceSize ? sizes : undefined}
    loading={loading}
    decoding={decoding}
    fetchpriority={fetchpriority}
    /* Rebuild srcset from our local cached URLs */
    srcset={
      useSrcSet && !forceSize
        ? [
            xl ? `${xl} 1700w` : "",
            lg ? `${lg} 1400w` : "",
            md ? `${md} 1000w` : "",
            sm ? `${sm} 600w` : "",
          ]
            .filter(Boolean)
            .join(", ")
        : undefined
    }
  />
)}