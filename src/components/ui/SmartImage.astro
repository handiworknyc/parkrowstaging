---
// src/components/ui/SmartImage.astro

import type { ResponsiveImageMap } from "../../lib/images/responsive";
import {
  buildResponsiveSrcSet,
  getResponsivePrimarySrc,
} from "../../lib/images/responsive";

interface PictureSource {
  media: string;
  srcset: string;
  sizes?: string;
}

interface Props {
  images: ResponsiveImageMap;
  sizes?: string;
  alt?: string;
  imgClass?: string;
  critical?: boolean;
  fetchpriority?: "auto" | "high" | "low";
  useSrcSet?: boolean;
  forceSize?: "xl" | "large" | "med" | "small";
  panorama?: boolean; // Enable full-size image
  pictureSources?: PictureSource[];
}

const {
  images,
  sizes = "(max-width: 1200px) 40vw, 100vw",
  alt = "",
  imgClass = "",
  critical = false,
  fetchpriority = critical ? "high" : "auto",
  useSrcSet = true,
  forceSize,
  panorama = false,
  pictureSources = [],
} = Astro.props;
const srcSet = buildResponsiveSrcSet(images, { panorama });
const primarySrc = getResponsivePrimarySrc(images, { panorama, forceSize });

/* --------------------------------------------------------------------------
   CONFIG
-------------------------------------------------------------------------- */
const loading = critical ? "eager" : "lazy";
const decoding = critical ? "sync" : "async";
const className = ["hw-lazy-img", imgClass].filter(Boolean).join(" ");

const useSrcSetAttr = useSrcSet && !forceSize && srcSet;
const imgId = critical ? `crit-${crypto.randomUUID().slice(0, 8)}` : undefined;
const responsiveSources = pictureSources.filter(
  (source) => source?.media && source?.srcset
);
const hasPictureSources = responsiveSources.length > 0;
const imgSrcSetAttr = hasPictureSources ? undefined : useSrcSetAttr || undefined;
const imgSizesAttr =
  hasPictureSources ? undefined : useSrcSetAttr ? sizes : undefined;
---

{primarySrc && (
  <>
    {hasPictureSources ? (
      <picture>
        {responsiveSources.map((source) => (
          <source
            media={source.media}
            srcset={source.srcset}
            sizes={source.sizes || sizes}
          />
        ))}

        <img
          id={imgId}
          src={primarySrc}
          srcset={imgSrcSetAttr}
          sizes={imgSizesAttr}
          alt={alt}
          class={className}
          loading={loading}
          decoding={decoding}
          fetchpriority={fetchpriority}
        />
      </picture>
    ) : (
      <img
        id={imgId}
        src={useSrcSetAttr ? undefined : primarySrc}
        srcset={imgSrcSetAttr}
        sizes={imgSizesAttr}
        alt={alt}
        class={className}
        loading={loading}
        decoding={decoding}
        fetchpriority={fetchpriority}
      />
    )}

    {critical && imgId && (
      <script is:inline define:vars={{ imgId }}>
        (function () {
          const img = document.getElementById(imgId);
          if (!img) return;

          const setLoaded = () => {
            requestAnimationFrame(() => {
              requestAnimationFrame(() => {
				img.classList.add("lazy-loaded");

				const parent = img.closest(".img-load-par");

				if (parent) {
					parent.classList.add("child-lazy-loaded");
					parent.classList.add("crit-child-lazy-loaded");
				}

					window.dispatchEvent(
						new CustomEvent("critImgLoaded", {
							detail: {
							id: imgId,
							src: img.currentSrc || img.src,
							width: img.naturalWidth,
							height: img.naturalHeight,
							},
						})
					);
	              });
	            });
	          };

          if (img.complete && img.naturalWidth > 0) {
            setLoaded();
          } else if ("decode" in img) {
            img.decode().then(setLoaded).catch(() => {
              img.onload = setLoaded;
            });
          } else {
            img.onload = setLoaded;
          }
        })();
      </script>
    )}
  </>
)}
