---
interface Props {
  position?: 'header' | 'footer' | 'absolute';
  className?: string;
}

const { position = 'header', className = '' } = Astro.props;

const wrapperClass = [
  'language-switcher',
  'abs',
  className
].filter(Boolean).join(' ');
---

<div class={wrapperClass}>
  <div class="flex gap-2 items-center">
    <a
      id="lang-en"
      class="lang-btn px-3 py-1 rounded transition-colors"
      href="/"
    >
      EN
    </a>

    <span class="text-gray-400">|</span>

    <a
      id="lang-zh"
      class="lang-btn px-3 py-1 rounded transition-colors"
      href="/zh"
    >
      中文
    </a>
  </div>
</div>

<script>
  function updateLangUI() {
    const path = window.location.pathname.replace(/\/+$/, '');

    const isZh = path === '/zh' || path.startsWith('/zh/');
    const cleanPath = path.replace(/^\/zh/, '') || '/';

    const en = document.getElementById('lang-en');
    const zh = document.getElementById('lang-zh');
    if (!en || !zh) return;

    // ✅ Update hrefs
    en.href = cleanPath === '/' ? '/' : cleanPath;
    zh.href = cleanPath === '/' ? '/zh' : `/zh${cleanPath}`;

    // ✅ Highlight states
    en.classList.toggle('bg-pink', !isZh);
    en.classList.toggle('font-semibold', !isZh);
    en.classList.toggle('bg-gray-200', isZh);
    en.classList.toggle('text-gray-700', isZh);

    zh.classList.toggle('bg-pink', isZh);
    zh.classList.toggle('font-semibold', isZh);
    zh.classList.toggle('bg-gray-200', !isZh);
    zh.classList.toggle('text-gray-700', !isZh);
  }

  // Initial load
  updateLangUI();

  // Astro view transitions
  document.addEventListener('astro:after-swap', updateLangUI);
</script>

<style>
  .lang-btn {
    text-decoration: none;
    font-size: 0.875rem;
    font-weight: 500;
  }
</style>
