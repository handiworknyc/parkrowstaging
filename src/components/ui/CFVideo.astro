---
// CFVideo.astro

import SmartImage from "../ui/SmartImage.astro";

const v = Astro.props.video?.[0] ?? {};

const src = v.cf_stream_video || "";
const playOnHover = v.yt_hover === true;
const showControls = v.show_controls ?? false;
const playOnScroll = true;
const threshold = 0.6;

// Generate safe ID
let rawId =
  (v.id || v.cf_stream_video || "") +
  "-" +
  Math.random().toString(36).slice(2, 8);

const videoId = String(rawId).replace(/[^a-z0-9]/gi, "").slice(-12);

// Poster
const ytImg = v.yt_img || null;
const smartImg = ytImg
  ? {
      xl: ytImg.sizes?.intch_xl || ytImg.url,
      large: ytImg.sizes?.intch_lg || ytImg.url,
      med: ytImg.sizes?.intch_med || ytImg.url,
      small: ytImg.sizes?.intch_sm || ytImg.url,
    }
  : null;

const ytAlt = ytImg?.alt || "";
---

{/* Fallback image only if NO video */}
{!src && smartImg && (
  <SmartImage
    images={smartImg}
    alt={ytAlt}
    imgClass="abs-full of-cover hw-vid-poster-img"
    sizes="(max-width: 1200px) 60vw, 100vw"
  />
)}

{src && (
  <>
    <div
      id={`cfvideo-${videoId}`}
      class="hw-vid-wrap loading"
      data-id={videoId}
      data-src={`${src}?clientBandwidthHint=1000`}
      data-hover={playOnHover}
      data-scroll={playOnScroll}
      data-threshold={threshold}
    >

      {/* Poster only when controls are OFF */}
      {smartImg && !showControls && (
        <SmartImage
          images={smartImg}
          alt={ytAlt}
          imgClass="abs-full hw-vid-poster-img"
          sizes="(max-width: 1200px) 60vw, 100vw"
        />
      )}

      <video
        class={`abs-full video-js hw-vid-player vjs-default-skin show-controls-${showControls}`}
        muted
        autoplay
        playsinline
        preload="auto"
        disablePictureInPicture
        controlsList="nodownload noplaybackrate noremoteplayback"
      ></video>
    </div>

<script>
	import { initCFVideo } from "/src/scripts/videojs.js";

    const init = () => {
        // 1. Session Logic
        const isFirstLoad = !window.hwSessionLoaded;
        window.hwSessionLoaded = true;

        const videos = document.querySelectorAll('.hw-vid-wrap');
		const shouldAnimate = document.body.classList.contains('first-load');

        videos.forEach((vid) => {

            // 🛑 Prevent this video from being initialized more than once
            if (vid.dataset.initted === "true") return;
            vid.dataset.initted = "true";

            const id = vid.getAttribute('data-id');
            console.log("CFVideo init:", id);

            // 2. First-load transition logic
            if (shouldAnimate) {
                const onTransitionEnd = (e) => {
                    if (e.propertyName === 'opacity' && e.target === vid) {
                        vid.classList.remove('loading');
                        document.body.classList.remove('first-load');
                        vid.removeEventListener('transitionend', onTransitionEnd);
                    }
                };
                vid.addEventListener('transitionend', onTransitionEnd);
            } else {
                vid.classList.remove('loading');
            }

            // 3. Init Player
            if (id) {
                initCFVideo(id);
            }
        });
    };

    document.addEventListener('astro:page-load', init);
</script>

  </>
)}
