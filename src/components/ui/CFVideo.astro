---
import SmartImage from "../ui/SmartImage.astro";
import { buildStreamUrl } from "../../lib/video/stream";
import type { WpImageLike } from "../../lib/images/responsive";
import {
  buildResponsiveSrcSet,
  extractWpResponsiveImages,
  normalizeResponsiveBreakpoint,
} from "../../lib/images/responsive";

/* ---------------- Types ---------------- */
interface VideoData {
  id?: string;
  cf_stream_video?: string;
  cf_stream_mob?: string | false;
  yt_hover?: boolean;
  show_controls?: boolean;
  panorama?: boolean; // Panorama flag
  yt_img?: WpImageLike & {
    alt?: string;
  };
  yt_img_mob?: (WpImageLike & {
    alt?: string;
  }) | false;
  mob_img_breakpoint?: string | number | null;
}

interface Props {
  video?: VideoData[];
  usePosterSrcSet?: boolean;
  posterForceSize?: "xl" | "large" | "med" | "small";
  critical?: boolean;
  panorama?: boolean; // Allow external panorama override
  enableResponsivePoster?: boolean;
}

/* ---------------- Props ---------------- */
const {
  video,
  usePosterSrcSet = true,
  posterForceSize,
  critical = false,
  panorama: externalPanorama,
  enableResponsivePoster = false,
} = Astro.props;

/* ---------------- Constants ---------------- */
const VIDEO_CONFIG = {
  PLAY_ON_SCROLL: true,
  SCROLL_THRESHOLD: 0.6,
  DEFAULT_SIZES: "(max-width: 1200px) 60vw, 100vw",
  HERO_SIZES: "100vw",
} as const;

/* ---------------- Helpers ---------------- */
function generateVideoId(videoData: VideoData): string {
  const seed = videoData.id || videoData.cf_stream_video || "";
  const random = Math.random().toString(36).slice(2, 8);
  const rawId = `${seed}-${random}`;
  
  return rawId.replace(/[^a-z0-9]/gi, "").slice(-12);
}

/* ---------------- Data Extraction ---------------- */
const videoData = video?.[0];
if (!videoData) {
  throw new Error("[CFVideo] No video data provided");
}

const desktopStreamUrl =
  typeof videoData.cf_stream_video === "string"
    ? videoData.cf_stream_video.trim()
    : "";
const playOnHover = videoData.yt_hover === true;
const showControls = videoData.show_controls ?? false;
const desktopPosterImages = extractWpResponsiveImages(videoData.yt_img);
const mobilePosterImages = enableResponsivePoster
  ? extractWpResponsiveImages(videoData.yt_img_mob || null)
  : null;
const posterImages = desktopPosterImages || mobilePosterImages;
const mobilePosterAlt =
  videoData.yt_img_mob && typeof videoData.yt_img_mob === "object"
    ? videoData.yt_img_mob.alt || ""
    : "";
const posterAlt = videoData.yt_img?.alt || mobilePosterAlt || "";
const responsiveMediaBreakpoint = enableResponsivePoster
  ? normalizeResponsiveBreakpoint(videoData.mob_img_breakpoint)
  : null;
const responsiveMobileStreamUrl =
  enableResponsivePoster && typeof videoData.cf_stream_mob === "string"
    ? videoData.cf_stream_mob.trim()
    : "";

// Determine if this is a panorama video
// Priority: external prop > video data property
const isPanorama = externalPanorama ?? videoData.panorama ?? false;

const videoId = generateVideoId(videoData);
const desktopVideoSrc = desktopStreamUrl
  ? buildStreamUrl(desktopStreamUrl, null)
  : "";
const hasResponsiveMobileStream =
  !!responsiveMobileStreamUrl && !!responsiveMediaBreakpoint;
const hasAnyStream = !!desktopVideoSrc || hasResponsiveMobileStream;
const posterSizes = enableResponsivePoster
  ? VIDEO_CONFIG.HERO_SIZES
  : VIDEO_CONFIG.DEFAULT_SIZES;
const responsivePosterSrcSet =
  mobilePosterImages && responsiveMediaBreakpoint
    ? buildResponsiveSrcSet(mobilePosterImages, { panorama: isPanorama })
    : undefined;
const responsivePosterSources =
  responsivePosterSrcSet && responsiveMediaBreakpoint
    ? [
        {
          media: `(max-width: ${responsiveMediaBreakpoint}px)`,
          srcset: responsivePosterSrcSet,
          sizes: posterSizes,
        },
      ]
    : undefined;

/* ---------------- Component Config ---------------- */
const posterProps = {
  images: posterImages,
  alt: posterAlt,
  imgClass: "abs-full of-cover hw-vid-poster-img",
  sizes: posterSizes,
  useSrcSet: usePosterSrcSet,
  forceSize: posterForceSize,
  critical,
  panorama: isPanorama, // Pass panorama flag to SmartImage
  pictureSources: responsivePosterSources,
};

// ✅ CRITICAL FIX 1: If critical, do not render 'loading' class on server
// This ensures the poster is visible the exact millisecond HTML is parsed.
const wrapperClass = `hw-vid-wrap ${!critical ? "loading" : ""}`;
---

{/* Fallback: Image only (no video) */}
{!hasAnyStream && posterImages && (
  <SmartImage {...posterProps} />
)}

{/* Video player */}
{hasAnyStream && (
  <>
    <div
      id={`cfvideo-${videoId}`}
      class={wrapperClass}
      data-id={videoId}
      data-src={desktopVideoSrc || undefined}
      data-src-mobile={responsiveMobileStreamUrl || undefined}
      data-mobile-breakpoint={responsiveMediaBreakpoint || undefined}
      data-hover={playOnHover}
      data-critical={critical} 
      data-scroll={VIDEO_CONFIG.PLAY_ON_SCROLL}
      data-threshold={VIDEO_CONFIG.SCROLL_THRESHOLD}
    >
      {/* Poster (only when controls are disabled) */}
      {posterImages && !showControls && (
        <SmartImage {...posterProps} imgClass="abs-full hw-vid-poster-img" />
      )}

      <video
        class={`abs-full video-js hw-vid-player vjs-default-skin show-controls-${showControls}`}
        muted
        playsinline
        loop={critical} 
        preload={critical ? "auto" : "metadata"}
        disablePictureInPicture
        controlsList="nodownload noplaybackrate noremoteplayback"
      ></video>
    </div>

    <script>
      import { initCFVideo } from "/src/scripts/videojs.js";

      const CONFIG = {
        SELECTOR: ".hw-vid-wrap",
        FIRST_LOAD_CLASS: "first-load",
        LOADING_CLASS: "loading",
      };

      function isFirstLoad(): boolean {
        return HW.$html.classList.contains(CONFIG.FIRST_LOAD_CLASS);
      }

      function removeLoadingState(element: HTMLElement, animated: boolean): void {
        // If the class is already gone (critical case handled by server), just return
        if (!element.classList.contains(CONFIG.LOADING_CLASS)) return;

        if (!animated) {
          element.classList.remove(CONFIG.LOADING_CLASS);
          return;
        }

        const handleTransitionEnd = (e: TransitionEvent) => {
          if (e.propertyName === "opacity" && e.target === element) {
            element.classList.remove(CONFIG.LOADING_CLASS);
            HW.$html.classList.remove(CONFIG.FIRST_LOAD_CLASS);
            element.removeEventListener("transitionend", handleTransitionEnd);
          }
        };

        element.addEventListener("transitionend", handleTransitionEnd);
      }

      function runAfterFrames(callback: () => void, frames = 1): void {
        if (frames <= 0) {
          callback();
          return;
        }

        requestAnimationFrame(() => {
          runAfterFrames(callback, frames - 1);
        });
      }

      function initVideo(element: HTMLElement, reason: string): void {
        const id = element.getAttribute("data-id");
        if (!id) return;
        
        // ✅ CRITICAL FIX 2: Detect critical status
        const isCritical = element.getAttribute("data-critical") === "true";

        // For critical videos, NEVER animate the loading state (it causes delay on mobile)
        const shouldAnimate = isFirstLoad() && !isCritical;
        
        removeLoadingState(element, shouldAnimate);

        // ✅ CRITICAL FIX 3: Prioritize execution
        if (isCritical) {
          // Initialize immediately on the main thread
          initCFVideo(id, reason);
        } else {
          // Defer non-critical videos to save resources
          requestAnimationFrame(() => {
            initCFVideo(id, reason);
          });
        }
      }

      function initAllVideos(reason: string): void {
        const videos = document.querySelectorAll(CONFIG.SELECTOR);

        videos.forEach((video) => {
          initVideo(video as HTMLElement, reason);
        });
      }

      function scheduleInitAllVideos(reason: string, frames = 1): void {
        runAfterFrames(() => {
          initAllVideos(reason);
        }, frames);
      }

      const bootKey = "__HW_CFVIDEO_BOOTSTRAPPED__";
      const win = window as Window & Record<string, boolean | undefined>;

      if (!win[bootKey]) {
        win[bootKey] = true;
        document.addEventListener("astro:page-load", () => {
          scheduleInitAllVideos("astro:page-load", 1);
        });

        document.addEventListener("astro:after-swap", () => {
          scheduleInitAllVideos("astro:after-swap", 2);
        });
      }

      if (document.readyState === "loading") {
        document.addEventListener("DOMContentLoaded", () => {
          scheduleInitAllVideos("DOMContentLoaded", 1);
        }, { once: true });
      } else {
        scheduleInitAllVideos("boot", 1);
      }
    </script>
  </>
)}
