<!-- Inline JSON payload (SSR-safe, no globals) -->
<script
  id="header-menu-cn"
  type="application/json"
  is:inline
  set:html={JSON.stringify(headerMenuCN)}
></script>

<script is:inline>
  function debugChineseMenuInjection() {
    console.group("🇨🇳 Header Menu CN Debug");

    // 1️⃣ Is the JSON payload present?
    const dataEl = document.getElementById("header-menu-cn");
    console.log("JSON element found:", !!dataEl);

    if (!dataEl) {
      console.error("❌ #header-menu-cn script tag not found");
      console.groupEnd();
      return;
    }

    let CN_MAP = {};
    try {
      CN_MAP = JSON.parse(dataEl.textContent || "{}");
    } catch (e) {
      console.error("❌ Failed to parse CN JSON", e);
      console.groupEnd();
      return;
    }

    console.log("CN_MAP:", CN_MAP);
    console.log("CN_MAP keys:", Object.keys(CN_MAP));

    // 2️⃣ What menu <li>s actually exist?
    const allLis = [...document.querySelectorAll("#main-nav li")];
    console.log(
      "Menu <li> count:",
      allLis.length
    );
    console.log(
      "Menu <li> classes:",
      allLis.map(li => li.className)
    );

    // 3️⃣ Try to resolve each CN item
    for (const [id, cn] of Object.entries(CN_MAP)) {
      console.group(`Menu item ID ${id}`);

      const liByClass = document.querySelector(`.menu-item-${id}`);
      const liById = document.getElementById(`nav-menu-item-${id}`);

      console.log("li via .menu-item-ID:", liByClass);
      console.log("li via #nav-menu-item-ID:", liById);

      const li = liByClass || liById;
      if (!li) {
        console.error("❌ No <li> found for menu item", id);
        console.groupEnd();
        continue;
      }

      const link = li.querySelector("a");
      console.log("<a> found:", link);

      if (!link) {
        console.error("❌ No <a> inside menu item", id);
        console.groupEnd();
        continue;
      }

      const enSpan = link.querySelector(".header-link--title");
      const cnSpan = link.querySelector(".header-link--title-cn");

      console.log("EN span exists:", !!enSpan);
      console.log("CN span exists:", !!cnSpan);

      // Inject visibly for debugging
      if (!enSpan) {
        const s = document.createElement("span");
        s.className = "header-link--title";
        s.textContent = link.textContent || "";
        link.textContent = "";
        link.appendChild(s);
        console.log("✅ EN span injected");
      }

		if (!cnSpan) {
		const s = document.createElement("span");
		s.className = "header-link--title-cn";
		s.textContent = cn;
		link.appendChild(s);

		link.classList.add("has-cn-title"); // ✅ ALWAYS add
		}

      console.groupEnd();
    }

    console.groupEnd();
  }


document.addEventListener("astro:page-load", debugChineseMenuInjection);
document.addEventListener("astro:after-swap", debugChineseMenuInjection);

</script>






<script>
  import initStickyHeader from "/src/scripts/sticky-header.ts";
  import { animate } from "motion";

  function initNav() {
    initStickyHeader();

    const toggle = document.querySelector(".nav-toggle");
    const wrapper = document.querySelector(".nav-toggle-wrap") || toggle;
    const modal = document.querySelector("#main-nav[data-nav-modal]");
    const logoSvg = document.getElementById("logo-svg");
    const html = document.documentElement;

    if (!toggle || !modal) return;
    const getClosedLogoFill = () =>
      html.classList.contains("penthouses") ? "var(--white)" : "var(--darkgreen)";
    const syncLogoState = () => {
      if (!logoSvg) return;

      const isMenuOpen = modal.classList.contains("open");
      const closedLogoFill = getClosedLogoFill();
      logoSvg.style.setProperty("--logo-fill", isMenuOpen ? "var(--pink)" : closedLogoFill);
      logoSvg.style.setProperty("--bofa-fill", closedLogoFill);
      logoSvg.style.setProperty("--bofa-op", isMenuOpen ? "0" : "1");
    };

    syncLogoState();
    if ((toggle as any)._navBound) return;
    (toggle as any)._navBound = true;

    const ul = modal.querySelector("ul");

    // -----------------------------------------------------------------------
    // HOVER INTERACTIONS
    // -----------------------------------------------------------------------
    if (wrapper) {
      const wrapEl = wrapper as HTMLElement;
      const elasticEase = [0.175, 0.885, 0.32, 1.275];

      wrapEl.addEventListener("mouseenter", () => {
        animate(wrapEl, { scale: 0.95, y: "-50%" }, { duration: 0.05, easing: elasticEase });
      });

      wrapEl.addEventListener("mouseleave", () => {
        animate(wrapEl, { scale: 1, y: "-50%" }, { duration: 0.05, easing: elasticEase });
      });

      wrapEl.addEventListener("click", () => {
        wrapEl.style.transform = "";
      });
    }

    // -----------------------------------------------------------------------
    // MENU LOGIC
    // -----------------------------------------------------------------------
    const clearStates = () => {
      html.classList.remove("modal-opening", "modal-opened", "modal-closing", "modal-closed");
    };

    const openMenu = () => {
      clearStates();
      html.classList.add("modal-opening", "modal-open");
      toggle.classList.add("active");
      modal.classList.add("open");

      if (typeof window.locoScroll !== "undefined") {
        window.locoScroll.stop();
      }

      if (ul) ul.classList.add("sal-animate");

      if (logoSvg) {
        animate(logoSvg, { "--logo-fill": "var(--pink)", "--bofa-op": 0 }, { duration: 0.3 });
      }
    };

    const closeMenu = () => {
      clearStates();
      html.classList.add("modal-closing");
      toggle.classList.remove("active");
      modal.classList.remove("open");
      html.classList.remove("modal-open");

      if (ul) ul.classList.remove("sal-animate");

      if (logoSvg) {
        animate(logoSvg, { "--logo-fill": getClosedLogoFill(), "--bofa-op": 1 }, { duration: 0.3 });
      }

      if (typeof window.locoScroll !== "undefined") {
        window.locoScroll.start();
      }
    };

    toggle.addEventListener("click", (e) => {
      e.stopPropagation();
      modal.classList.contains("open") ? closeMenu() : openMenu();
    });

    modal.addEventListener("click", (e) => {
      if ((e.target as HTMLElement).closest("a")) closeMenu();
    });

    modal.addEventListener("transitionend", () => {
      if (modal.classList.contains("open")) {
        html.classList.remove("modal-opening");
        html.classList.add("modal-opened");
      } else {
        html.classList.remove("modal-closing");
        html.classList.add("modal-closed");
      }
    });
  }

  document.addEventListener("astro:page-load", initNav);
</script>



<script is:inline>
  function localizeHeaderLinks() {
    const isZh =
      location.pathname === "/zh" ||
      location.pathname.startsWith("/zh/");

    const logoLink = document.getElementById("header-logo-a");
    if (logoLink) {
      logoLink.setAttribute("href", isZh ? "/zh" : "/");
    }

    const nav = document.getElementById("main-nav");
    if (!nav) return;

    nav.querySelectorAll("a[href]").forEach(a => {
      const href = a.getAttribute("href");
      if (!href) return;

      // Ignore external + special links
      if (
        href.startsWith("http") ||
        href.startsWith("#") ||
        href.startsWith("mailto:") ||
        href.startsWith("tel:")
      ) {
        return;
      }

      // Strip any existing /zh
      let clean = href.replace(/^\/zh/, "") || "/";

      // Apply language
      const next = isZh
        ? clean === "/" ? "/zh" : `/zh${clean}`
        : clean;

      a.setAttribute("href", next);
    });
  }

  // Initial load
  document.addEventListener("astro:page-load", localizeHeaderLinks);

  // View transition navigation
  document.addEventListener("astro:after-swap", localizeHeaderLinks);
</script>




