---
import { getHeaderMenu } from "../lib/wp/getHeaderMenu";
import { getHeaderMenuCN } from "../lib/wp/getHeaderMenuCn";
import { getHideLanguage } from "../lib/wp/getHideLanguage";
import LanguageSwitcher from "../components/ui/LanguageSwitcher.astro";

interface Props {
  lang?: "en" | "zh";
}

// -----------------------------------------------------------------------------
// SETTINGS
// -----------------------------------------------------------------------------
const WP_BASE_URL = (import.meta.env.WP_BASE_URL || "")
  .trim()
  .replace(/\/$/, "");
const { lang = "en" } = Astro.props as Props;
const homeHref = lang === "zh" ? "/zh" : "/";

// -----------------------------------------------------------------------------
// ⚡ GLOBAL NAV CACHE (HTML ONLY)
// -----------------------------------------------------------------------------
let _cachedHeaderMenu: string | null = null;

// -----------------------------------------------------------------------------
// 🚀 FAST URL REWRITE
// -----------------------------------------------------------------------------
function fastRewrite(html: string, baseUrl: string) {
  if (!html || !baseUrl) return html;
  let processed = html.replaceAll(baseUrl, "");
  processed = processed.replaceAll('href="//', 'href="/');
  return processed;
}

// -----------------------------------------------------------------------------
// FETCH & PROCESS (HTML)
// -----------------------------------------------------------------------------
if (!_cachedHeaderMenu) {
  try {
    const raw = await getHeaderMenu();
    let html = raw;

    if (raw && raw.trim().startsWith('"') && raw.includes("<li")) {
      try { html = JSON.parse(raw); } catch {}
    }

    _cachedHeaderMenu = fastRewrite(html, WP_BASE_URL);
  } catch (err) {
    console.error("[SiteNav] Error:", err);
    _cachedHeaderMenu = "";
  }
}

// -----------------------------------------------------------------------------
// FETCH CN TITLES (SEPARATE, SAFE)
// -----------------------------------------------------------------------------
const headerMenuCN = await getHeaderMenuCN();
const hideLanguage = await getHideLanguage();


const headerMenu = _cachedHeaderMenu;
