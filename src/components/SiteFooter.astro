---
import address from "../content/wp/schema-address.json";

const hasAddress = address && address.streetAddress;
const { lang = "en" } = Astro.props;
const langPrefix = lang === "zh" ? "/zh" : "";
const termsHref = `${langPrefix}/terms-of-use/`;
const privacyHref = `${langPrefix}/privacy-policy/`;
---

<div class="site-footer bg-darkgreen pt-14 pb-14 c-white" id="footer" transition:persist>
  <div class="hw-contain">
    <div class="footer-content">
      <div class="footer-top mb-5 items-start text-[1.1rem] flex-wrap">
        <div
          class="address text-white/50"
          {...(hasAddress
            ? {
                itemscope: true,
                itemtype: "https://schema.org/PostalAddress",
              }
            : {})}
        >
          {hasAddress && (
            <>
              {address.name && (
                <div class="address-title caps c-white relative -top-[1.5px] tracking-[.03em]" itemprop="name">
                  {address.name}
                </div>
              )}

              <div class="address-lines">
                <span itemprop="streetAddress">{address.streetAddress}</span>
                <br />
                <span itemprop="addressLocality">
                  {address.addressLocality}
                </span>
                ,{" "}
                <span itemprop="addressRegion">
                  {address.addressRegion}
                </span>{" "}
                <span itemprop="postalCode">
                  {address.postalCode}
                </span>
              </div>
            </>
          )}
        </div>

	    <div class="footer-somed ml-auto">
		  <div>
			  <a href="https://www.facebook.com/ParkRowBellevue">
				  <img src="/images/fb.svg" loading="lazy" alt="Facebook profile" />
			  </a>
			  <a href="https://www.instagram.com/parkrowbellevue">
				  <img src="/images/insta.svg" class='insta' loading="lazy" alt="Instagram profile" />
			  </a>
		  </div>

		  <a class="caps press-link" style="display: none" href="">Press</a>
	    </div>
      </div>

      <div class="footer-bottom justify-start flex-wrap pt-7">
		
        <a href="https://bosadevleopment.com">
          <img src="/images/bosa-logo.svg" loading="lazy" alt="Bosa Development Logo" />
        </a>

        <div class="footer-bottom-right ml-auto items-end">
          <div class="footer-meta-links" aria-label="Cookie settings and legal links">
            <button
              type="button"
              class="footer-meta-link footer-cookie-trigger"
              data-cookie-settings-open
              aria-controls="footer-cookie-overlay"
              aria-haspopup="dialog"
            >
              Cookie Settings
            </button>
            <a class="footer-meta-link" href={termsHref}>Terms of Use</a>
            <a class="footer-meta-link" href={privacyHref}>Privacy Policy</a>
          </div>

          <a class="footer-housing-link" href="">
            <img src="/images/equal-housing.svg" loading="lazy" alt="Equal Opportunity Housing" />
          </a>
        </div>
      </div>
    </div>
  </div>

  <div id="footer-cookie-overlay" class="footer-cookie-overlay" aria-hidden="true">
    <div class="hw-contain footer-cookie-overlay-inner">
      <div
        class="footer-cookie-panel"
        role="dialog"
        aria-modal="false"
        aria-labelledby="footer-cookie-title"
      >
        <div id="footer-cookie-title" class="footer-cookie-kicker">Cookie Settings</div>

        <p class="footer-cookie-text">
          We use cookies and other technologies for marketing, to analyze site performance,
          and to improve your experience on our site. We also share information about your
          use of our site with our social media, advertising and analytics partners using
          these technologies. By clicking "Accept" you agree to the use of these
          technologies as described in our
          <a href={privacyHref}>Privacy Policy</a>. If you click Reject, only strictly
          necessary technologies will be used.
        </p>

        <div class="footer-cookie-actions">
          <button type="button" class="footer-cookie-button" data-cookie-consent="accepted">
            Accept
          </button>
          <button
            type="button"
            class="footer-cookie-button is-secondary"
            data-cookie-consent="rejected"
          >
            Reject
          </button>
        </div>
      </div>
    </div>
  </div>
</div>

<style lang="scss">
  .site-footer {
    position: relative;
    overflow: hidden;
  }

  .footer-content {
    transition: filter 0.25s var(--cubicBez);
    will-change: filter;
  }

  :global(.cookie-settings-open) .footer-content {
    filter: blur(10px);
  }

  .footer-bottom-right {
    display: flex;
    align-items: flex-end;
    gap: 1.75rem;
  }

  .footer-housing-link {
    display: inline-flex;
    align-items: flex-end;
    flex: 0 0 auto;
  }

  .footer-meta-links {
    display: flex;
    align-items: center;
    justify-content: flex-end;
    flex-wrap: wrap;
    gap: 0.5rem 1.35rem;
  }

  .footer-meta-link {
    appearance: none;
    border: 0;
    background: transparent;
    padding: 0;
    cursor: pointer;
    text-decoration: none;
    color: rgba(255, 255, 255, 0.5);
    font-size: 1.08rem;
    line-height: 1.4;
    transition: color 0.2s ease, opacity 0.2s ease;

    &:hover,
    &:focus-visible {
      color: rgba(255, 255, 255, 0.9);
    }
  }

  .footer-cookie-overlay {
    position: fixed;
    inset: 0;
    z-index: 9999;
    display: flex;
    align-items: flex-end;
    justify-content: center;
    padding: 1rem clamp(1rem, 2.5vw, 2rem)
      max(1rem, calc(env(safe-area-inset-bottom) + 1rem));
    background: linear-gradient(180deg, rgba(0, 0, 0, 0) 30%, rgba(0, 0, 0, 0.16) 100%);
    opacity: 0;
    visibility: hidden;
    pointer-events: none;
    transform: translateY(1rem);
    transition:
      opacity 0.28s ease,
      visibility 0.28s ease,
      transform 0.28s ease;

    &.is-active {
      opacity: 1;
      visibility: visible;
      pointer-events: auto;
      transform: translateY(0);
    }
  }

  .footer-cookie-overlay-inner {
    width: min(100%, 112rem);
    display: flex;
    align-items: flex-end;
  }

  .footer-cookie-panel {
    width: 100%;
    display: grid;
    grid-template-columns: auto minmax(0, 1fr) auto;
    grid-template-areas: "title text actions";
    align-items: flex-start;
    gap: 2rem;
    padding: clamp(1.15rem, 1rem + 1vw, 1.8rem);
    background: var(--darkgreen);
    border: 0;
    border-radius: 1rem;
    box-shadow: 0 -24px 50px rgba(0, 0, 0, 0.24);
  }

  .footer-cookie-kicker {
    grid-area: title;
    margin: 0;
    font-size: clamp(1rem, 0.82rem + 1vw, 1.65rem);
    line-height: 1;
    color: rgba(255, 255, 255, 0.55);
  }

  .footer-cookie-text {
    grid-area: text;
    margin: 0;
    padding: 0;
    font-size: 1rem;
    line-height: 1.55;
    color: rgba(255, 255, 255, 0.78);

    a {
      color: var(--white);
      text-decoration: underline;
      text-underline-offset: 0.18em;
    }
  }

  .footer-cookie-actions {
    grid-area: actions;
    display: inline-flex;
    align-items: center;
    justify-content: flex-end;
    gap: 1rem;
    flex-wrap: wrap;
  }

  .footer-cookie-button {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    appearance: none;
    border-radius: 999px;
    min-width: 120px;
    padding: 0.92rem 1.35rem;
    cursor: pointer;
    font-size: 1.08rem;
    line-height: 1;
    flex: 0 0 auto;
    transition: border-color 0.2s ease, background-color 0.2s ease, color 0.2s ease;
    border: 1px solid rgba(255, 255, 255, 0.32);
    background: rgba(255, 255, 255, 0.12);
    color: var(--white);

    &.is-active {
      background: var(--white);
      border-color: var(--white);
      color: var(--darkgreen);
    }

    &:hover,
    &:focus-visible {
      background: var(--white);
      border-color: var(--white);
      color: var(--darkgreen);
    }

    &.is-secondary {
      background: transparent;

      &:hover,
      &:focus-visible {
        background: rgba(255, 255, 255, 0.15);
        border-color: var(--white);
        color: #fff;
      }
    }
  }

  @media all and (max-width: 1159px) {
    .footer-cookie-panel {
      grid-template-columns: minmax(0, 1fr) auto;
      grid-template-areas:
        "title actions"
        "text text";
    }
  }

  @media all and (max-width: 59.375em) {
    .footer-bottom-right {
      width: 100%;
      margin-top: 1.5rem;
      justify-content: space-between;
      gap: 1rem;
    }

    .footer-meta-links {
      justify-content: flex-start;
    }
  }

  @media all and (max-width: 40em) {
    .footer-cookie-overlay {
      padding-left: 0.75rem;
      padding-right: 0.75rem;
      padding-bottom: max(0.75rem, calc(env(safe-area-inset-bottom) + 0.75rem));
    }

    .footer-meta-links {
      gap: 0.35rem 1rem;
    }

    .footer-cookie-panel {
      grid-template-columns: 1fr;
      grid-template-areas:
        "title"
        "text"
        "actions";
    }

    .footer-cookie-text {
      padding: 0;
    }

    .footer-cookie-actions {
      width: 100%;
      flex-direction: column;
      gap: 1rem;
    }

    .footer-cookie-button {
      width: 100%;
    }
  }
</style>

<script>
  function initFooterCookieSettings() {
    const footer = document.getElementById("footer");
    if (!footer) return;

    const overlay = footer.querySelector("#footer-cookie-overlay");
    const openButtons = footer.querySelectorAll("[data-cookie-settings-open]");
    const consentButtons = footer.querySelectorAll("[data-cookie-consent]");
    const acceptButton = footer.querySelector('[data-cookie-consent="accepted"]');

    if (!overlay || consentButtons.length === 0) return;

    const consentApi = window.ParkRowConsent;
    const hasStoredConsent = () => {
      const value = consentApi?.read?.();
      return value === "accepted" || value === "rejected";
    };

    const shouldWaitForSplash = () => {
      if (hasStoredConsent()) return false;

      return (
        document.documentElement.classList.contains("home") &&
        !!document.querySelector("[data-splash-video]") &&
        window.hwSplashActive === true &&
        !document.documentElement.classList.contains("splash-dismissed")
      );
    };

    const clearPendingAutoOpen = () => {
      if (typeof footer._cookieSplashDismissHandler !== "function") return;

      window.removeEventListener("splash:dismiss", footer._cookieSplashDismissHandler);
      footer._cookieSplashDismissHandler = null;
    };

    const setOverlayOpen = (isOpen, trigger) => {
      document.documentElement.classList.toggle("cookie-settings-open", isOpen);
      overlay.classList.toggle("is-active", isOpen);
      overlay.setAttribute("aria-hidden", String(!isOpen));

      if (isOpen) {
        footer._cookieSettingsTrigger = trigger || document.activeElement;
        window.requestAnimationFrame(() => acceptButton?.focus());
        return;
      }

      const lastTrigger = footer._cookieSettingsTrigger;
      if (lastTrigger instanceof HTMLElement) {
        lastTrigger.focus();
      }
    };

    const maybeAutoOpen = () => {
      clearPendingAutoOpen();

      if (hasStoredConsent()) {
        setOverlayOpen(false);
        return;
      }

      if (shouldWaitForSplash()) {
        const onSplashDismiss = () => {
          footer._cookieSplashDismissHandler = null;
          setOverlayOpen(true);
        };

        footer._cookieSplashDismissHandler = onSplashDismiss;
        window.addEventListener("splash:dismiss", onSplashDismiss, { once: true });
        return;
      }

      setOverlayOpen(true);
    };

    if (footer.dataset.cookieSettingsReady !== "true") {
      footer.dataset.cookieSettingsReady = "true";

      openButtons.forEach((button) => {
        button.addEventListener("click", (event) => {
          event.preventDefault();
          clearPendingAutoOpen();
          setOverlayOpen(true, button);
        });
      });

      overlay.addEventListener("click", (event) => {
        if (event.target === overlay) {
          setOverlayOpen(false);
        }
      });

      consentButtons.forEach((button) => {
        button.addEventListener("click", () => {
          const value = button.dataset.cookieConsent;
          if (!value || !consentApi?.write) return;

          clearPendingAutoOpen();
          consentApi.write(value);
          setOverlayOpen(false);
        });
      });

      document.addEventListener("keydown", (event) => {
        if (event.key === "Escape" && overlay.classList.contains("is-active")) {
          setOverlayOpen(false);
        }
      });
    }

    maybeAutoOpen();
  }

  initFooterCookieSettings();
  document.addEventListener("astro:page-load", initFooterCookieSettings);
</script>
