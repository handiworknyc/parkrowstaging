---
// Props
const {
  layout_settings = {},
  h1 = "",
  h2 = "",
  description = "",
  smaller_text = false,
  className = ""
} = Astro.props;

// Destructure layout settings
const {
  section_title = "",
  section_h2 = "",
  section_text = "",
  green_bg = false,
  section_text_below = false,
  section_class = ""
} = layout_settings;

// ------------------
// FALLBACK LOGIC
// ------------------
const pageTitle   = h1 || section_title || "";
const pageSubhead = h2 || section_h2 || "";
const pageText    = description || section_text || "";

// ------------------
// STATE
// ------------------
const hasSubhead = !!pageSubhead;

// ------------------
// SLOT STATE (OPTIONAL)
// ------------------
const hasSlot = Astro.slots?.default;

// ------------------
// CLASS MERGE
// ------------------
const sectionClass = [
  "page-title-wrap",
  green_bg && "bg-green-600",
  section_text_below && "text-below",
  section_class,
  className
].filter(Boolean).join(" ");
---

<section class={sectionClass}>
  <div class="hw-contain text-center page-title-wrap-inner">

    {/* H1 */}
    {pageTitle && (
      <h1 class="antiga text-[3.75rem]">
        {pageTitle}
      </h1>
    )}

    {/* H2 */}
    {pageSubhead && (
      <h2 class="figure text-[1.75rem] leading-[2.75rem] max-w-[25em] mx-auto">
        {pageSubhead}
      </h2>
    )}

    {/* Description */}
    {pageText && (
      <div
        class={
          hasSubhead
            ? "text-[1.25rem] mx-auto"
            : smaller_text
              ? "text-[1.25rem] max-w-[36em] leading-[1.75rem] mx-auto"
              : "figure text-[1.75rem] max-w-[25em] leading-[2.75rem] mx-auto"
        }
        set:html={pageText}
      />
    )}

    {/* ✅ OPTIONAL SLOT (confirmation message, etc.) */}
    {hasSlot && (
      <div class="figure text-[1.75rem] max-w-[25em] leading-[2.75rem] mx-auto">
        <slot />
      </div>
    )}

  </div>
</section>
