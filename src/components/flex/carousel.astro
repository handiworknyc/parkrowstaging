---
import ImageCarousel from "../react/ImageCarousel.jsx";
import fslightboxScriptUrl from "../../scripts/plugins/fslightbox.js?url";
import "../../styles/fslightbox.css";
import {
  renderFlatListItemsHtml,
  renderTwoColListItemsHtml,
  splitListItems,
} from "../../lib/contentLists.js";

const DEBUG_CAROUSEL_LIGHTBOX = false;

/* ---------------- Props ---------------- */
interface Props {
  label_above?: string;
  content?: any[];
  images?: any[];
  caption?: string;
  caption_pos?: "left" | "center" | "right";
  natural_aspect?: boolean;
  bleed?: boolean;
  rowIndex?: number;
}

const {
  label_above = "",
  content = [],
  images = [],
  caption = "",
  caption_pos = "left",
  natural_aspect = false,
  bleed = false,
  rowIndex = 0,
} = Astro.props;

/* ---------------- Helpers ---------------- */
function getColumnClass(index: number, total: number): string {
  if (total === 1) {
    return "min-[990px]:col-5 max-[990px]:col-12 column-content";
  }
  
  if (index === 1) {
    const mobileMt = content[1]?.title ? "max-[990px]:mt-20" : "max-[990px]:mt-6";
    return `min-[1050px]:col-4 min-[990px]:col-5 min-[1050px]:push-2 min-[990px]:push-1 ${mobileMt} max-[990px]:col-12 column-content`;
  }
  
  return "min-[1050px]:col-4 min-[990px]:col-5 col-12 column-content";
}

function getCarouselImageData(item: any) {
  if (typeof item === "string") {
    return { url: item };
  }

  if (typeof item?.image === "string") {
    return { url: item.image };
  }

  if (item?.image && typeof item.image === "object") {
    return item.image;
  }

  if (item && typeof item === "object" && (item.url || item.src || item.sizes)) {
    return item;
  }

  return null;
}

/* ---------------- Data Processing ---------------- */
const processedContent = Array.isArray(content)
  ? content.map((item) => ({
      title: item.title || "",
      text: item.text || "",
      twoColList: item.two_col_list || false,
      listItems: splitListItems(item.list),
    }))
  : [];

const carouselImages = Array.isArray(images)
  ? images.flatMap((item, index) => {
      const imgData = getCarouselImageData(item);
      const mediumUrl = imgData?.sizes?.intch_med;
      const imageUrl = mediumUrl || imgData?.url || imgData?.src;

      if (!imgData || !imageUrl) {
        return [];
      }

      const lightboxUrl =
        imgData.sizes?.intch_xl ||
        imgData.sizes?.["2048x2048"] ||
        imgData.sizes?.large ||
        imgData.url ||
        imgData.src ||
        imageUrl;

      return [
        {
          id: imgData.ID || imgData.id || index,
          src: imageUrl,
          lightboxSrc: lightboxUrl,
          alt: imgData.alt || imgData.title || `Image ${index + 1}`,
          caption: item?.caption || "",
          slideContent: Array.isArray(item?.slide_content) ? item.slide_content : null,
          aspectRatio:
            imgData.width && imgData.height
              ? imgData.width / imgData.height
              : 4 / 3,
        },
      ];
    })
  : [];

/* ---------------- HTML Generation ---------------- */
const contentColumnsHTML = processedContent
  .map((item, index) => {
    const cssClass = getColumnClass(index, processedContent.length);
    const ulClass = `section-text ${item.twoColList ? "two-col-list" : ""}`.trim();
    const listItemsHtml = item.twoColList
      ? renderTwoColListItemsHtml(item.listItems)
      : renderFlatListItemsHtml(item.listItems);

    return [
      `<div class="${cssClass}">`,
      item.title ? `<h3 class='figure-h3'>${item.title}</h3>` : "",
      item.text ? `<div class='section-text'>${item.text}</div>` : "",
      item.listItems.length > 0 ? `<ul class='${ulClass}'>${listItemsHtml}</ul>` : "",
      "</div>",
    ].join("");
  })
  .join("");

/* ---------------- CSS Classes ---------------- */
const alignmentMap = {
  left: "text-left",
  center: "text-center",
  right: "text-right",
} as const;

const captionWrapperClass = [
  "full-bleed-caption",
  "mt-5",
  alignmentMap[caption_pos] || "text-left",
  bleed ? "hw-contain" : null,
]
  .filter(Boolean)
  .join(" ");

const hasContent = processedContent.length > 0;
const hasImages = carouselImages.length > 0;
const transitionName = `carousel-${
  Astro.url.pathname
    .replace(/[^a-z0-9]+/gi, "-")
    .replace(/^-+|-+$/g, "") || "home"
}-${rowIndex}`;
const instanceId = transitionName;
---

{label_above && (
  <div class="tac figure hw-contain mb-6 text-[1.75rem]">
    {label_above}
  </div>
)}

{/* Carousel Section */}
{hasImages && (
  <div class:list={["w-full relative block", natural_aspect && "carousel-natural-aspect"]}>
    <ImageCarousel
      client:load
      images={carouselImages}
      defaultContent={content}
      caption={caption}
      captionPos={caption_pos}
      instanceId={instanceId}
      transition:name={transitionName}
    />
  </div>
)}

{hasImages && (
  <script define:vars={{ debugCarouselLightbox: DEBUG_CAROUSEL_LIGHTBOX, carouselInstanceId: instanceId, carouselFslightboxScriptUrl: fslightboxScriptUrl }}>
    const DEBUG_CAROUSEL_LIGHTBOX = Boolean(debugCarouselLightbox);
    const CAROUSEL_INSTANCE_ID = carouselInstanceId || "carousel";
    const CAROUSEL_FSLIGHTBOX_SCRIPT_URL = carouselFslightboxScriptUrl;
    const rootSelector = "[data-carousel-lightbox-root]";
    const triggerSelector = "[data-carousel-lightbox-trigger]";

    function resolveCarouselLightboxDebugFlag() {
      if (DEBUG_CAROUSEL_LIGHTBOX) {
        return true;
      }

      if (typeof window === "undefined") {
        return false;
      }

      try {
        if (Boolean(window.__carouselLightboxDebug)) {
          return true;
        }

        const searchParams = new URLSearchParams(window.location.search);
        if (searchParams.has("debug-carousel-lightbox")) {
          window.__carouselLightboxDebug = true;
          return true;
        }

        if (window.localStorage?.getItem("debug-carousel-lightbox") === "true") {
          window.__carouselLightboxDebug = true;
          return true;
        }
      } catch {}

      return false;
    }

    const activeDebugCarouselLightbox = resolveCarouselLightboxDebugFlag();

    function logCarouselLightbox(message, details) {
      const isDebugEnabled = activeDebugCarouselLightbox || Boolean(window.__carouselLightboxDebug);

      if (!isDebugEnabled || typeof console === "undefined") {
        return;
      }

      const prefix = `[CarouselLightbox][${new Date().toISOString()}][${CAROUSEL_INSTANCE_ID}] ${message}`;

      if (typeof details === "undefined") {
        console.debug(prefix);
        return;
      }

      console.debug(prefix, details);
    }

    window.__carouselLightboxDebug = activeDebugCarouselLightbox;

    const state = window["__carouselFsLightboxState"] || {
      activeInstance: null,
      log: null,
      lastInstanceId: null,
    };

    state.log = logCarouselLightbox;
    state.lastInstanceId = CAROUSEL_INSTANCE_ID;
    window["__carouselFsLightboxState"] = state;

    async function loadCarouselFsLightboxConstructor() {
      logCarouselLightbox("loadCarouselFsLightboxConstructor start", {
        hasConstructor: typeof window["FsLightbox"] === "function",
        scriptUrl: CAROUSEL_FSLIGHTBOX_SCRIPT_URL,
      });

      if (typeof window === "undefined") {
        logCarouselLightbox("loadCarouselFsLightboxConstructor skipped", { reason: "no-window" });
        return null;
      }

      if (typeof window["FsLightbox"] === "function") {
        logCarouselLightbox("loadCarouselFsLightboxConstructor reuse-existing");
        return window["FsLightbox"];
      }

      if (!window["__carouselFsLightboxScriptPromise"]) {
        window["__carouselFsLightboxScriptPromise"] = new Promise((resolve, reject) => {
          const existingScript = document.querySelector('script[data-carousel-fslightbox-script="true"]');

          if (existingScript instanceof HTMLScriptElement) {
            logCarouselLightbox("loadCarouselFsLightboxConstructor waiting-for-existing-script");
            existingScript.addEventListener("load", () => resolve(), { once: true });
            existingScript.addEventListener("error", (event) => reject(event), { once: true });
            return;
          }

          const script = document.createElement("script");
          script.src = CAROUSEL_FSLIGHTBOX_SCRIPT_URL;
          script.async = true;
          script.dataset.carouselFslightboxScript = "true";
          logCarouselLightbox("loadCarouselFsLightboxConstructor append-script", {
            scriptUrl: script.src,
          });
          script.addEventListener("load", () => resolve(), { once: true });
          script.addEventListener("error", (event) => reject(event), { once: true });
          document.head.appendChild(script);
        }).catch((error) => {
          logCarouselLightbox("loadCarouselFsLightboxConstructor script-error", {
            scriptUrl: CAROUSEL_FSLIGHTBOX_SCRIPT_URL,
            error,
          });
          window["__carouselFsLightboxScriptPromise"] = null;
          throw error;
        });
      }

      await window["__carouselFsLightboxScriptPromise"];

      logCarouselLightbox("loadCarouselFsLightboxConstructor imported", {
        hasConstructor: typeof window["FsLightbox"] === "function",
      });

      return typeof window["FsLightbox"] === "function" ? window["FsLightbox"] : null;
    }

    function teardownCarouselFsLightboxInstance(instance) {
      if (!instance) {
        logCarouselLightbox("teardownCarouselFsLightboxInstance skipped", { reason: "no-instance" });
        return;
      }

      logCarouselLightbox("teardownCarouselFsLightboxInstance start", {
        hasContainer: Boolean(instance.elements?.container),
        isInitialized: instance.data?.isInitialized ?? null,
        isFullscreenOpen: instance.data?.isFullscreenOpen ?? null,
      });

      try {
        instance.core?.globalEventsController?.removeListeners?.();
      } catch {}

      try {
        if (instance.data?.isFullscreenOpen) {
          instance.core?.fullscreenToggler?.exitFullscreen?.();
        }
      } catch {}

      try {
        instance.core?.scrollbarRecompensor?.removeRecompense?.();
      } catch {}

      if (instance.slideSwipingProps) {
        instance.slideSwipingProps.isSwiping = false;
      }

      try {
        const container = instance.elements?.container;
        if (container?.parentNode) {
          container.parentNode.removeChild(container);
        }
      } catch {}

      document.documentElement.classList.remove("fslightbox-open");
      document.body?.style.removeProperty("margin-right");
      logCarouselLightbox("teardownCarouselFsLightboxInstance complete");
    }

    const destroyActiveInstance = () => {
      const currentInstance = state.activeInstance;
      state.activeInstance = null;
      logCarouselLightbox("destroyActiveInstance", {
        hadInstance: Boolean(currentInstance),
      });
      teardownCarouselFsLightboxInstance(currentInstance);
    };

    const collectSources = (root) => {
      const sources = Array.from(root.querySelectorAll(triggerSelector))
        .map((element) => element.getAttribute("data-carousel-lightbox-source") || "")
        .filter(Boolean);
      logCarouselLightbox("collectSources", {
        sourceCount: sources.length,
        sources,
      });
      return sources;
    };

    const openFromRoot = async (root, index = 0) => {
      if (!(root instanceof HTMLElement)) {
        logCarouselLightbox("openFromRoot aborted", {
          reason: "invalid-root",
          index,
        });
        return false;
      }

      logCarouselLightbox("openFromRoot start", {
        index,
        rootReady: root.dataset.ready ?? null,
        rootInstance: root.dataset.carouselInstance ?? null,
        hasPluginStyleTag: Boolean(document.querySelector(".fslightbox-styles")),
      });
      const sources = collectSources(root);

      if (sources.length === 0) {
        logCarouselLightbox("openFromRoot aborted", {
          reason: "no-sources",
          index,
        });
        return false;
      }

      const FsLightbox = await loadCarouselFsLightboxConstructor();

      if (!FsLightbox) {
        logCarouselLightbox("openFromRoot aborted", {
          reason: "missing-constructor",
          index,
        });
        return false;
      }

      destroyActiveInstance();

      const nextInstance = new FsLightbox();
      nextInstance.props.sources = sources;
      nextInstance.props.loadOnlyCurrentSource = true;
      nextInstance.setup();

      state.activeInstance = nextInstance;

      const boundedIndex = Math.max(0, Math.min(index, sources.length - 1));
      logCarouselLightbox("openFromRoot opening", {
        requestedIndex: index,
        boundedIndex,
        sourceCount: sources.length,
      });
      nextInstance.open(boundedIndex);

      logCarouselLightbox("openFromRoot success", {
        boundedIndex,
        hasActiveInstance: Boolean(state.activeInstance),
      });

      requestAnimationFrame(() => {
        const container = nextInstance.elements?.container;
        logCarouselLightbox("openFromRoot post-open", {
          boundedIndex,
          bodyContainsContainer: Boolean(container && document.body?.contains(container)),
          containerClassName: container?.className || null,
          containerConnected: Boolean(container?.isConnected),
          documentElementHasOpenClass: document.documentElement.classList.contains("fslightbox-open"),
          hasPluginStyleTag: Boolean(document.querySelector(".fslightbox-styles")),
        });
      });

      return true;
    };

    window["__destroyCarouselFsLightboxActiveInstance"] = destroyActiveInstance;
    window["__openCarouselFsLightbox"] = async (rootOrTrigger, index = 0) => {
      if (rootOrTrigger instanceof HTMLElement && rootOrTrigger.matches(rootSelector)) {
        return openFromRoot(rootOrTrigger, index);
      }

      const root = rootOrTrigger instanceof HTMLElement
        ? rootOrTrigger.closest(rootSelector)
        : null;

      return openFromRoot(root, index);
    };

    if (!window["__carouselFsLightboxDelegatedClickInstalled"]) {
      logCarouselLightbox("installing global fallback helper");
      document.addEventListener("click", (event) => {
        const currentState = window["__carouselFsLightboxState"];
        const currentLog = typeof currentState?.log === "function"
          ? currentState.log
          : () => {};

        if (event.defaultPrevented) {
          currentLog("delegated click skipped", { reason: "defaultPrevented" });
          return;
        }

        const target = event.target;
        const trigger = target instanceof Element
          ? target.closest(triggerSelector)
          : null;

        if (!(trigger instanceof HTMLElement)) {
          return;
        }

        currentLog("delegated click trigger detected", {
          index: trigger.dataset.carouselLightboxIndex || null,
          source: trigger.dataset.carouselLightboxSource || null,
        });

        const root = trigger.closest(rootSelector);

        if (!(root instanceof HTMLElement)) {
          currentLog("delegated click aborted", { reason: "missing-root" });
          return;
        }

        if (root.dataset.carouselInstance) {
          currentLog("delegated click skipped", {
            reason: "react-managed",
            rootInstance: root.dataset.carouselInstance,
          });
          return;
        }

        const rawIndex = Number(trigger.dataset.carouselLightboxIndex || "0");
        const nextIndex = Number.isNaN(rawIndex) ? 0 : rawIndex;

        event.preventDefault();
        currentLog("delegated click opening", {
          index: nextIndex,
          rootReady: root.dataset.ready ?? null,
          rootInstance: root.dataset.carouselInstance ?? null,
        });
        void window["__openCarouselFsLightbox"]?.(root, nextIndex);
      });
      window["__carouselFsLightboxDelegatedClickInstalled"] = true;
    } else {
      logCarouselLightbox("global fallback helper refreshed");
    }

    if (!window["__carouselFsLightboxBeforeSwapInstalled"]) {
      document.addEventListener("astro:before-swap", () => {
        const currentState = window["__carouselFsLightboxState"];
        const currentLog = typeof currentState?.log === "function"
          ? currentState.log
          : () => {};
        currentLog("event astro:before-swap", {
          helperInstanceId: currentState?.lastInstanceId ?? null,
        });
        window["__destroyCarouselFsLightboxActiveInstance"]?.();
      });
      window["__carouselFsLightboxBeforeSwapInstalled"] = true;
    }
  </script>
)}

{/* Fallback Text Content */}
{!hasImages && (caption || hasContent) && (
  <div class={`hw-contain ${captionWrapperClass}`}>
    <div class="row">
      <div class="min-[1240px]:push-1 col-12">
        {caption && <div set:html={caption} />}
        {hasContent && (
          <div class="full-bleed-content-wrap mt-16">
            <div class="row" set:html={contentColumnsHTML} />
          </div>
        )}
      </div>
    </div>
  </div>
)}
