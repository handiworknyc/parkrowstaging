---
import ImageCarousel from "../react/ImageCarousel.jsx";

/* ---------------- Props ---------------- */
interface Props {
  label_above?: string;
  content?: any[];
  images?: any[];
  caption?: string;
  caption_pos?: "left" | "center" | "right";
  bleed?: boolean;
  rowIndex?: number;
}

const {
  label_above = "",
  content = [],
  images = [],
  caption = "",
  caption_pos = "left",
  bleed = false,
  rowIndex = 0,
} = Astro.props;

/* ---------------- Helpers ---------------- */
function getColumnClass(index: number, total: number): string {
  if (total === 1) {
    return "min-[990px]:col-5 max-[990px]:col-12 column-content";
  }
  
  if (index === 1) {
    const mobileMt = content[1]?.title ? "max-[990px]:mt-20" : "max-[990px]:mt-6";
    return `min-[1050px]:col-4 min-[990px]:col-5 min-[1050px]:push-2 min-[990px]:push-1 ${mobileMt} max-[990px]:col-12 column-content`;
  }
  
  return "min-[1050px]:col-4 min-[990px]:col-5 col-12 column-content";
}

/* ---------------- Data Processing ---------------- */
const processedContent = Array.isArray(content)
  ? content.map((item) => ({
      title: item.title || "",
      text: item.text || "",
      twoColList: item.two_col_list || false,
      listItems: item.list
        ? item.list.split(/\r?\n/).filter((li: string) => li.trim())
        : [],
    }))
  : [];

const carouselImages = Array.isArray(images)
  ? images.map((item, index) => {
      const imgData = item.image || {};
      const mediumUrl = imgData.sizes?.intch_med;

      return {
        id: imgData.ID || imgData.id || index,
        src: mediumUrl || imgData.url,
        alt: imgData.alt || imgData.title || `Image ${index + 1}`,
        caption: item.caption || "",
        slideContent: Array.isArray(item.slide_content) ? item.slide_content : null,
        aspectRatio:
          imgData.width && imgData.height
            ? imgData.width / imgData.height
            : 4 / 3,
      };
    })
  : [];

/* ---------------- HTML Generation ---------------- */
const contentColumnsHTML = processedContent
  .map((item, index) => {
    const cssClass = getColumnClass(index, processedContent.length);
    const ulClass = `section-text ${item.twoColList ? "two-col-list" : ""}`.trim();

    return `
      <div class="${cssClass}">
        ${item.title ? `<h3 class='figure-h3'>${item.title}</h3>` : ""}
        ${item.text ? `<div class='section-text'>${item.text}</div>` : ""}
        ${
          item.listItems.length > 0
            ? `<ul class='${ulClass}'>${item.listItems.map((li: string) => `<li>${li}</li>`).join("")}</ul>`
            : ""
        }
      </div>
    `;
  })
  .join("");

/* ---------------- CSS Classes ---------------- */
const alignmentMap = {
  left: "text-left",
  center: "text-center",
  right: "text-right",
} as const;

const captionWrapperClass = [
  "full-bleed-caption",
  "mt-5",
  alignmentMap[caption_pos] || "text-left",
  bleed ? "hw-contain" : null,
]
  .filter(Boolean)
  .join(" ");

const hasContent = processedContent.length > 0;
const hasImages = carouselImages.length > 0;
const transitionName = `carousel-${
  Astro.url.pathname
    .replace(/[^a-z0-9]+/gi, "-")
    .replace(/^-+|-+$/g, "") || "home"
}-${rowIndex}`;
const instanceId = transitionName;
---

{label_above && (
  <div class="tac figure hw-contain mb-6 text-[1.75rem]">
    {label_above}
  </div>
)}

{/* Carousel Section */}
{hasImages && (
  <div class="w-full relative block">
    <ImageCarousel
      client:load
      images={carouselImages}
      defaultContent={content}
      caption={caption}
      captionPos={caption_pos}
      instanceId={instanceId}
      transition:name={transitionName}
    />
  </div>
)}

{/* Fallback Text Content */}
{!hasImages && (caption || hasContent) && (
  <div class={`hw-contain ${captionWrapperClass}`}>
    <div class="row">
      <div class="min-[1240px]:push-1 col-12">
        {caption && <div set:html={caption} />}
        {hasContent && (
          <div class="full-bleed-content-wrap mt-16">
            <div class="row" set:html={contentColumnsHTML} />
          </div>
        )}
      </div>
    </div>
  </div>
)}
