---
import CFVideo from "../ui/CFVideo.astro";
import CollageParallax from "../CollageParallax.jsx";

interface Props {
  images?: Array<{
    video?: any[];
  }>;
}

const { images = [] } = Astro.props;

/* ---------------- Helpers ---------------- */
function isImageMode(video: any[] | undefined): boolean {
  const v = video?.[0];
  return !v?.cf_stream_video || v.cf_stream_video === "";
}

function hasVideo(index: number): boolean {
  return !!images[index]?.video;
}

/* ---------------- Layout Configuration ---------------- */
const LAYOUT_CONFIG = [
  // Row 1: 3 items
  {
    rowClass: "row flex justify-[flex-end]",
    items: [
      {
        index: 0,
        cellClass: "col-5 push-1 photo-collage-cell ml-auto",
        wrapClass: "pr img-load-par rounded-tl-[9rem] ofh",
        strength: 11,
        posterSize: "small",
      },
      {
        index: 1,
        cellClass: "col-3 photo-collage-cell ml-auto",
        wrapClass: "pr img-load-par",
        strength: 11,
        posterSize: "small",
      },
      {
        index: 2,
        cellClass: "col-3 photo-collage-cell bleed-right",
        wrapClass: "pr img-load-par",
        strength: 11,
        posterSize: "small",
      },
    ],
  },
  // Row 2: Full width inverted
  {
    rowClass: "row flex",
    items: [
      {
        index: 3,
        cellClass: "photo-collage-cell bleed-x w-full",
        wrapClass: "pr img-load-par",
        strength: 20,
        invert: true,
      },
    ],
  },
  // Row 3: 2 items
  {
    rowClass: "row flex",
    items: [
      {
        index: 4,
        cellClass: "photo-collage-cell col-6 bleed-left",
        wrapClass: "pr img-load-par",
        posterSize: "med",
      },
      {
        index: 5,
        cellClass: "photo-collage-cell col-6 bleed-right",
        wrapClass: "pr img-load-par",
        strength: 20,
        posterSize: "med",
      },
    ],
  },
  // Row 4: Full width inverted
  {
    rowClass: "row flex",
    items: [
      {
        index: 6,
        cellClass: "photo-collage-cell bleed-x w-full",
        wrapClass: "pr img-load-par",
        invert: true,
      },
    ],
  },
  // Row 5: 2 items
  {
    rowClass: "row flex",
    items: [
      {
        index: 7,
        cellClass: "photo-collage-cell col-5 bleed-left",
        wrapClass: "pr img-load-par",
        strength: 12,
        posterSize: "med",
      },
      {
        index: 8,
        cellClass: "photo-collage-cell col-6",
        wrapClass: "pr rounded-br-[9rem] ofh img-load-par",
        strength: 12,
        posterSize: "med",
      },
    ],
  },
] as const;
---

<div class="photo-collage hw-contain">
  {LAYOUT_CONFIG.map((row) => {
    const visibleItems = row.items.filter((item) => hasVideo(item.index));
    if (visibleItems.length === 0) return null;

    const rowClass = [
      row.rowClass,
      visibleItems.some((item) => item.cellClass.includes("col-"))
        ? "photo-collage-columns-row"
        : "photo-collage-bleed-row",
    ].join(" ");

    return (
      <div class={rowClass}>
        {visibleItems.map((item) => {
          const video = images[item.index].video;
          const isImage = isImageMode(video);
          const parallaxProps = {
            strength: item.strength,
            invert: item.invert,
          };

          return (
            <div class={item.cellClass}>
              <div class={item.wrapClass}>
                {isImage ? (
                  <CollageParallax client:load {...parallaxProps}>
                    <CFVideo video={video} posterForceSize={item.posterSize} />
                  </CollageParallax>
                ) : (
                  <CFVideo video={video} posterForceSize={item.posterSize} />
                )}
              </div>
            </div>
          );
        })}
      </div>
    );
  })}
</div>
