---
import CFVideo from "../ui/CFVideo.astro";

const vars = { ...Astro.props };

// ---------------------------------------------
// 1. ORDER & NORMALIZE IMAGES
// ---------------------------------------------
const rawImages = Array.isArray(vars.images) ? vars.images : [];
const isSingle = rawImages.length === 1;

let renderImages = [];

// 1. Normalize the Array
if (isSingle) {
  // 📸 SINGLE IMAGE: Duplicate it so we have 2 items to split
  renderImages = [rawImages[0], rawImages[0]];
} else {
  // 📸 MULTI IMAGE: Use as is (limit to 4 for sanity if needed)
  renderImages = rawImages.slice(0, 4); 
}

// 2. Calculate Split Index
// If we have 2 items (real or duplicated), split at 1 (Middle).
// If we have 3+ items, split at 2 (After first row of 2).
const splitIndex = renderImages.length <= 2 ? 1 : 2;

// 3. Enable Split
// simply checks if quote is true. The logic above handles the 'where'.
const isQuote = !!vars.quote;
const useMobileSplit = isQuote; 


// ---------------------------------------------
// 2. SIMPLE CONTENT
// ---------------------------------------------
const title = vars.title || "";
const text = vars.text || "";
const listItems = (vars.list || "")
  .split(/\r?\n/)
  .filter((li) => li.trim());

// ---------------------------------------------
// 3. CAPTION
// ---------------------------------------------
const caption = vars.caption || "";
const captionPos = vars.caption_pos || "left";

const alignMap = {
  left: "text-left",
  center: "text-center",
  right: "text-right",
};

const captionAlignClass = alignMap[captionPos] || "text-left";

const responsivePadClass =
  vars.align === "right"
    ? "max-[920px]:min-[760px]:pr-[var(--containerPadding)]"
    : "max-[920px]:min-[760px]:pl-[var(--containerPadding)]";

const captionWrapperClass = [
  responsivePadClass,
  "full-bleed-caption",
  "mt-5",
  captionAlignClass,
  vars.bleed === true ? "hw-contain" : null,
].filter(Boolean).join(" ");

const rowAlignClass = vars.align === "right" ? "align-right" : "align-left";

const mobileBleedClass = 
  vars.align === "right" 
    ? "max-[920px]:min-[760px]:bleed-right" 
    : "max-[920px]:min-[760px]:bleed-left";
---

<div class="hw-contain">
  <div class:list={["row", "flex", "curvy-image-row", rowAlignClass]}>

	<div
		class:list={[
		"curvy-image-grid",
		mobileBleedClass,

		/* -------- Base -------- */
		"min-[760px]:col-6",
		"min-[1024px]:col-6",
		"min-[1400px]:col-6",
		"min-[1400px]:push-1",
		"col-12",

		/* -------- Non-quote only -------- */
		!vars.quote && "min-[680px]:col-10 max-[759px]:mb-16",

		/* -------- Alignment push -------- */
		vars.align === "right"
			? "min-[760px]:push-1"
			: "min-[1400px]:push-1",

		/* -------- Quote overrides -------- */
		vars.quote && [
			"max-[759px]:col-12"
		]
		]}
	>

    
    <div class:list={[
      "grid-container hw-player-parent", 
      { [`is-quote-${!!vars.quote}`]: true }
    ]}>
        {renderImages.map((img, index) => {
          const video = img.video?.[0];
          
          // ✅ UNIVERSAL SPLIT CHECK
          const showMobileContent = useMobileSplit && index === splitIndex;
          
          const imageMarkup = (() => {
             if (!video) return null;

             let spanClass = "";
             if (isSingle) {
                spanClass = "grid-span-2"; 
             } else {
                spanClass = img.large ? "grid-span-2" : "grid-span-1";
             }
             
             let posClass = "";
             if (isSingle) {
                // If single, top half is index 0, bottom is index 1
                posClass = index === 0 ? "split-img-top" : "split-img-bottom";
             }
             
             const pSize = spanClass === "grid-span-1" ? "small" : "med";

             return (
                <div class={`grid-item ${spanClass}`}>
                  <div class={`hw-bg-vid img-load-par pr ${posClass} max-[759px]:h-[12rem]`}>
                    <CFVideo 
                      video={[video]} 
                      usePosterSrcSet={false} 
                      posterForceSize={pSize} 
                    />
                  </div>
                </div>
             );
          })();

          return (
            <>
                {showMobileContent && (
                    <div 
                        class:list={[
                            "mobile-mid-content",
                            "min-[760px]:hidden", // Hide on Desktop
                            "col-span-full",      // Tailwind Full Width
                            "w-full",
                            "py-12",
                            "!h-auto",            // Force auto height
                            "row-auto",           // Grid row auto
                            "self-start",
                            `text-align-${vars.text_align}`
                        ]}
                        style={{ gridRow: 'auto' }}
                    >
                        {title && <h3 class="figure-h3 pb-0" set:html={title} />}
                        {text && <div class="section-text mt-5" set:html={text} />}
                        {listItems.length > 0 && (
                            <ul class="section-text two-col-list min-[760px]:mt-6">
                                {listItems.map((li) => <li>{li}</li>)}
                            </ul>
                        )}
                    </div>
                )}
                {imageMarkup}
            </>
          );
        })}

      </div>

      {caption && <div class={captionWrapperClass}>{caption}</div>}
    </div>

    {/* DESKTOP CONTENT COLUMN */}
    <div
    class:list={[
        "column-content",
        "curvy-image-content",
        `text-align-${vars.text_align}`,
        "min-[1400px]:col-3",
        "min-[1024px]:col-4",
        "min-[760px]:col-5",
        "min-[450px]:col-10",
        "col-12",
        // ✅ Toggle Visibility
        useMobileSplit ? "max-[759px]:hidden" : "",
        vars.align === "right"
        ? "min-[1400px]:push-1"
        : "min-[760px]:push-1",
        caption && "min-[760px]:mb-9"
    ]}
    >

      {title && <h3 class="figure-h3 pb-0" set:html={title} />}

      {text && (
        <div class="section-text mt-5" set:html={text} />
      )}

      {listItems.length > 0 && (
        <ul class="section-text two-col-list min-[760px]:mt-6">
          {listItems.map((li) => <li>{li}</li>)}
        </ul>
      )}

    </div>

  </div>
</div>

<style>
/* Force object position for the single-image split trick */
.split-img-top :global(video),
.split-img-top :global(img) {
    object-position: center top !important;
}

.split-img-bottom :global(video),
.split-img-bottom :global(img) {
    object-position: center bottom !important;
}

/* Grid row height: grid-span-2 determines row height at 16/9 */
.grid-container {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  grid-auto-rows: 1fr; /* All rows match height */
  gap: 1rem;
}

/* The grid-span-2 item sets 16/9 aspect ratio, rounded to nearest rem */
.grid-container .grid-item.grid-span-2 .hw-bg-vid {
  width: 100%;
  /* Calculate 16/9 height and round to nearest rem */
  min-height: round(nearest, calc(100cqw * 7.5 / 16), 1rem);
  max-height: round(nearest, calc(100cqw * 7.5 / 16), 1rem);
  aspect-ratio: 16 / 7.5;
}

/* Make grid-span-2 items container queries aware */
.grid-container .grid-item.grid-span-2 {
  container-type: inline-size;
}

/* grid-span-1 items fill the row height set by grid-span-2 */
.grid-container .grid-item.grid-span-1 .hw-bg-vid {
  height: 100%;
  width: 100%;
}

/* Ensure images/videos cover their containers */
.grid-container .hw-bg-vid :global(img),
.grid-container .hw-bg-vid :global(video) {
  width: 100%;
  height: 100%;
  object-fit: cover;
}

/* Remove mobile fixed height on desktop */
@media (min-width: 760px) {
  .grid-container .grid-item.grid-span-1 .hw-bg-vid {
    height: 100% !important;
  }
  
  .grid-container .grid-item.grid-span-2 .hw-bg-vid {
    height: auto !important;
  }
}
</style>