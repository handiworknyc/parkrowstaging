---
import CFVideo from "../ui/CFVideo.astro";

const vars = { ...Astro.props };


// ---------------------------------------------
// 1. ORDER IMAGES
// ---------------------------------------------
const images = Array.isArray(vars.images) ? vars.images : [];

const orderedImages =
  images.length === 4
    ? [images[0], images[1], images[2], images[3]]
    : images;

// ---------------------------------------------
// 2. SIMPLE CONTENT
// ---------------------------------------------
const title = vars.title || "";
const text = vars.text || "";
const listItems = (vars.list || "")
  .split(/\r?\n/)
  .filter((li) => li.trim());

// ---------------------------------------------
// 3. CAPTION
// ---------------------------------------------
const caption = vars.caption || "";
const captionPos = vars.caption_pos || "left";

const alignMap = {
  left: "text-left",
  center: "text-center",
  right: "text-right",
};

const captionAlignClass = alignMap[captionPos] || "text-left";

// ✅ responsive padding based on alignment
const responsivePadClass =
  vars.align === "right"
    ? "max-[920px]:min-[760px]:pr-[var(--containerPadding)]"
    : "max-[920px]:min-[760px]:pl-[var(--containerPadding)]";

const captionWrapperClass = [
  responsivePadClass,
  "full-bleed-caption",
  "mt-5",
  captionAlignClass,
  vars.bleed === true ? "hw-contain" : null,
].filter(Boolean).join(" ");

// ⭐ ROW ALIGN CLASS (unchanged)
const rowAlignClass =
  vars.align === "right"
    ? "align-right"
    : "align-left";


// ✅ FIX: Define complete strings for Tailwind Scanner
const mobileBleedClass = 
  vars.align === "right" 
    ? "max-[920px]:min-[760px]:bleed-right" 
    : "max-[920px]:min-[760px]:bleed-left";
---

<div class="hw-contain">
  <div
    class:list={[
      "row",
      "flex",
      "curvy-image-row",
      rowAlignClass
    ]}
  >

    <div
    class:list={[
        "curvy-image-grid",
		"max-[760px]:mb-16",
        mobileBleedClass,
		"col-12",
        "min-[760px]:col-6",
        "min-[1024px]:col-7",
        "min-[1400px]:col-6",
        vars.align === "right"
        ? "min-[760px]:push-1"
        : "min-[1400px]:push-1"
    ]}
    >
      <div class="grid-container hw-player-parent">

        {orderedImages.map((img) => {
          const video = img.video?.[0];
          if (!video) return null;

          const isSingle = orderedImages.length === 1;

          // 1. Determine Span Class
          const spanClass = isSingle
            ? "grid-span-4"
            : img.large
            ? "grid-span-2"
            : "grid-span-1";

          // 2. Determine Poster Size based on Span
          const pSize = spanClass === "grid-span-1" ? "med" : "large";

          return (
            <div class={`grid-item ${spanClass}`}>
              <div class="hw-bg-vid img-load-par pr">
                <CFVideo 
                  video={[video]} 
                  usePosterSrcSet={false} 
                  posterForceSize={pSize} 
                />
              </div>
            </div>
          );
        })}

      </div>

      {caption && <div class={captionWrapperClass}>{caption}</div>}
    </div>

    <div
    class:list={[
		"column-content",
        "curvy-image-content",
        `text-align-${vars.text_align}`,
        "min-[1400px]:col-3",
        "min-[1024px]:col-4",
        "col-5",
		"max-[1024px]:flex-1",
        vars.align === "right"
        ? "min-[1400px]:push-1 pr-col-h"
        : "min-[1024px]:push-1 min-[760px]:push-h",
		caption && "mb-9"
    ]}
    >

      {title && <h3 class="figure-h3 mb-5" set:html={title} />}

      {text && (
        <div class="section-text mb-6" set:html={text} />
      )}

      {listItems.length > 0 && (
        <ul class="section-text two-col-list">
          {listItems.map((li) => <li>{li}</li>)}
        </ul>
      )}

    </div>

  </div>
</div>