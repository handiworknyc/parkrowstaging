  .floorplans-detail-visual {
    display: flex;
    align-items: center;
    justify-content: center;
    min-width: 0;
    height: 100%;
    overflow: visible;
    overscroll-behavior: contain;
    position: relative;
  }

  .floorplans-detail-viewer {
    --floorplans-reset-top: 2rem;
    --floorplans-reset-right: 5.75rem;
    box-sizing: border-box;
    position: relative;
    z-index: 1;
    width: 100%;
    height: min(70vh, calc(100% - 4rem));
    max-height: calc(100% - 4rem);
    min-width: 0;
    min-height: 0;
  }

  .floorplans-detail-viewer--with-keyplan {
    padding-left: 150px;
  }

  .floorplans-detail-viewer :global(astro-island) {
    display: block;
    width: 100%;
    height: 100%;
  }

  .floorplans-detail-keyplan {
    position: absolute;
    left: 2rem;
    bottom: 2rem;
    z-index: 0;
    width: 400px;
    height: 300px;
    max-width: calc(100% - 4rem);
    max-height: calc(100% - 4rem);
    pointer-events: none;
    opacity: 1;
    transition: opacity 220ms ease;
  }

  .floorplans-detail-keyplan img {
    display: block;
    width: 100%;
    height: 100%;
    object-fit: contain;
    object-position: left bottom;
  }

  .floorplans-detail-visual[data-keyplan-dimmed="true"] .floorplans-detail-keyplan {
    opacity: 0;
  }

  .floorplans-modal-card[data-floorplan-zoomed="true"] > .floorplans-detail-copy {
    opacity: 0;
    pointer-events: none;
  }

  .floorplans-detail-viewer :global(.floorplans-zoom-button:hover),
  .floorplans-detail-viewer :global(.floorplans-zoom-button:focus-visible),
  .floorplans-modal-close:hover,
  .floorplans-modal-close:focus-visible {
    background: var(--pink) !important;
  }

  .floorplans-detail-viewer :global(.floorplans-zoom-button-icon) {
    position: relative;
    display: block;
    width: 1.125rem;
    height: 1.125rem;
  }

  .floorplans-detail-viewer :global(.floorplans-zoom-button-icon)::before,
  .floorplans-detail-viewer :global(.floorplans-zoom-button-icon--plus)::after {
    content: "";
    position: absolute;
    top: 50%;
    left: 50%;
    background: currentColor;
    transform: translate(-50%, -50%);
    border-radius: 999px;
  }

  .floorplans-detail-viewer :global(.floorplans-zoom-button-icon)::before {
    width: 1rem;
    height: 1.5px;
  }

  .floorplans-detail-viewer :global(.floorplans-zoom-button-icon--minus)::before {
    width: 1.15rem;
  }

  .floorplans-detail-viewer :global(.floorplans-zoom-button-icon--plus)::after {
    width: 1.5px;
    height: 1rem;
  }

  .floorplans-detail-disclaimer {
    box-sizing: border-box;
    position: relative;
    z-index: 2;
    padding: 4.5rem 2rem 4.25rem;
    border-top: 1px solid rgba(58, 42, 34, 0.12);
    background: #efeeec;
    color: #3a2a22;
  }

  .floorplans-detail-disclaimer::before {
    content: "";
    position: absolute;
    left: 0;
    right: 0;
    top: 0;
    height: 3rem;
    background: linear-gradient(180deg, rgba(239, 238, 236, 0) 0%, #efeeec 100%);
    pointer-events: none;
  }

  .floorplans-detail-disclaimer p {
    margin: 0 auto;
    max-width: 58rem;
    font-family: "Hanken Grotesk", system-ui, sans-serif;
    font-size: 0.95rem;
    line-height: 1.5;
  }

  .floorplans-panorama-modal[hidden] {
    display: none;
  }

  .floorplans-panorama-modal {
    position: absolute;
    inset: 0;
    z-index: 3;
    opacity: 0;
    pointer-events: none;
    transition: opacity 0.4s var(--cubicBez);
    background: #efeeec;
  }

  .floorplans-panorama-modal.is-closing,
  .floorplans-panorama-modal.is-visible {
    pointer-events: auto;
  }

  .floorplans-panorama-modal.is-visible {
    opacity: 1;
  }

  .floorplans-panorama-card {
    position: relative;
    width: 100%;
    height: 100%;
    overflow: hidden;
    background: #efeeec;
  }

  .floorplans-panorama-close {
    z-index: 4;
  }

  .floorplans-panorama-copy {
    z-index: 3;
    color: #fff;
  }

  .floorplans-panorama-copy .floorplans-detail-meta {
    gap: 0.2rem;
  }

  .floorplans-panorama-copy .floorplans-detail-meta p:not(:first-child) {
    white-space: nowrap;
  }

  .floorplans-panorama-copyline {
    font-size: inherit;
    line-height: inherit;
  }

  .floorplans-panorama-scroll {
    position: relative;
    width: 100%;
    height: 100%;
    overflow-x: hidden;
    overflow-y: auto;
    overscroll-behavior: contain;
  }

  .floorplans-panorama-shell {
    min-height: 0;
  }

  .floorplans-panorama-stage {
    box-sizing: border-box;
    position: relative;
    height: calc(100vh - var(--headerHeight));
    height: calc(100dvh - var(--headerHeight));
    min-height: calc(100vh - var(--headerHeight));
    min-height: calc(100dvh - var(--headerHeight));
  }

  .floorplans-panorama-viewer {
    width: 100%;
    height: 100%;
    min-width: 0;
    min-height: 0;
  }

  .floorplans-panorama-viewer :global(astro-island) {
    display: block;
    width: 100%;
    height: 100%;
  }

  .floorplans-panorama-viewer :global(.floorplans-panorama-viewport) {
    position: relative;
  }

  .floorplans-panorama-viewer
    :global(.floorplans-panorama-viewport--day-underlay[data-panorama-daytime-underlay="true"])::before {
    content: "";
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    z-index: 1;
    background: linear-gradient(
      140deg,
      rgba(0, 0, 0, 0.28) 0px,
      rgba(0, 0, 0, 0.08) 142px,
      rgba(0, 0, 0, 0) 308px
    );
    background-repeat: no-repeat;
    pointer-events: none;
  }

  @media (max-width: 1299px) {
    .floorplans-detail-keyplan {
      display: none;
    }

    .floorplans-detail-viewer--with-keyplan {
      padding-left: 0;
      padding-bottom: 0;
    }
  }

  @media (min-width: 815px) and (max-width: 1149px) {
    .floorplans-detail-viewer :global(.floorplans-zoom-image--svg) {
      width: min(100%, 80vw) !important;
      height: auto !important;
      max-width: min(100%, 80vw) !important;
      max-height: 100% !important;
    }
  }

  @media (max-width: 814px) {
    .floorplans-detail-visual {
      align-items: flex-end;
    }

    .floorplans-detail-viewer {
      height: max(
        0px,
        calc(100% - var(--floorplans-detail-copy-height, 0px) - 2.5rem)
      );
      max-height: max(
        0px,
        calc(100% - var(--floorplans-detail-copy-height, 0px) - 2.5rem)
      );
    }

    .floorplans-detail-viewer--with-keyplan {
      padding-left: 0;
      padding-bottom: 0;
    }

    .floorplans-detail-viewer :global(.floorplans-zoom-content--svg) {
      align-items: flex-start !important;
    }

    .floorplans-detail-viewer :global(.floorplans-zoom-image--svg) {
      width: min(100%, 80vw) !important;
      height: auto !important;
      max-width: min(100%, 80vw) !important;
      max-height: 100% !important;
      object-position: center center !important;
    }

    .floorplans-detail-keyplan {
      left: 1rem;
      bottom: 1rem;
      width: min(400px, calc(100% - 2rem));
      height: min(300px, calc(100% - 2rem));
    }
  }

  @media (max-width: 884px) {
