---
import { existsSync, readFileSync } from "node:fs";
import { resolve } from "node:path";
import FloorplanZoomViewer from "@/components/react/FloorplanZoomViewer.jsx";
import inventory from "@/content/wp/avesdo-floorplans.json";
import floorPlanDetailPage from "@/content/wp/floor-plan-detail.json";

const { rowIndex = 0 } = Astro.props;
const tableId = `floorplans-${rowIndex}`;
const svgSizeCache = new Map<string, { width: number; height: number } | null>();

function parseSvgNumericDimension(value: string | null | undefined) {
  const numeric = Number.parseFloat(String(value ?? "").trim());
  return Number.isFinite(numeric) && numeric > 0 ? numeric : null;
}

function getSvgIntrinsicSize(imageUrl: string) {
  if (!imageUrl.toLowerCase().endsWith(".svg")) return null;

  const cached = svgSizeCache.get(imageUrl);
  if (cached !== undefined) {
    return cached;
  }

  const imagePath = resolve(process.cwd(), "public", imageUrl.replace(/^\/+/, ""));
  if (!existsSync(imagePath)) {
    svgSizeCache.set(imageUrl, null);
    return null;
  }

  try {
    const svg = readFileSync(imagePath, "utf8");
    const viewBoxMatch = svg.match(/<svg\b[^>]*\bviewBox=(["'])([^"']+)\1/i);
    const viewBoxParts = viewBoxMatch?.[2]
      ?.trim()
      .split(/[\s,]+/)
      .map((part) => Number.parseFloat(part));
    const viewBoxWidth = viewBoxParts?.[2];
    const viewBoxHeight = viewBoxParts?.[3];

    if (
      Number.isFinite(viewBoxWidth) &&
      viewBoxWidth > 0 &&
      Number.isFinite(viewBoxHeight) &&
      viewBoxHeight > 0
    ) {
      const size = { width: viewBoxWidth, height: viewBoxHeight };
      svgSizeCache.set(imageUrl, size);
      return size;
    }

    const widthMatch = svg.match(/<svg\b[^>]*\bwidth=(["'])([^"']+)\1/i);
    const heightMatch = svg.match(/<svg\b[^>]*\bheight=(["'])([^"']+)\1/i);
    const width = parseSvgNumericDimension(widthMatch?.[2]);
    const height = parseSvgNumericDimension(heightMatch?.[2]);

    if (width && height) {
      const size = { width, height };
      svgSizeCache.set(imageUrl, size);
      return size;
    }
  } catch {
    svgSizeCache.set(imageUrl, null);
    return null;
  }

  svgSizeCache.set(imageUrl, null);
  return null;
}

const rawDetails = Array.isArray(floorPlanDetailPage?.floor_plan_detail)
  ? floorPlanDetailPage.floor_plan_detail
  : [];
const details = rawDetails.flatMap((detail) => {
    const image = detail?.floor_plan_image;
    const imageUrl = String(image?.url ?? "").trim();
    const svgSize = imageUrl ? getSvgIntrinsicSize(imageUrl) : null;
    const fallbackImageWidth = Number(image?.width);
    const fallbackImageHeight = Number(image?.height);
    const imageWidth =
      svgSize?.width ??
      (Number.isFinite(fallbackImageWidth) && fallbackImageWidth > 0
        ? fallbackImageWidth
        : undefined);
    const imageHeight =
      svgSize?.height ??
      (Number.isFinite(fallbackImageHeight) && fallbackImageHeight > 0
        ? fallbackImageHeight
        : undefined);

    return imageUrl
      ? [
          {
            unit: String(detail?.unit ?? "").trim(),
            exterior: String(detail?.exterior ?? "").trim(),
            exposure: String(detail?.exposure ?? "").trim(),
            imageUrl,
            imageWidth,
            imageHeight,
            imageAspectRatio:
              imageWidth && imageHeight ? String(imageWidth / imageHeight) : undefined,
          },
        ]
      : [];
  });

const defaultDetail = details[0] ?? null;
const detailMap = new Map(details.map((detail) => [detail.unit, detail]));

const units = Array.isArray(inventory?.units)
  ? [...inventory.units]
      .sort((a, b) =>
        String(a?.unitNumber || "").localeCompare(String(b?.unitNumber || ""), undefined, {
          numeric: true,
          sensitivity: "base",
        })
      )
      .map((unit) => {
        const unitNumber = String(unit?.unitNumber ?? "").trim();
        const matchedDetail = detailMap.get(unitNumber) ?? defaultDetail;

        return {
          ...unit,
          detail: matchedDetail
            ? {
                ...matchedDetail,
                unit: unitNumber,
              }
            : null,
        };
      })
  : [];
const hasOrientation = units.some((unit) => String(unit?.orientation ?? "").trim());
const columnTemplate = hasOrientation
  ? "minmax(8rem, 1.4fr) minmax(6rem, 0.8fr) minmax(6rem, 0.8fr) minmax(7rem, 0.9fr) minmax(7rem, 0.9fr) minmax(9rem, 1fr)"
  : "minmax(8rem, 1.5fr) minmax(6rem, 0.8fr) minmax(6rem, 0.8fr) minmax(7rem, 0.9fr) minmax(9rem, 1fr)";
const tableStyle = {
  minWidth: hasOrientation ? "840px" : "720px",
  "--floorplans-columns": columnTemplate,
};

const numberFormat = new Intl.NumberFormat("en-US");

function formatBathrooms(value: number | string | null | undefined) {
  const numeric = Number(value || 0);
  return Number.isInteger(numeric) ? String(numeric) : numeric.toFixed(1);
}

function formatOrientation(value: string | null | undefined) {
  return String(value ?? "").trim() || "-";
}

function formatExterior(value: number | string | null | undefined) {
  const normalized = String(value ?? "").trim();
  if (!normalized) return "";

  const numeric = Number(normalized.replace(/,/g, ""));
  return Number.isFinite(numeric) ? numberFormat.format(numeric) : normalized;
}
---

<div class="floorplans-wrap" data-floorplans-table>
  <div class="floorplans-scroller">
    <div id={tableId} class="floorplans-table" style={tableStyle}>
      <div class="floorplans-head-row">
        <div class="floorplans-head hw-contain">
          <div class="floorplans-cell floorplans-cell--unit">Residence</div>
          <div class="floorplans-cell floorplans-cell--metric">
            <button
              type="button"
              class="floorplans-sort-button"
              data-sort-key="bedrooms"
              data-label="Bedrooms"
              aria-pressed="false"
            >
              <span class="floorplans-sort-label">Bedrooms</span>
              <span class="floorplans-sort-indicator" aria-hidden="true"></span>
            </button>
          </div>
          <div class="floorplans-cell floorplans-cell--metric">
            <button
              type="button"
              class="floorplans-sort-button"
              data-sort-key="bathrooms"
              data-label="Bathrooms"
              aria-pressed="false"
            >
              <span class="floorplans-sort-label">Bathrooms</span>
              <span class="floorplans-sort-indicator" aria-hidden="true"></span>
            </button>
          </div>
          <div class="floorplans-cell floorplans-cell--metric">
            <button
              type="button"
              class="floorplans-sort-button"
              data-sort-key="area"
              data-label="Area"
              aria-pressed="false"
            >
              <span class="floorplans-sort-label">Area</span>
              <span class="floorplans-sort-indicator" aria-hidden="true"></span>
            </button>
          </div>
          {hasOrientation && (
            <div class="floorplans-cell floorplans-cell--orientation">Exposure</div>
          )}
          <div class="floorplans-cell floorplans-cell--action">Floorplan View</div>
        </div>
      </div>

      <div class="floorplans-body" data-floorplans-body>
        {units.map((unit) => {
          const hasDetail = Boolean(unit.detail?.imageUrl);
          const detailId = `${tableId}-detail-${unit.unitNumber}`;
          const exteriorLabel = formatExterior(unit.detail?.exterior);
          const exposureLabel = formatOrientation(unit.orientation);

          return (
            <div
              class="floorplans-item"
              data-unit-item
              data-unit-number={unit.unitNumber}
              data-bedrooms={unit.bedrooms}
              data-bathrooms={unit.bathrooms}
              data-area={unit.area}
            >
              <div
                class={`floorplans-row hw-contain${hasDetail ? " floorplans-row--interactive" : ""}`}
                data-floorplans-row
                role={hasDetail ? "button" : undefined}
                tabindex={hasDetail ? "0" : undefined}
                aria-haspopup={hasDetail ? "dialog" : undefined}
                aria-expanded={hasDetail ? "false" : undefined}
                aria-controls={hasDetail ? detailId : undefined}
              >
                <div class="floorplans-cell floorplans-cell--unit">{unit.unitNumber}</div>
                <div class="floorplans-cell floorplans-cell--metric">{unit.bedrooms}</div>
                <div class="floorplans-cell floorplans-cell--metric">
                  {formatBathrooms(unit.bathrooms)}
                </div>
                <div class="floorplans-cell floorplans-cell--metric">
                  {numberFormat.format(unit.area)}
                </div>
                {hasOrientation && (
                  <div class="floorplans-cell floorplans-cell--orientation">
                    {formatOrientation(unit.orientation)}
                  </div>
                )}
                <div class="floorplans-cell floorplans-cell--action">
                  {hasDetail ? (
                    <span
                      class="floorplans-view-link"
                      data-floorplans-toggle-label
                      data-collapsed-label="View"
                      data-expanded-label="Close"
                    >
                      View
                    </span>
                  ) : (
                    <span>-</span>
                  )}
                </div>
              </div>

              {hasDetail && (
                <div id={detailId} class="floorplans-modal" data-floorplans-modal hidden>
                  <button
                    type="button"
                    class="floorplans-modal-backdrop"
                    data-floorplans-close
                    aria-label={`Close floor plan for unit ${unit.unitNumber}`}
                  ></button>

                  <div
                    class="floorplans-modal-card"
                    data-floorplans-modal-card
                    role="dialog"
                    aria-modal="true"
                    aria-label={`Floor plan for unit ${unit.unitNumber}`}
                  >
                    <button
                      type="button"
                      class="floorplans-modal-close"
                      data-floorplans-close
                      data-floorplans-close-button
                      aria-label={`Close floor plan for unit ${unit.unitNumber}`}
                    >
                      Close
                    </button>

                    <div class="floorplans-detail-inner">
                      <div class="floorplans-detail-copy">
                        <div class="floorplans-detail-meta">
                          <p>{unit.bedrooms} Bedroom, {formatBathrooms(unit.bathrooms)} Bath</p>
                          <p>Interior: {numberFormat.format(unit.area)} SF</p>
                          {exteriorLabel && <p>Exterior: {exteriorLabel} SF</p>}
                          <p>Exposure: {exposureLabel}</p>
                        </div>
                      </div>

                      <div class="floorplans-detail-visual">
                        <div class="floorplans-detail-viewer">
                          <FloorplanZoomViewer
                            client:load
                            src={unit.detail.imageUrl}
                            width={unit.detail.imageWidth}
                            height={unit.detail.imageHeight}
                            imageAspectRatio={unit.detail.imageAspectRatio}
                            alt={`Floor plan for unit ${unit.unitNumber}`}
                          />
                        </div>
                      </div>
                    </div>
                  </div>
                </div>
              )}
            </div>
          );
        })}
      </div>
    </div>
  </div>

  {!units.length && <p class="floorplans-empty hw-contain">No floorplans available.</p>}
</div>

<script>
  (() => {
    const init = () => {
      const roots = Array.from(document.querySelectorAll("[data-floorplans-table]"));
      if (!roots.length) return;

      roots.forEach((root) => {
        if (!(root instanceof HTMLElement)) return;

        const body = root.querySelector("[data-floorplans-body]");
        if (!(body instanceof HTMLElement)) return;

        if (root.dataset.floorplansInitialized === "true") {
          return;
        }

        root.dataset.floorplansInitialized = "true";
        const abortController = new AbortController();

        const buttons = Array.from(root.querySelectorAll("[data-sort-key]"));
        let sortKey = "";
        let sortDir = "asc";
        let headerHiddenBeforeModal = false;
        let lockedScrollY = 0;
        let lockedScrollbarWidth = 0;
        let activeScrollLockMode = "none";
        const modalFadeMs = 400;
        const modalCloseTimers = new WeakMap();
        const getItems = () => Array.from(body.querySelectorAll("[data-unit-item]"));
        const getOpenItem = () =>
          getItems().find((item) => item.classList.contains("is-modal-open"));
        const hasOpenModal = () =>
          document.querySelector("[data-floorplans-modal]:not([hidden])") instanceof HTMLElement;
        const getLocoScroll = () => {
          const locoScroll = window.locoScroll;
          if (
            locoScroll &&
            typeof locoScroll.stop === "function" &&
            typeof locoScroll.start === "function"
          ) {
            return locoScroll;
          }

          return null;
        };
        const getCurrentScrollY = () => {
          const locoScroll = getLocoScroll();
          const locoY = locoScroll?.lenisInstance?.scroll;
          if (typeof locoY === "number" && Number.isFinite(locoY)) {
            return locoY;
          }

          return (
            window.scrollY ||
            document.scrollingElement?.scrollTop ||
            document.documentElement.scrollTop ||
            0
          );
        };
        const isHeaderHidden = () =>
          document.getElementById("header")?.classList.contains("is-hidden") ?? false;
        const setHeaderHidden = (hidden) => {
          if (typeof window.__setStickyHeaderHidden === "function") {
            window.__setStickyHeaderHidden(hidden);
            return;
          }

          document.getElementById("header")?.classList.toggle("is-hidden", hidden);
        };
        const lockPageScroll = () => {
          const locoScroll = getLocoScroll();
          lockedScrollY = getCurrentScrollY();

          if (locoScroll) {
            activeScrollLockMode = "loco";
            locoScroll.stop();
            return;
          }

          activeScrollLockMode = "native";
          lockedScrollbarWidth = Math.max(
            0,
            window.innerWidth - document.documentElement.clientWidth
          );
          document.documentElement.style.setProperty(
            "--floorplans-scrollbar-compensation",
            `${lockedScrollbarWidth}px`
          );

          document.body.style.position = "fixed";
          document.body.style.top = `-${lockedScrollY}px`;
          document.body.style.width = "100%";
          document.body.classList.add("floorplans-modal-open");
        };
        const unlockPageScroll = () => {
          if (hasOpenModal()) return;

          const savedY = lockedScrollY;

          if (activeScrollLockMode === "loco") {
            const locoScroll = getLocoScroll();
            if (locoScroll?.scrollTo) {
              locoScroll.scrollTo(savedY, {
                immediate: true,
                force: true,
              });
            } else {
              window.scrollTo({ top: savedY, left: 0, behavior: "auto" });
            }

            locoScroll?.start();
            activeScrollLockMode = "none";
            return;
          }

          if (activeScrollLockMode === "native") {
            document.body.style.position = "";
            document.body.style.top = "";
            document.body.style.width = "";
            document.body.classList.remove("floorplans-modal-open");
            document.documentElement.style.removeProperty("--floorplans-scrollbar-compensation");
            window.scrollTo({ top: savedY, left: 0, behavior: "auto" });
          }

          activeScrollLockMode = "none";
        };
        const clearModalCloseTimer = (modal) => {
          const closeTimer = modalCloseTimers.get(modal);
          if (closeTimer) {
            window.clearTimeout(closeTimer);
            modalCloseTimers.delete(modal);
          }
        };
        const finalizeItemClose = (item, modal, row, restoreFocus = false) => {
          clearModalCloseTimer(modal);
          modal.hidden = true;
          modal.classList.remove("is-visible", "is-closing");

          if (modal.parentElement !== item) {
            item.appendChild(modal);
          }

          unlockPageScroll();

          if (!hasOpenModal()) {
            setHeaderHidden(headerHiddenBeforeModal);

            if (restoreFocus) {
              row.focus({ preventScroll: true });
            }
          }
        };
        const getItemModal = (item, row) => {
          const modalId = row?.getAttribute("aria-controls");
          if (modalId) {
            const modalById = document.getElementById(modalId);
            if (modalById instanceof HTMLElement) {
              return modalById;
            }
          }

          const modalInItem = item.querySelector("[data-floorplans-modal]");
          return modalInItem instanceof HTMLElement ? modalInItem : null;
        };
        const setItemOpen = (item, open, restoreFocus = false) => {
          const row = item.querySelector("[data-floorplans-row]");
          const modal = row instanceof HTMLElement ? getItemModal(item, row) : null;
          const label = item.querySelector("[data-floorplans-toggle-label]");

          if (!(row instanceof HTMLElement) || !(modal instanceof HTMLElement)) return;

          item.classList.toggle("is-modal-open", open);
          row.setAttribute("aria-expanded", open ? "true" : "false");

          if (open) {
            clearModalCloseTimer(modal);

            if (modal.parentElement !== document.body) {
              document.body.appendChild(modal);
            }

            modal.hidden = false;
            modal.classList.remove("is-closing", "is-visible");
            headerHiddenBeforeModal = isHeaderHidden();
            setHeaderHidden(false);
            lockPageScroll();
            requestAnimationFrame(() => {
              if (!modal.hidden) {
                modal.classList.add("is-visible");
              }
            });

            const closeButton = modal.querySelector("[data-floorplans-close-button]");
            if (closeButton instanceof HTMLElement) {
              closeButton.focus({ preventScroll: true });
            }

            if (label instanceof HTMLElement) {
              label.textContent = label.dataset.expandedLabel || "Close";
            }

            return;
          }

          if (label instanceof HTMLElement) {
            label.textContent = label.dataset.collapsedLabel || "View";
          }

          clearModalCloseTimer(modal);
          modal.classList.remove("is-visible");
          modal.classList.add("is-closing");

          const closeTimer = window.setTimeout(() => {
            finalizeItemClose(item, modal, row, restoreFocus);
          }, modalFadeMs);
          modalCloseTimers.set(modal, closeTimer);
        };
        const closeOpenItem = (restoreFocus = false) => {
          const item = getOpenItem();
          if (!item) {
            unlockPageScroll();
            return;
          }

          setItemOpen(item, false, restoreFocus);
        };
        const openItem = (item) => {
          if (item.classList.contains("is-modal-open")) return;

          closeOpenItem();
          setItemOpen(item, true);
        };

        const updateButtons = () => {
          buttons.forEach((button) => {
            const active = button.dataset.sortKey === sortKey;
            const indicator = button.querySelector(".floorplans-sort-indicator");
            if (indicator) {
              indicator.textContent = active ? (sortDir === "asc" ? "▲" : "▼") : "";
            }
            button.setAttribute("aria-pressed", active ? "true" : "false");
          });
        };

        const sortRows = (key, dir) => {
          const items = getItems();

          items.sort((itemA, itemB) => {
            const valueA = Number(itemA.dataset[key] || 0);
            const valueB = Number(itemB.dataset[key] || 0);

            if (valueA !== valueB) {
              return dir === "asc" ? valueA - valueB : valueB - valueA;
            }

            return (itemA.dataset.unitNumber || "").localeCompare(
              itemB.dataset.unitNumber || "",
              undefined,
              { numeric: true, sensitivity: "base" }
            );
          });

          items.forEach((item) => body.appendChild(item));
        };

        getItems().forEach((item) => {
          const row = item.querySelector("[data-floorplans-row]");
          const modal = item.querySelector("[data-floorplans-modal]");

          if (row instanceof HTMLElement && row.getAttribute("role") === "button") {
            row.addEventListener("click", (event) => {
              if (event.target instanceof HTMLElement && event.target.closest("button")) return;
              openItem(item);
            });

            row.addEventListener("keydown", (event) => {
              if (event.key !== "Enter" && event.key !== " ") return;
              event.preventDefault();
              openItem(item);
            });
          }

          if (modal instanceof HTMLElement) {
            modal.addEventListener("click", (event) => {
              if (!(event.target instanceof HTMLElement)) return;
              if (event.target.closest("[data-floorplans-close]")) {
                closeOpenItem(true);
              }
            });
          }
        });

        buttons.forEach((button) => {
          button.addEventListener("click", () => {
            const key = button.dataset.sortKey;
            if (!key) return;

            closeOpenItem();
            sortDir = sortKey === key && sortDir === "asc" ? "desc" : "asc";
            sortKey = key;
            sortRows(key, sortDir);
            updateButtons();
          });
        });

        document.addEventListener(
          "keydown",
          (event) => {
            if (event.key === "Escape") {
              closeOpenItem(true);
            }
          },
          { signal: abortController.signal }
        );

        updateButtons();
        document.addEventListener(
          "astro:before-swap",
          () => {
            closeOpenItem();
            abortController.abort();
          },
          { once: true }
        );
      });
    };

    init();
    document.addEventListener("astro:page-load", init);
    document.addEventListener("astro:after-swap", init);
  })();
</script>

<style>
  :global(body.floorplans-modal-open) {
    overflow: hidden;
    padding-right: var(--floorplans-scrollbar-compensation, 0px);
    height: 100vh;
    position: relative;
  }

  .floorplans-scroller {
    overflow-x: auto;
  }

  .floorplans-wrap {
    width: 100%;
  }

  .floorplans-table {
    width: 100%;
    min-width: 720px;
    font-family: "Hanken Grotesk", system-ui, sans-serif;
    font-size: 1.33rem;
    line-height: 1.75rem;
  }

  .floorplans-head {
    display: grid;
    grid-template-columns: var(--floorplans-columns);
  }

  .floorplans-head-row {
    border-bottom: 1px solid var(--brown);
  }

  .floorplans-head,
  .floorplans-row {
    display: grid;
    grid-template-columns: var(--floorplans-columns);
    width: 100%;
    justify-content: space-between;
  }

  .floorplans-cell {
    box-sizing: border-box;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 1.25rem 0.5rem;
    text-align: center;
    vertical-align: middle;
    min-width: 0;
    font-weight: 400;
  }

  .floorplans-item {
    border-bottom: 1px solid var(--brown);
  }

  .floorplans-row--interactive {
    cursor: pointer;
    transition: background-color 160ms ease;
  }

  .floorplans-row--interactive:hover {
    background: rgba(58, 42, 34, 0.05);
  }

  .floorplans-row--interactive:focus-visible {
    outline: 2px solid currentColor;
    outline-offset: -2px;
  }

  .floorplans-head .floorplans-cell {
    font-weight: 700;
  }

  .floorplans-head .floorplans-cell--unit {
    font-weight: 400;
  }

  .floorplans-cell--unit {
    font-family: "Figure", "Hanken Grotesk", system-ui, sans-serif;
    font-size: 1.75rem;
    line-height: 2.25rem;
    font-weight: 400;
    justify-content: flex-start;
    text-align: left;
  }

  .floorplans-cell--action {
    justify-content: flex-end;
    text-align: right;
  }

  .floorplans-cell--metric,
  .floorplans-cell--orientation {
    justify-content: center;
    text-align: center;
  }

  .floorplans-sort-button {
    appearance: none;
    background: transparent;
    border: 0;
    cursor: pointer;
    display: grid;
    grid-template-columns: 1fr auto 1fr;
    align-items: center;
    font: inherit;
    font-weight: inherit;
    padding: 0;
    text-align: center;
    width: 100%;
    white-space: nowrap;
  }

  .floorplans-sort-label {
    grid-column: 2;
    justify-self: center;
  }

  .floorplans-sort-indicator {
    grid-column: 3;
    justify-self: start;
    width: 1ch;
    margin-left: 0.35rem;
    text-align: center;
  }

  .floorplans-view-link {
    box-sizing: border-box;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    height: 2.75rem;
    padding: 4px 20px 2px;
    border: 1px solid currentColor;
    border-radius: 999px;
    text-decoration: none;
    white-space: nowrap;
    line-height: 1;
  }

  .floorplans-view-link::after {
    content: "";
    width: 0.5625rem;
