---
import { existsSync, readFileSync, readdirSync } from "node:fs";
import { resolve } from "node:path";
import FloorplanZoomViewer from "@/components/react/FloorplanZoomViewer.jsx";
import PanoramicViewViewer from "../react/PanoramicViewViewer.jsx";
import inventory from "@/content/wp/avesdo-floorplans.json";
import floorPlanDetailPage from "@/content/wp/floor-plan-detail.json";
import floorplanDisclaimerPage from "@/content/wp/floorplan-disclaimer.json";
import panoramicViewsPage from "@/content/wp/panoramic-views.json";

const { rowIndex = 0 } = Astro.props;
const tableId = `floorplans-${rowIndex}`;
const svgSizeCache = new Map<string, { width: number; height: number } | null>();

function parseSvgNumericDimension(value: string | null | undefined) {
  const numeric = Number.parseFloat(String(value ?? "").trim());
  return Number.isFinite(numeric) && numeric > 0 ? numeric : null;
}

function getSvgIntrinsicSize(imageUrl: string) {
  if (!imageUrl.toLowerCase().endsWith(".svg")) return null;

  const cached = svgSizeCache.get(imageUrl);
  if (cached !== undefined) {
    return cached;
  }

  const imagePath = resolve(process.cwd(), "public", imageUrl.replace(/^\/+/, ""));
  if (!existsSync(imagePath)) {
    svgSizeCache.set(imageUrl, null);
    return null;
  }

  try {
    const svg = readFileSync(imagePath, "utf8");
    const viewBoxMatch = svg.match(/<svg\b[^>]*\bviewBox=(["'])([^"']+)\1/i);
    const viewBoxParts = viewBoxMatch?.[2]
      ?.trim()
      .split(/[\s,]+/)
      .map((part) => Number.parseFloat(part));
    const viewBoxWidth = viewBoxParts?.[2];
    const viewBoxHeight = viewBoxParts?.[3];

    if (
      Number.isFinite(viewBoxWidth) &&
      viewBoxWidth > 0 &&
      Number.isFinite(viewBoxHeight) &&
      viewBoxHeight > 0
    ) {
      const size = { width: viewBoxWidth, height: viewBoxHeight };
      svgSizeCache.set(imageUrl, size);
      return size;
    }

    const widthMatch = svg.match(/<svg\b[^>]*\bwidth=(["'])([^"']+)\1/i);
    const heightMatch = svg.match(/<svg\b[^>]*\bheight=(["'])([^"']+)\1/i);
    const width = parseSvgNumericDimension(widthMatch?.[2]);
    const height = parseSvgNumericDimension(heightMatch?.[2]);

    if (width && height) {
      const size = { width, height };
      svgSizeCache.set(imageUrl, size);
      return size;
    }
  } catch {
    svgSizeCache.set(imageUrl, null);
    return null;
  }

  svgSizeCache.set(imageUrl, null);
  return null;
}

function extractUrl(value: unknown) {
  if (typeof value === "string") {
    return value.trim();
  }

  if (value && typeof value === "object") {
    if ("url" in value && typeof value.url === "string") {
      return value.url.trim();
    }

    if ("href" in value && typeof value.href === "string") {
      return value.href.trim();
    }

    if ("link" in value && typeof value.link === "string") {
      return value.link.trim();
    }
  }

  return "";
}

function extractAsset(value: unknown) {
  if (typeof value === "string") {
    const url = value.trim();
    return url ? { url } : null;
  }

  if (value && typeof value === "object") {
    const url = extractUrl(value);
    if (!url) return null;

    const width =
      "width" in value && Number.isFinite(Number(value.width)) && Number(value.width) > 0
        ? Number(value.width)
        : undefined;
    const height =
      "height" in value && Number.isFinite(Number(value.height)) && Number(value.height) > 0
        ? Number(value.height)
        : undefined;

    return { url, width, height };
  }

  return null;
}

function pickUrl(...values: unknown[]) {
  for (const value of values) {
    const url = extractUrl(value);
    if (url) return url;
  }

  return "";
}

function parseUnitFloor(unitNumber: string | number | null | undefined) {
  const digits = String(unitNumber ?? "").replace(/\D/g, "");
  if (!digits) return null;

  const floorDigits = digits.length > 2 ? digits.slice(0, -2) : digits;
  const floor = Number.parseInt(floorDigits, 10);
  return Number.isFinite(floor) ? floor : null;
}

function normalizeUnitNumber(value: string | number | null | undefined) {
  const digits = String(value ?? "").replace(/\D/g, "");
  return digits.length >= 3 ? digits : "";
}

function extractFilenameStem(value: string | null | undefined) {
  const normalized = String(value ?? "").trim();
  if (!normalized) return "";

  const pathname = normalized.split(/[?#]/, 1)[0] ?? "";
  const filename = pathname.split("/").pop() ?? "";
  if (!filename) return "";

  const stem = filename.replace(/\.[^.]+$/i, "");
  return stem.replace(/-[0-9a-f]{8,}$/i, "");
}

function expandSharedUnitRange(startValue: string, endValue: string) {
  const start = normalizeUnitNumber(startValue);
  const end = normalizeUnitNumber(endValue);
  if (!start || !end) return [];

  const startFloor = parseUnitFloor(start);
  const endFloor = parseUnitFloor(end);
  const startSuffix = start.slice(-2);
  const endSuffix = end.slice(-2);
  if (startFloor === null || endFloor === null || startSuffix !== endSuffix) return [];

  const minFloor = Math.min(startFloor, endFloor);
  const maxFloor = Math.max(startFloor, endFloor);

  return Array.from({ length: maxFloor - minFloor + 1 }, (_, index) => {
    return `${minFloor + index}${startSuffix}`;
  });
}

function extractUnitKeysFromSpec(value: string | null | undefined) {
  const normalized = String(value ?? "").trim();
  if (!normalized) return [];

  const matches = normalized.match(/\d{3,4}/g) ?? [];
  if (!matches.length) return [];

  if (matches.length === 2) {
    const expanded = expandSharedUnitRange(matches[0], matches[1]);
    if (expanded.length) {
      return expanded;
    }
  }

  return [...new Set(matches.map((match) => normalizeUnitNumber(match)).filter(Boolean))];
}

function getFallbackKeyplanMap() {
  const keyplanDir = resolve(process.cwd(), "public", "img-cache");
  if (!existsSync(keyplanDir)) {
    return new Map<
      string,
      { url: string; width?: number; height?: number; aspectRatio?: string }
    >();
  }

  const map = new Map<string, { url: string; width?: number; height?: number; aspectRatio?: string }>();

  for (const filename of readdirSync(keyplanDir)) {
    if (!/^key-plan-.*\.svg$/i.test(filename)) continue;

    const url = `/img-cache/${filename}`;
    const size = getSvgIntrinsicSize(url);
    const width = size?.width;
    const height = size?.height;
    const aspectRatio = width && height ? String(width / height) : undefined;
    const unitKeys = extractUnitKeysFromSpec(extractFilenameStem(filename));

    for (const unit of unitKeys) {
      if (!map.has(unit)) {
        map.set(unit, { url, width, height, aspectRatio });
      }
    }
  }

  return map;
}

function getDetailUnitKeys(detail: any) {
  const image = detail?.floor_plan_image;
  const imageFilenameKeys = extractUnitKeysFromSpec(image?.filename);
  if (imageFilenameKeys.length) return imageFilenameKeys;

  const imageTitleKeys = extractUnitKeysFromSpec(image?.title);
  if (imageTitleKeys.length) return imageTitleKeys;

  const imageUrlKeys = extractUnitKeysFromSpec(extractFilenameStem(image?.url));
  if (imageUrlKeys.length) return imageUrlKeys;

  return extractUnitKeysFromSpec(detail?.unit ?? detail?.unitNumber);
}

function floorSpecMatches(spec: string | null | undefined, floor: number | null) {
  if (floor === null) return false;

  const normalized = String(spec ?? "").trim();
  if (!normalized) return false;

  return normalized.split(/[\n\r,\/]+/).some((token) => {
    const trimmed = token.trim();
    if (!trimmed) return false;

    const rangeMatch = trimmed.match(/^(\d+)\s*[-–—]\s*(\d+)$/);
    if (rangeMatch) {
      const start = Number.parseInt(rangeMatch[1], 10);
      const end = Number.parseInt(rangeMatch[2], 10);
      const min = Math.min(start, end);
      const max = Math.max(start, end);
      return floor >= min && floor <= max;
    }

    const single = Number.parseInt(trimmed, 10);
    return Number.isFinite(single) && single === floor;
  });
}

function derivePdfUrl(sourceUrl: string | null | undefined) {
  const normalized = String(sourceUrl ?? "").trim();
  if (!normalized) return "";

  const match = normalized.match(/^([^?#]+)([?#].*)?$/);
  if (!match) return "";

  const [, pathname, suffix = ""] = match;
  if (/\.pdf$/i.test(pathname)) {
    return normalized;
  }

  if (!/\.(?:jpe?g|png|webp|gif|svg)$/i.test(pathname)) {
    return "";
  }

  return `${pathname.replace(/\.[^.]+$/i, ".pdf")}${suffix}`;
}

function hasPenthouseMarker(...values: unknown[]) {
  return values.some((value) => /\bPH\b/i.test(String(value ?? "").trim()));
}

const panoramicViews = Array.isArray(panoramicViewsPage?.views) ? panoramicViewsPage.views : [];

function getPanoramicView(unitNumber: string) {
  const floor = parseUnitFloor(unitNumber);
  const matchedView = panoramicViews.find((view) => floorSpecMatches(view?.floors, floor));
  if (!matchedView) return null;

  const dayView = extractAsset(matchedView?.day_view);
  const nightView = extractAsset(matchedView?.night_view);

  if (!dayView?.url && !nightView?.url) return null;

  return {
    dayUrl: dayView?.url || nightView?.url || "",
    dayWidth: dayView?.width ?? nightView?.width,
    dayHeight: dayView?.height ?? nightView?.height,
    nightUrl: nightView?.url || "",
    nightWidth: nightView?.width ?? dayView?.width,
    nightHeight: nightView?.height ?? dayView?.height,
  };
}

const rawDetails = (
  Array.isArray(floorPlanDetailPage?.floor_plan_detail) ? floorPlanDetailPage.floor_plan_detail : []
) as any[];
const fallbackKeyplanMap = getFallbackKeyplanMap();
const details = rawDetails.flatMap((detail: any) => {
  const unitKeys = getDetailUnitKeys(detail);
  const keyplan = extractAsset(detail?.floor_plan_keyplan ?? detail?.floorPlanKeyplan);
  const fallbackKeyplan = unitKeys.map((unit) => fallbackKeyplanMap.get(unit)).find(Boolean) ?? null;
  const keyplanUrl = String(keyplan?.url ?? fallbackKeyplan?.url ?? "").trim();
  const keyplanSvgSize = keyplanUrl ? getSvgIntrinsicSize(keyplanUrl) : null;
  const fallbackKeyplanWidth = Number(keyplan?.width);
  const fallbackKeyplanHeight = Number(keyplan?.height);
  const keyplanWidth =
    keyplanSvgSize?.width ??
    fallbackKeyplan?.width ??
    (Number.isFinite(fallbackKeyplanWidth) && fallbackKeyplanWidth > 0
      ? fallbackKeyplanWidth
      : undefined);
  const keyplanHeight =
    keyplanSvgSize?.height ??
    fallbackKeyplan?.height ??
    (Number.isFinite(fallbackKeyplanHeight) && fallbackKeyplanHeight > 0
      ? fallbackKeyplanHeight
      : undefined);
  const image = detail?.floor_plan_image;
  const imageUrl = String(image?.url ?? "").trim();
  const svgSize = imageUrl ? getSvgIntrinsicSize(imageUrl) : null;
  const fallbackImageWidth = Number(image?.width);
  const fallbackImageHeight = Number(image?.height);
  const imageWidth =
    svgSize?.width ??
    (Number.isFinite(fallbackImageWidth) && fallbackImageWidth > 0
      ? fallbackImageWidth
      : undefined);
  const imageHeight =
    svgSize?.height ??
    (Number.isFinite(fallbackImageHeight) && fallbackImageHeight > 0
      ? fallbackImageHeight
      : undefined);
  const pdfUrl = pickUrl(
    detail?.pdf_url,
    detail?.pdfUrl,
    detail?.pdf,
    detail?.floor_plan_pdf,
    detail?.floorPlanPdf
  );
  const isPenthouse = hasPenthouseMarker(
    detail?.unit,
    detail?.unitNumber,
    detail?.floor_plan_pdf?.filename,
    detail?.floor_plan_pdf?.title,
    detail?.floorPlanPdf?.filename,
    detail?.floorPlanPdf?.title,
    detail?.pdf?.filename,
    detail?.pdf?.title,
    extractFilenameStem(pdfUrl)
  );
  return imageUrl
    ? unitKeys.map((unit) => ({
        unit,
        isPenthouse,
        exterior: String(detail?.exterior ?? "").trim(),
        exposure: String(detail?.exposure ?? "").trim(),
        keyplanUrl,
        keyplanWidth,
        keyplanHeight,
        keyplanAspectRatio:
          keyplanWidth && keyplanHeight ? String(keyplanWidth / keyplanHeight) : undefined,
        imageUrl,
        pdfUrl,
        imageWidth,
        imageHeight,
        imageAspectRatio: imageWidth && imageHeight ? String(imageWidth / imageHeight) : undefined,
      }))
    : [];
});

const detailMap = new Map(details.map((detail) => [detail.unit, detail]));

const units = Array.isArray(inventory?.units)
  ? [...inventory.units]
      .sort((a, b) =>
        String(a?.unitNumber || "").localeCompare(String(b?.unitNumber || ""), undefined, {
          numeric: true,
          sensitivity: "base",
        })
      )
      .map((unit) => {
        const unitNumber = String(unit?.unitNumber ?? "").trim();
        const matchedDetail = detailMap.get(unitNumber) ?? null;
        const panoramicView = getPanoramicView(unitNumber);
        const pdfUrl = derivePdfUrl(String(unit?.floorPlanImage ?? ""));

        return {
          ...unit,
          detail: matchedDetail
            ? {
                ...matchedDetail,
                unit: unitNumber,
                panoramicView,
                pdfUrl: matchedDetail.pdfUrl || pdfUrl,
              }
            : null,
        };
      })
  : [];
const floorplanDisclaimer = String(floorplanDisclaimerPage?.floorplan_disclaimer ?? "").trim();
const panoramaDisclaimer =
  String(
    floorplanDisclaimerPage?.panorama_disclaimer ?? floorplanDisclaimerPage?.panoramaDisclaimer ?? ""
  ).trim() || "panorama disclaimer here";
const hasOrientation = units.some((unit) => String(unit?.orientation ?? "").trim());
const columnTemplate = hasOrientation
  ? "minmax(8rem, 1.4fr) minmax(6rem, 0.8fr) minmax(7rem, 0.9fr) minmax(7rem, 0.9fr) minmax(9rem, 1fr)"
  : "minmax(8rem, 1.5fr) minmax(6rem, 0.8fr) minmax(7rem, 0.9fr) minmax(9rem, 1fr)";
const tableStyle = {
  "--floorplans-table-min-width": hasOrientation ? "840px" : "720px",
  "--floorplans-columns": columnTemplate,
};

const numberFormat = new Intl.NumberFormat("en-US");

function formatBathrooms(value: number | string | null | undefined) {
  const numeric = Number(value || 0);
  return Number.isInteger(numeric) ? String(numeric) : numeric.toFixed(1);
}

function formatBedrooms(
  bedrooms: number | string | null | undefined,
  flex: number | string | null | undefined
) {
  const normalized = String(bedrooms ?? "").trim();
  if (!normalized) return "";

  return Number(flex ?? 0) === 1 ? `${normalized} + flex` : normalized;
}

function formatBedroomSummary(
  bedrooms: number | string | null | undefined,
  flex: number | string | null | undefined,
  shortLabel = false
) {
  const normalized = String(bedrooms ?? "").trim();
  if (!normalized) return "";

  const label = shortLabel ? "Bed" : "Bedroom";
  return Number(flex ?? 0) === 1 ? `${normalized} ${label} + Flex` : `${normalized} ${label}`;
}

function isAccessibleResidence(value: unknown) {
  const normalized = String(value ?? "").trim().toLowerCase();
  if (!normalized) return false;

  return ["1", "true", "yes", "accessible", "ada", "type-a", "type a"].includes(normalized);
}

function formatOutdoorSpace(value: string | null | undefined) {
  return String(value ?? "").trim().replace(/\s+/g, " ");
}

function formatOrientation(value: string | null | undefined) {
  return String(value ?? "").trim() || "-";
}

function formatSquareFootage(value: number | string | null | undefined) {
  const normalized = String(value ?? "").trim();
  if (!normalized) return "";

  const squareFootageMatch = normalized.match(
    /^([\d,]+(?:\.\d+)?)\s*(?:s\.?f\.?|sq\.?\s*ft\.?|square\s+feet)?\.?$/i
  );

  if (squareFootageMatch) {
    const numeric = Number(squareFootageMatch[1].replace(/,/g, ""));
    if (Number.isFinite(numeric)) {
      return `${numberFormat.format(numeric)} SF`;
    }
  }

  return normalized.replace(/\s+approx\.?$/i, "");
}

function getPanoramaIndicativeFloorLabel(floor: number | null) {
  if (floor === null) return "";
  if (floor >= 5 && floor <= 9) return "5";
  if (floor >= 10 && floor <= 14) return "10";
  if (floor >= 15 && floor <= 19) return "15";
  if (floor === 20) return "20";
  if (floor >= 21) return "21";
  return "";
}

function formatResidenceLabel(
  value: string | number | null | undefined,
  isPenthouse = false,
  isAccessible = false
) {
  const unitNumber = String(value ?? "").trim();
  const label = isPenthouse ? `PH ${unitNumber}` : unitNumber;
  return isAccessible ? `${label}*` : label;
}
---

<div class="floorplans-wrap" data-floorplans-table>
  <div class="floorplans-scroller">
    <div
      id={tableId}
      class="floorplans-table"
      data-has-orientation={hasOrientation ? "true" : "false"}
      style={tableStyle}
    >
      <div class="floorplans-head-row">
        <div class="floorplans-head hw-contain">
          <div class="floorplans-cell floorplans-cell--unit">
            <button
              type="button"
              class="floorplans-sort-button floorplans-sort-button--start"
              data-sort-key="unitNumber"
              data-label="Residence"
              aria-pressed="false"
            >
              <span class="floorplans-sort-label">
                <span class="floorplans-sort-text">Residence</span>
              </span>
              <span class="floorplans-sort-indicator" aria-hidden="true"></span>
            </button>
          </div>
          <div class="floorplans-cell floorplans-cell--metric">
            <button
              type="button"
              class="floorplans-sort-button"
              data-sort-key="bedrooms"
              data-label="Bedrooms"
              aria-pressed="false"
            >
              <span class="floorplans-sort-label">
                <span class="floorplans-sort-text floorplans-sort-text--full">Bedrooms</span>
                <span class="floorplans-sort-text floorplans-sort-text--short">Beds</span>
              </span>
              <span class="floorplans-sort-indicator" aria-hidden="true"></span>
            </button>
          </div>
          <div class="floorplans-cell floorplans-cell--metric floorplans-cell--bathrooms">
            <button
              type="button"
              class="floorplans-sort-button"
              data-sort-key="bathrooms"
              data-label="Bathrooms"
              aria-pressed="false"
            >
              <span class="floorplans-sort-label">
                <span class="floorplans-sort-text floorplans-sort-text--full">Bathrooms</span>
                <span class="floorplans-sort-text floorplans-sort-text--short">Baths</span>
              </span>
              <span class="floorplans-sort-indicator" aria-hidden="true"></span>
            </button>
          </div>
          <div class="floorplans-cell floorplans-cell--metric">
            <button
              type="button"
              class="floorplans-sort-button"
              data-sort-key="area"
              data-label="SF"
              aria-pressed="false"
            >
              <span class="floorplans-sort-label">SF</span>
              <span class="floorplans-sort-indicator" aria-hidden="true"></span>
            </button>
          </div>
          {hasOrientation && (
            <div class="floorplans-cell floorplans-cell--orientation">
              <button
                type="button"
                class="floorplans-sort-button"
                data-sort-key="exposure"
                data-label="Exposure"
                aria-pressed="false"
              >
                <span class="floorplans-sort-label">Exposure</span>
                <span class="floorplans-sort-indicator" aria-hidden="true"></span>
              </button>
            </div>
          )}
          <div class="floorplans-cell floorplans-cell--action">
            <span class="floorplans-action-label">Floor Plan View</span>
            <span class="floorplans-action-placeholder" aria-hidden="true">View</span>
          </div>
        </div>
      </div>

      <div class="floorplans-body" data-floorplans-body>
        {units.map((unit) => {
          const hasDetail = Boolean(unit.detail?.imageUrl);
          const detailId = tableId + "-detail-" + unit.unitNumber;
          const panoramaId = detailId + "-panorama";
          const unitFloor = parseUnitFloor(unit.unitNumber);
          const isPenthouse = Boolean(unit.detail?.isPenthouse);
          const isAccessible = isAccessibleResidence(unit.accessibility);
          const unitLabel = formatResidenceLabel(unit.unitNumber, isPenthouse, isAccessible);
          const bedroomLabel = formatBedrooms(unit.bedrooms, unit.flex);
          const bedroomSummaryLabel = formatBedroomSummary(unit.bedrooms, unit.flex);
          const bedroomSummaryShortLabel = formatBedroomSummary(unit.bedrooms, unit.flex, true);
          const interiorLabel = formatSquareFootage(unit.area);
          const exteriorValue =
            Number.isFinite(Number(unit.outdoorArea)) && Number(unit.outdoorArea) > 0
              ? unit.outdoorArea
              : unit.detail?.exterior;
          const exteriorLabel = formatSquareFootage(exteriorValue);
          const outdoorSpaceLabel = formatOutdoorSpace(unit.outdoorSpace);
          const bathSummaryLabel = `${formatBathrooms(unit.bathrooms)} Bath`;
          const exposureSortValue = String(unit.orientation ?? "").trim();
          const exposureLabel = formatOrientation(exposureSortValue);
          const panoramaExposureValue = exposureSortValue;
          const panoramaFloorLabel = getPanoramaIndicativeFloorLabel(unitFloor);
          const panorama = unit.detail?.panoramicView;
          const hasPanorama = Boolean(panorama?.dayUrl || panorama?.nightUrl);
          const showPanoramaAction =
            hasPanorama && !(unitFloor !== null && unitFloor >= 2 && unitFloor <= 4);
          const pdfUrl = String(unit.detail?.pdfUrl ?? "").trim();
          const keyplanUrl = String(unit.detail?.keyplanUrl ?? "").trim();
          const usePenthouseLayout = isPenthouse;
          const hasKeyplan = Boolean(keyplanUrl);

          return (
            <div
              class={"floorplans-item" + (hasDetail ? " floorplans-item--interactive" : "")}
              data-unit-item
              data-unit-number={unit.unitNumber}
              data-bedrooms={unit.bedrooms}
              data-bathrooms={unit.bathrooms}
              data-area={unit.area}
              data-exposure={exposureSortValue}
            >
              <div
                class={"floorplans-row hw-contain" + (hasDetail ? " floorplans-row--interactive" : "")}
                data-floorplans-row
                role={hasDetail ? "button" : undefined}
                tabindex={hasDetail ? "0" : undefined}
                aria-haspopup={hasDetail ? "dialog" : undefined}
                aria-expanded={hasDetail ? "false" : undefined}
                aria-controls={hasDetail ? detailId : undefined}
              >
                <div class="floorplans-cell floorplans-cell--unit">{unitLabel}</div>
                <div class="floorplans-cell floorplans-cell--metric">{bedroomLabel}</div>
                <div class="floorplans-cell floorplans-cell--metric floorplans-cell--bathrooms">
                  {formatBathrooms(unit.bathrooms)}
                </div>
                <div class="floorplans-cell floorplans-cell--metric">
                  <span class="floorplans-area-approx">Approx.&nbsp;</span>
                  {numberFormat.format(unit.area)} SF
                  <span class="floorplans-area-asterisk"> *</span>
                </div>
                {hasOrientation && (
                  <div class="floorplans-cell floorplans-cell--orientation">
                    {formatOrientation(unit.orientation)}
                  </div>
                )}
                <div class="floorplans-cell floorplans-cell--action">
                  {hasDetail ? (
                    <span
                      class="floorplans-view-link"
                    >
                      View
                    </span>
                  ) : (
                    <span>-</span>
                  )}
                </div>
              </div>

              {hasDetail && (
                <div id={detailId} class="floorplans-modal" data-floorplans-modal hidden>
                  <button
                    type="button"
                    class="floorplans-modal-backdrop"
                    data-floorplans-close
                    aria-label={"Close floor plan for unit " + unit.unitNumber}
                  ></button>

                  <div
                    class="floorplans-modal-card"
                    data-floorplans-modal-card
                    data-floorplan-zoomed="false"
                    role="dialog"
                    aria-modal="true"
                    aria-label={"Floor plan for unit " + unit.unitNumber}
                  >
                    <button
                      type="button"
                      class="floorplans-modal-close"
                      data-floorplans-close
                      data-floorplans-close-button
                      aria-label={"Close floor plan for unit " + unit.unitNumber}
                    >
                      Close
                    </button>

                    <div class="floorplans-detail-copy">
                      <div class="floorplans-detail-meta">
                        <p>Residence {unitLabel}</p>
                        <p class="floorplans-detail-summary">
                          {bedroomSummaryLabel && (
                            <span class="floorplans-detail-summary-item floorplans-detail-summary-item--bedrooms">
                              <span class="floorplans-detail-summary-text floorplans-detail-summary-text--full">
                                {bedroomSummaryLabel}
                              </span>
                              <span class="floorplans-detail-summary-text floorplans-detail-summary-text--short">
                                {bedroomSummaryShortLabel}
                              </span>
                            </span>
                          )}
                          <span>{bathSummaryLabel}</span>
                          {outdoorSpaceLabel && <span>{outdoorSpaceLabel}</span>}
                        </p>
                        <p>Approx. Interior: {interiorLabel}</p>
                        {exteriorLabel && <p>Approx. Exterior: {exteriorLabel}</p>}
                        <p>Exposure: {exposureLabel}</p>
                      </div>

                      {(showPanoramaAction || pdfUrl) && (
                        <div class="floorplans-detail-actions">
                          {showPanoramaAction && (
                            <button
                              type="button"
                              class="floorplans-detail-action floorplans-detail-action--view"
                              data-floorplans-panorama-open
                              aria-haspopup="dialog"
                              aria-expanded="false"
                              aria-controls={panoramaId}
                            >
                              See View
                            </button>
                          )}

                          {pdfUrl && (
                            <a
                              href={pdfUrl}
                              class="floorplans-detail-action floorplans-detail-action--download"
                              target="_blank"
                              rel="noopener noreferrer"
                            >
                              Open PDF
                            </a>
                          )}
                        </div>
                      )}
                    </div>

                    <div class="floorplans-modal-scroll" data-floorplans-modal-scroll>
                      <div class="floorplans-detail-shell">
                        <div class="floorplans-detail-inner">
                          <div class="floorplans-detail-visual">
                            <div
                              class={
                                "floorplans-detail-viewer" +
                                (usePenthouseLayout ? " floorplans-detail-viewer--with-keyplan" : "")
                              }
                            >
                              <FloorplanZoomViewer
                                client:load
                                src={unit.detail.imageUrl}
                                width={unit.detail.imageWidth}
                                height={unit.detail.imageHeight}
                                imageAspectRatio={unit.detail.imageAspectRatio}
                                alt={"Floor plan for unit " + unit.unitNumber}
                              />
                            </div>

                            {hasKeyplan && (
                              <div class="floorplans-detail-keyplan">
                                <img
                                  src={keyplanUrl}
                                  width={unit.detail.keyplanWidth}
                                  height={unit.detail.keyplanHeight}
                                  alt={"Key plan for unit " + unit.unitNumber}
                                  loading="eager"
                                  decoding="async"
                                />
                              </div>
                            )}
                          </div>
                        </div>

                        {floorplanDisclaimer && (
                          <div class="floorplans-detail-disclaimer">
                            <p>{floorplanDisclaimer}</p>
                          </div>
                        )}
                      </div>
                    </div>

                    {showPanoramaAction && (
                      <div
                        id={panoramaId}
                        class="floorplans-panorama-modal"
                        data-floorplans-panorama-modal
                        hidden
                      >
                        <div
                          class="floorplans-panorama-card"
                          role="dialog"
                          aria-label={"Panoramic view for unit " + unit.unitNumber}
                        >
                          <button
                            type="button"
                            class="floorplans-modal-close floorplans-panorama-close"
                            data-floorplans-panorama-close
                            data-floorplans-panorama-close-button
                            aria-label={"Close panoramic view for unit " + unit.unitNumber}
                          >
                            Close
                          </button>

                          <div class="floorplans-detail-copy floorplans-panorama-copy">
                            <div class="floorplans-detail-meta">
                              <p>Residence {unitLabel}</p>
                              {panoramaExposureValue && (
                                <p class="floorplans-panorama-copyline">
                                  Views from this residence: {panoramaExposureValue}
                                </p>
                              )}
                              {panoramaFloorLabel && (
                                <p class="floorplans-panorama-copyline">
                                  Indicative views from floor {panoramaFloorLabel}
                                </p>
                              )}
                            </div>
                          </div>

                          <div class="floorplans-panorama-scroll" data-floorplans-panorama-scroll>
                            <div class="floorplans-panorama-shell">
                              <div class="floorplans-panorama-stage">
                                <div class="floorplans-panorama-viewer">
                                  <PanoramicViewViewer
                                    client:load
                                    daySrc={panorama.dayUrl}
                                    dayWidth={panorama.dayWidth}
                                    dayHeight={panorama.dayHeight}
                                    nightSrc={panorama.nightUrl}
                                    nightWidth={panorama.nightWidth}
                                    nightHeight={panorama.nightHeight}
                                    alt={"Panoramic view for unit " + unit.unitNumber}
                                  />
                                </div>
                              </div>

                              {panoramaDisclaimer && (
                                <div class="floorplans-detail-disclaimer floorplans-panorama-disclaimer">
                                  <p>{panoramaDisclaimer}</p>
                                </div>
                              )}
                            </div>
                          </div>
                        </div>
                      </div>
                    )}
                  </div>
                </div>
              )}
            </div>
          );
        })}
      </div>
    </div>
  </div>

  {!units.length && <p class="floorplans-empty hw-contain">No floorplans available.</p>}
</div>

<script>
  (() => {
    const init = () => {
      const roots = Array.from(document.querySelectorAll("[data-floorplans-table]"));
      if (!roots.length) return;

      roots.forEach((root) => {
        if (!(root instanceof HTMLElement)) return;

        const body = root.querySelector("[data-floorplans-body]");
        if (!(body instanceof HTMLElement)) return;

        if (root.dataset.floorplansInitialized === "true") {
          return;
        }

        root.dataset.floorplansInitialized = "true";
        const abortController = new AbortController();

        const buttons = Array.from(root.querySelectorAll("[data-sort-key]"));
        const numericSortKeys = new Set(["bedrooms", "bathrooms", "area"]);
        const mobileWidthQuery = window.matchMedia("(max-width: 884px)");
        const detailCopyHeightQuery = window.matchMedia("(max-width: 814px)");
        let sortKey = "";
        let sortDir = "asc";
        let headerHiddenBeforeModal = false;
        let lockedScrollY = 0;
        let lockedScrollbarWidth = 0;
        let activeScrollLockMode = "none";
        const modalFadeMs = 400;
        const modalCloseTimers = new WeakMap();
        const panoramaFadeMs = 300;
        const panoramaCloseTimers = new WeakMap();
        let mobileColumnSyncFrame = 0;
        const detailCopySyncFrames = new Map();
        const detailCopyObservers = [];
        const getItems = () => Array.from(body.querySelectorAll("[data-unit-item]"));
        const getOpenItem = () =>
          getItems().find((item) => item.classList.contains("is-modal-open"));
        const hasOpenModal = () =>
          document.querySelector("[data-floorplans-modal]:not([hidden])") instanceof HTMLElement;
        const getLocoScroll = () => {
          const locoScroll = window.locoScroll;
          if (
            locoScroll &&
            typeof locoScroll.stop === "function" &&
            typeof locoScroll.start === "function"
          ) {
            return locoScroll;
          }

          return null;
        };
        const getCurrentScrollY = () => {
          const locoScroll = getLocoScroll();
          const locoY = locoScroll?.lenisInstance?.scroll;
          if (typeof locoY === "number" && Number.isFinite(locoY)) {
            return locoY;
          }

          return (
            window.scrollY ||
            document.scrollingElement?.scrollTop ||
            document.documentElement.scrollTop ||
            0
          );
        };
        const isHeaderHidden = () =>
          document.getElementById("header")?.classList.contains("is-hidden") ?? false;
        const setHeaderHidden = (hidden) => {
          if (typeof window.__setStickyHeaderHidden === "function") {
            window.__setStickyHeaderHidden(hidden);
            return;
          }

          document.getElementById("header")?.classList.toggle("is-hidden", hidden);
        };
        const lockPageScroll = () => {
          const locoScroll = getLocoScroll();
          lockedScrollY = getCurrentScrollY();

          if (locoScroll) {
            activeScrollLockMode = "loco";
            locoScroll.stop();
            return;
          }

          activeScrollLockMode = "native";
          lockedScrollbarWidth = Math.max(
            0,
            window.innerWidth - document.documentElement.clientWidth
          );
          document.documentElement.style.setProperty(
            "--floorplans-scrollbar-compensation",
            lockedScrollbarWidth + "px"
          );

          document.body.style.position = "fixed";
          document.body.style.top = "-" + lockedScrollY + "px";
          document.body.style.width = "100%";
          document.body.classList.add("floorplans-modal-open");
        };
        const unlockPageScroll = () => {
          if (hasOpenModal()) return;

          const savedY = lockedScrollY;

          if (activeScrollLockMode === "loco") {
            const locoScroll = getLocoScroll();
            if (locoScroll?.scrollTo) {
              locoScroll.scrollTo(savedY, {
                immediate: true,
                force: true,
              });
            } else {
              window.scrollTo({ top: savedY, left: 0, behavior: "auto" });
            }

            locoScroll?.start();
            activeScrollLockMode = "none";
            return;
          }

          if (activeScrollLockMode === "native") {
            document.body.style.position = "";
            document.body.style.top = "";
            document.body.style.width = "";
            document.body.classList.remove("floorplans-modal-open");
            document.documentElement.style.removeProperty("--floorplans-scrollbar-compensation");
            window.scrollTo({ top: savedY, left: 0, behavior: "auto" });
          }

          activeScrollLockMode = "none";
        };
        const clearModalCloseTimer = (modal) => {
          const closeTimer = modalCloseTimers.get(modal);
          if (closeTimer) {
            window.clearTimeout(closeTimer);
            modalCloseTimers.delete(modal);
          }
        };
        const clearPanoramaCloseTimer = (modal) => {
          const closeTimer = panoramaCloseTimers.get(modal);
          if (closeTimer) {
            window.clearTimeout(closeTimer);
            panoramaCloseTimers.delete(modal);
          }
        };
        const finalizePanoramaClose = (item, modal, restoreFocus = false) => {
          const trigger = getPanoramaTrigger(item);

          clearPanoramaCloseTimer(modal);
          modal.hidden = true;
          modal.classList.remove("is-visible", "is-closing");
          item.classList.remove("is-panorama-open");

          if (trigger instanceof HTMLElement) {
            trigger.setAttribute("aria-expanded", "false");

            if (restoreFocus) {
              trigger.focus({ preventScroll: true });
            }
          }
        };
        const setPanoramaOpen = (item, open, restoreFocus = false) => {
          const modal = getPanoramaModal(item);
          const trigger = getPanoramaTrigger(item);

          if (!(modal instanceof HTMLElement) || !(trigger instanceof HTMLElement)) return false;

          if (open) {
            clearPanoramaCloseTimer(modal);
            item.classList.add("is-panorama-open");
            modal.hidden = false;
            modal.classList.remove("is-closing", "is-visible");
            trigger.setAttribute("aria-expanded", "true");

            requestAnimationFrame(() => {
              if (!modal.hidden) {
                modal.classList.add("is-visible");
              }
            });

            const scrollRegion = modal.querySelector("[data-floorplans-panorama-scroll]");
            if (scrollRegion instanceof HTMLElement) {
              scrollRegion.scrollTop = 0;
            }

            const closeButton = modal.querySelector("[data-floorplans-panorama-close-button]");
            if (closeButton instanceof HTMLElement) {
              closeButton.focus({ preventScroll: true });
            }

            return true;
          }

          clearPanoramaCloseTimer(modal);
          modal.classList.remove("is-visible");
          modal.classList.add("is-closing");

          const closeTimer = window.setTimeout(() => {
            finalizePanoramaClose(item, modal, restoreFocus);
          }, panoramaFadeMs);
          panoramaCloseTimers.set(modal, closeTimer);
          return true;
        };
        const closePanoramaInItem = (item, restoreFocus = false, immediate = false) => {
          if (!(item instanceof HTMLElement)) return false;
          if (!item.classList.contains("is-panorama-open")) return false;

          const modal = getPanoramaModal(item);
          if (!(modal instanceof HTMLElement)) {
            item.classList.remove("is-panorama-open");
            return false;
          }

          if (immediate) {
            finalizePanoramaClose(item, modal, restoreFocus);
            return true;
          }

          return setPanoramaOpen(item, false, restoreFocus);
        };
        const finalizeItemClose = (item, modal, row, restoreFocus = false) => {
          clearModalCloseTimer(modal);
          modal.hidden = true;
          modal.classList.remove("is-visible", "is-closing");

          if (modal.parentElement !== item) {
            item.appendChild(modal);
          }

          unlockPageScroll();

          if (!hasOpenModal()) {
            setHeaderHidden(headerHiddenBeforeModal);

            if (restoreFocus) {
              row.focus({ preventScroll: true });
            }
          }
        };
        const getItemModal = (item, row) => {
          const modalId = row?.getAttribute("aria-controls");
          if (modalId) {
            const modalById = document.getElementById(modalId);
            if (modalById instanceof HTMLElement) {
              return modalById;
            }
          }

          const modalInItem = item.querySelector("[data-floorplans-modal]");
          return modalInItem instanceof HTMLElement ? modalInItem : null;
        };
        const getPanoramaModal = (item) => {
          if (!(item instanceof HTMLElement)) return null;
          const row = item.querySelector("[data-floorplans-row]");
          const itemModal = row instanceof HTMLElement ? getItemModal(item, row) : null;
          if (!(itemModal instanceof HTMLElement)) return null;

          const panoramaModal = itemModal.querySelector("[data-floorplans-panorama-modal]");
          return panoramaModal instanceof HTMLElement ? panoramaModal : null;
        };
        const getPanoramaTrigger = (item) => {
          if (!(item instanceof HTMLElement)) return null;
          const row = item.querySelector("[data-floorplans-row]");
          const itemModal = row instanceof HTMLElement ? getItemModal(item, row) : null;
          if (!(itemModal instanceof HTMLElement)) return null;

          const trigger = itemModal.querySelector("[data-floorplans-panorama-open]");
          return trigger instanceof HTMLElement ? trigger : null;
        };
        const getModalCard = (modal) => {
          if (!(modal instanceof HTMLElement)) return null;

          const modalCard = modal.querySelector("[data-floorplans-modal-card]");
          return modalCard instanceof HTMLElement ? modalCard : null;
        };
        const getModalDetailCopy = (modal) => {
          const modalCard = getModalCard(modal);
          if (!(modalCard instanceof HTMLElement)) return null;

          return (
            Array.from(modalCard.children).find(
              (child) =>
                child instanceof HTMLElement &&
                child.classList.contains("floorplans-detail-copy")
            ) ?? null
          );
        };
        const syncModalDetailCopyHeight = (modal) => {
          const modalCard = getModalCard(modal);
          const detailCopy = getModalDetailCopy(modal);

          if (!(modalCard instanceof HTMLElement)) return;

          if (
            !(detailCopy instanceof HTMLElement) ||
            modal.hidden ||
            !detailCopyHeightQuery.matches
          ) {
            modalCard.style.removeProperty("--floorplans-detail-copy-height");
            return;
          }

          const detailCopyHeight = Math.ceil(detailCopy.getBoundingClientRect().height);
          if (detailCopyHeight > 0) {
            modalCard.style.setProperty(
              "--floorplans-detail-copy-height",
              detailCopyHeight + "px"
            );
          }
        };
        const scheduleModalDetailCopyHeightSync = (modal) => {
          if (!(modal instanceof HTMLElement)) return;

          const pendingFrame = detailCopySyncFrames.get(modal);
          if (pendingFrame) return;

          const nextFrame = window.requestAnimationFrame(() => {
            detailCopySyncFrames.delete(modal);
            syncModalDetailCopyHeight(modal);
          });

          detailCopySyncFrames.set(modal, nextFrame);
        };
        const observeModalDetailCopy = (modal) => {
          if (!(modal instanceof HTMLElement) || !("ResizeObserver" in window)) return;

          const modalCard = getModalCard(modal);
          const detailCopy = getModalDetailCopy(modal);
          if (!(modalCard instanceof HTMLElement) || !(detailCopy instanceof HTMLElement)) return;

          const observer = new ResizeObserver(() => {
            scheduleModalDetailCopyHeightSync(modal);
          });

          observer.observe(modalCard);
          observer.observe(detailCopy);
          detailCopyObservers.push(observer);
        };
        const scheduleOpenModalDetailCopyHeightSync = () => {
          const openModal = document.querySelector("[data-floorplans-modal]:not([hidden])");
          if (openModal instanceof HTMLElement) {
            scheduleModalDetailCopyHeightSync(openModal);
          }
        };
        const setItemOpen = (item, open, restoreFocus = false) => {
          const row = item.querySelector("[data-floorplans-row]");
          const modal = row instanceof HTMLElement ? getItemModal(item, row) : null;

          if (!(row instanceof HTMLElement) || !(modal instanceof HTMLElement)) return;

          item.classList.toggle("is-modal-open", open);
          row.setAttribute("aria-expanded", open ? "true" : "false");

          if (open) {
            clearModalCloseTimer(modal);

            if (modal.parentElement !== document.body) {
              document.body.appendChild(modal);
            }

            modal.hidden = false;
            modal.classList.remove("is-closing", "is-visible");
            syncModalDetailCopyHeight(modal);
            const scrollRegion = modal.querySelector("[data-floorplans-modal-scroll]");
            if (scrollRegion instanceof HTMLElement) {
              scrollRegion.scrollTop = 0;
            }
            headerHiddenBeforeModal = isHeaderHidden();
            setHeaderHidden(false);
            lockPageScroll();
            requestAnimationFrame(() => {
              scheduleModalDetailCopyHeightSync(modal);
              if (!modal.hidden) {
                modal.classList.add("is-visible");
              }
            });

            const closeButton = modal.querySelector("[data-floorplans-close-button]");
            if (closeButton instanceof HTMLElement) {
              closeButton.focus({ preventScroll: true });
            }

            return;
          }

          closePanoramaInItem(item, false, true);

          clearModalCloseTimer(modal);
          modal.classList.remove("is-visible");
          modal.classList.add("is-closing");

          const closeTimer = window.setTimeout(() => {
            finalizeItemClose(item, modal, row, restoreFocus);
          }, modalFadeMs);
          modalCloseTimers.set(modal, closeTimer);
        };
        const closeOpenItem = (restoreFocus = false) => {
          const item = getOpenItem();
          if (!item) {
            unlockPageScroll();
            return;
          }

          setItemOpen(item, false, restoreFocus);
        };
        const openItem = (item) => {
          if (item.classList.contains("is-modal-open")) return;

          closeOpenItem();
          setItemOpen(item, true);
        };
        const compareUnitNumbers = (valueA, valueB) =>
          String(valueA ?? "").localeCompare(String(valueB ?? ""), undefined, {
            numeric: true,
            sensitivity: "base",
          });
        const compareTextValues = (valueA, valueB) => {
          const textA = String(valueA ?? "").trim();
          const textB = String(valueB ?? "").trim();
          const hasTextA = textA.length > 0;
          const hasTextB = textB.length > 0;

          if (hasTextA !== hasTextB) {
            return hasTextA ? -1 : 1;
          }

          return textA.localeCompare(textB, undefined, {
            numeric: true,
            sensitivity: "base",
          });
        };
        const syncMobileColumnWidths = () => {
          mobileColumnSyncFrame = 0;

          if (!mobileWidthQuery.matches) {
            root.style.removeProperty("--floorplans-mobile-unit-column");
            return;
          }

          const unitCells = [
            ...root.querySelectorAll(".floorplans-head .floorplans-cell--unit"),
            ...root.querySelectorAll(".floorplans-row .floorplans-cell--unit"),
          ].filter((cell) => cell instanceof HTMLElement);

          if (!unitCells.length) return;

          const unitColumnWidth = Math.ceil(
            unitCells.reduce((maxWidth, cell) => {
              return Math.max(maxWidth, cell.getBoundingClientRect().width);
            }, 0)
          );

          if (unitColumnWidth > 0) {
            root.style.setProperty("--floorplans-mobile-unit-column", unitColumnWidth + "px");
          }
        };
        const scheduleMobileColumnSync = () => {
          if (mobileColumnSyncFrame) return;

          mobileColumnSyncFrame = window.requestAnimationFrame(() => {
            syncMobileColumnWidths();
          });
        };

        const updateButtons = () => {
          buttons.forEach((button) => {
            const active = button.dataset.sortKey === sortKey;
            const indicator = button.querySelector(".floorplans-sort-indicator");
            if (indicator instanceof HTMLElement) {
              indicator.dataset.sortDirection = active ? sortDir : "";
            }
            button.setAttribute("aria-pressed", active ? "true" : "false");
          });
        };

        const sortRows = (key, dir) => {
          const items = getItems();

          items.sort((itemA, itemB) => {
            if (numericSortKeys.has(key)) {
              const valueA = Number(itemA.dataset[key] || 0);
              const valueB = Number(itemB.dataset[key] || 0);

              if (valueA !== valueB) {
                return dir === "asc" ? valueA - valueB : valueB - valueA;
              }
            } else {
              const comparison = compareTextValues(itemA.dataset[key], itemB.dataset[key]);

              if (comparison !== 0) {
                return dir === "asc" ? comparison : -comparison;
              }
            }

            return compareUnitNumbers(itemA.dataset.unitNumber, itemB.dataset.unitNumber);
          });

          items.forEach((item) => body.appendChild(item));
        };

        getItems().forEach((item) => {
          const row = item.querySelector("[data-floorplans-row]");
          const modal = item.querySelector("[data-floorplans-modal]");

          if (row instanceof HTMLElement && row.getAttribute("role") === "button") {
            row.addEventListener("click", (event) => {
              if (event.target instanceof HTMLElement && event.target.closest("button")) return;
              openItem(item);
            });

            row.addEventListener("keydown", (event) => {
              if (event.key !== "Enter" && event.key !== " ") return;
              event.preventDefault();
              openItem(item);
            });
          }

          if (modal instanceof HTMLElement) {
            observeModalDetailCopy(modal);
            modal.addEventListener("click", (event) => {
              if (!(event.target instanceof HTMLElement)) return;
              if (event.target.closest("[data-floorplans-panorama-open]")) {
                event.preventDefault();
                setPanoramaOpen(item, true);
                return;
              }
              if (event.target.closest("[data-floorplans-panorama-close]")) {
                event.preventDefault();
                closePanoramaInItem(item, true);
                return;
              }
              if (event.target.closest("[data-floorplans-close]")) {
                closeOpenItem(true);
              }
            });
          }
        });

        buttons.forEach((button) => {
          button.addEventListener("click", () => {
            const key = button.dataset.sortKey;
            if (!key) return;

            closeOpenItem();
            sortDir = sortKey === key && sortDir === "asc" ? "desc" : "asc";
            sortKey = key;
            sortRows(key, sortDir);
            updateButtons();
          });
        });

        document.addEventListener(
          "keydown",
          (event) => {
            if (event.key === "Escape") {
              const openItem = getOpenItem();
              if (closePanoramaInItem(openItem, true)) {
                return;
              }
              closeOpenItem(true);
            }
          },
          { signal: abortController.signal }
        );

        window.addEventListener("resize", scheduleMobileColumnSync, {
          signal: abortController.signal,
        });
        mobileWidthQuery.addEventListener("change", scheduleMobileColumnSync, {
          signal: abortController.signal,
        });
        window.addEventListener("resize", scheduleOpenModalDetailCopyHeightSync, {
          signal: abortController.signal,
        });
        detailCopyHeightQuery.addEventListener("change", scheduleOpenModalDetailCopyHeightSync, {
          signal: abortController.signal,
        });
        document.fonts?.ready?.then(() => {
          scheduleMobileColumnSync();
          scheduleOpenModalDetailCopyHeightSync();
        });

        updateButtons();
        scheduleMobileColumnSync();
        document.addEventListener(
          "astro:before-swap",
          () => {
            detailCopySyncFrames.forEach((frame) => {
              window.cancelAnimationFrame(frame);
            });
            detailCopySyncFrames.clear();
            detailCopyObservers.forEach((observer) => {
              observer.disconnect();
            });
            if (mobileColumnSyncFrame) {
              window.cancelAnimationFrame(mobileColumnSyncFrame);
              mobileColumnSyncFrame = 0;
            }
            closeOpenItem();
            abortController.abort();
          },
          { once: true }
        );
      });
    };

    init();
    document.addEventListener("astro:page-load", init);
    document.addEventListener("astro:after-swap", init);
  })();
</script>

<style>
  :global(body.floorplans-modal-open) {
    overflow: hidden;
    padding-right: var(--floorplans-scrollbar-compensation, 0px);
    height: 100vh;
    position: relative;
  }

  .floorplans-scroller {
    overflow-x: auto;
  }

  .floorplans-wrap {
    --floorplans-chevron-icon: url("data:image/svg+xml,%3Csvg%20width%3D%229%22%20height%3D%2215%22%20viewBox%3D%220%200%209%2015%22%20fill%3D%22none%22%20xmlns%3D%22http%3A//www.w3.org/2000/svg%22%3E%3Cpath%20d%3D%22M0.353516%2014.3535L7.35352%207.35352L0.353516%200.353516%22%20stroke%3D%22black%22/%3E%3C/svg%3E");
    width: 100%;
  }

  .floorplans-table {
    width: 100%;
    min-width: var(--floorplans-table-min-width, 720px);
    font-family: "Hanken Grotesk", system-ui, sans-serif;
    font-size: 1.33rem;
    line-height: 1.75rem;
  }

  .floorplans-head {
    display: grid;
    grid-template-columns: var(--floorplans-columns);
  }

  .floorplans-head-row {
    border-bottom: 1px solid var(--brown);
  }

  .floorplans-head,
  .floorplans-row {
    display: grid;
    grid-template-columns: var(--floorplans-columns);
    width: 100%;
    justify-content: space-between;
  }

  .floorplans-cell {
    box-sizing: border-box;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 1.25rem 0.5rem;
    text-align: center;
    vertical-align: middle;
    min-width: 0;
    font-weight: 400;
  }

  .floorplans-item {
    border-bottom: 1px solid var(--brown);
  }

  .floorplans-item--interactive {
    transition: background-color 160ms ease;
  }

  .floorplans-item--interactive:hover,
  .floorplans-item--interactive:focus-within {
    background: rgba(58, 42, 34, 0.05);
  }

  .floorplans-row--interactive {
    cursor: pointer;
  }

  .floorplans-row--interactive:focus-visible {
    outline: 2px solid currentColor;
    outline-offset: -2px;
  }

  .floorplans-head .floorplans-cell {
    font-weight: 700;
  }

  .floorplans-head .floorplans-cell--unit {
    font-weight: 400;
  }

  .floorplans-cell--unit {
    font-family: "Figure Extended", "Hanken Grotesk", system-ui, sans-serif;
    font-size: 1.75rem;
    line-height: 2.25rem;
    font-weight: 400;
    justify-content: flex-start;
    text-align: left;
  }

  .floorplans-cell--action {
    justify-content: flex-end;
    text-align: right;
  }

  .floorplans-cell--bathrooms {
    display: none;
  }

  .floorplans-cell--metric,
  .floorplans-cell--orientation {
    justify-content: center;
    text-align: center;
  }

  .floorplans-sort-button {
    appearance: none;
    background: transparent;
    border: 0;
    cursor: pointer;
    display: grid;
    grid-template-columns: 1fr auto 1fr;
    align-items: center;
    font: inherit;
    font-weight: inherit;
    padding: 0;
    text-align: center;
    width: 100%;
    white-space: nowrap;
  }

  .floorplans-sort-button--start {
    grid-template-columns: auto auto 1fr;
    text-align: left;
  }

  .floorplans-sort-label {
    grid-column: 2;
    justify-self: center;
  }

  .floorplans-sort-text--short {
    display: none;
  }

  .floorplans-action-label {
    display: inline;
  }

  .floorplans-action-placeholder {
    display: none;
  }

  .floorplans-area-approx {
    display: inline;
  }

  .floorplans-area-asterisk {
    display: none;
  }

  .floorplans-sort-button--start .floorplans-sort-label {
    grid-column: 1;
    justify-self: start;
  }

  .floorplans-sort-indicator {
    grid-column: 3;
    align-self: center;
    display: inline-flex;
    align-items: center;
    justify-content: flex-end;
    justify-self: start;
    width: 1.0625rem;
    height: 0.9375rem;
    padding-left: 0.25rem;
    box-sizing: content-box;
    opacity: 0;
    transition: opacity 160ms ease;
  }

  .floorplans-cell--unit .floorplans-sort-indicator {
	position: relative;
	top: 2px 
  }

  .floorplans-cell:not(.floorplans-cell--unit) .floorplans-sort-indicator[data-sort-direction='desc'] {
	position: relative;
	top: 1px 
  }




  .floorplans-sort-button--start .floorplans-sort-indicator {
    grid-column: 2;
  }

  .floorplans-sort-indicator::after {
    content: "";
    display: block;
    width: 0.5625rem;
    height: 0.9375rem;
    background-image: var(--floorplans-chevron-icon);
    background-position: center;
    background-repeat: no-repeat;
    background-size: contain;
    transform-origin: center;
    transition: transform 160ms ease;
  }

  .floorplans-sort-indicator[data-sort-direction="asc"] {
    opacity: 1;
  }

  .floorplans-sort-indicator[data-sort-direction="desc"] {
    opacity: 1;
  }

  .floorplans-sort-indicator[data-sort-direction="asc"]::after {
    transform: rotate(-90deg);
  }

  .floorplans-sort-indicator[data-sort-direction="desc"]::after {
    transform: rotate(90deg);
  }

  .floorplans-view-link {
    box-sizing: border-box;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    height: 2.75rem;
    padding: 4px 20px 2px;
    border: 1px solid currentColor;
    border-radius: 999px;
    text-decoration: none;
    white-space: nowrap;
    line-height: 1;
  }

  .floorplans-view-link::after {
    content: "";
    width: 0.5625rem;
    height: 0.9375rem;
    margin-left: 0.75rem;
    background-image: var(--floorplans-chevron-icon);
    background-position: center;
    background-repeat: no-repeat;
    background-size: contain;
    flex: 0 0 auto;
  }

  .floorplans-modal[hidden] {
    display: none;
  }

  .floorplans-modal {
    position: fixed;
    top: var(--headerHeight);
    left: 0;
    width: 100vw;
    height: calc(100vh - var(--headerHeight));
    height: calc(100dvh - var(--headerHeight));
    z-index: 9997;
    opacity: 0;
    pointer-events: none;
    transition: opacity 0.7s var(--cubicBez);
  }

  .floorplans-modal.is-closing {
    transition-duration: 0.4s;
  }

  .floorplans-modal.is-visible,
  .floorplans-modal.is-closing {
    pointer-events: auto;
  }

  .floorplans-modal.is-visible {
    opacity: 1;
  }

  .floorplans-modal-backdrop {
    position: absolute;
    inset: 0;
    border: 0;
    background: rgba(8, 32, 19, 0.28);
    cursor: pointer;
  }

  .floorplans-modal-card {
    --floorplans-detail-copy-height: 0px;
    position: relative;
    z-index: 1;
    width: 100%;
    height: 100%;
    background: #efeeec;
    overflow: hidden;
  }

  .floorplans-modal-scroll {
    position: relative;
    width: 100%;
    height: 100%;
    overflow-x: hidden;
    overflow-y: auto;
    overscroll-behavior: contain;
  }

  .floorplans-modal-close {
    appearance: none;
    position: absolute;
    top: 2rem;
    display: flex;
    align-items: center;
    justify-content: center;
    width: 2.75rem;
    height: 2.75rem;
    z-index: 2;
    border: 0;
    border-radius: 999px;
    background: #fff;
    color: #3a2a22;
    cursor: pointer;
    font-size: 0;
    line-height: 0;
    padding: 0;
    transition: background-color 160ms ease;
  }

  .floorplans-modal-close {
    right: 2rem;
  }

  .floorplans-modal-close::before,
  .floorplans-modal-close::after {
    content: "";
    position: absolute;
    width: 1.75rem;
    height: 1px;
    background: currentColor;
    top: 50%;
    left: 50%;
    transform-origin: center;
  }

  .floorplans-modal-close::before {
    transform: translate(-50%, -50%) rotate(45deg);
  }

  .floorplans-modal-close::after {
    transform: translate(-50%, -50%) rotate(-45deg);
  }

  .floorplans-detail-shell {
    position: relative;
    min-height: 0;
    overflow: hidden;
  }

  .floorplans-detail-inner {
    box-sizing: border-box;
    position: relative;
    height: calc(100vh - var(--headerHeight));
    height: calc(100dvh - var(--headerHeight));
    min-height: calc(100vh - var(--headerHeight));
    min-height: calc(100dvh - var(--headerHeight));
    padding: 0;
  }

  .floorplans-detail-copy {
    box-sizing: border-box;
    position: absolute;
    top: 0;
    left: 0;
    z-index: 2;
    width: min(21rem, 100%);
    max-width: 100%;
    padding: 2rem;
    color: #3a2a22;
    opacity: 1;
    transition: opacity 220ms ease;
  }

  .floorplans-detail-meta {
    font-family: "Figure Extended", "Hanken Grotesk", system-ui, sans-serif;
    font-weight: 400;
    font-size: 1.5rem;
    line-height: 2.25rem;
  }

  .floorplans-detail-meta p {
    margin: 0;
    white-space: nowrap;
  }

  .floorplans-detail-meta p:first-child {
    text-transform: uppercase;
  }

  .floorplans-detail-summary {
    display: flex;
    flex-wrap: nowrap;
    align-items: center;
    white-space: nowrap;
  }

  .floorplans-detail-summary > span {
    display: inline-flex;
    align-items: center;
    white-space: nowrap;
  }

  .floorplans-detail-summary > span + span {
    margin-left: 0.75rem;
  }

  .floorplans-detail-summary > span + span::before {
    content: "";
    display: block;
    width: 1px;
    height: 0.8em;
    margin-right: 0.75rem;
    background: currentColor;
  }

  .floorplans-detail-summary-text--short {
    display: none;
  }

  .floorplans-detail-actions {
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem;
    margin-top: 1.25rem;
  }

  .floorplans-detail-action {
    appearance: none;
    background: transparent;
    box-sizing: border-box;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 10rem;
    min-height: 2.75rem;
    padding: 0.25rem 1rem 0.125rem;
    border: 1px solid currentColor;
    border-radius: 999px;
    color: inherit;
    cursor: pointer;
    text-decoration: none;
    white-space: nowrap;
    font-family: "Hanken Grotesk", system-ui, sans-serif;
    font-size: 1rem;
    line-height: 1;
    transition: background-color 160ms ease;
  }

  .floorplans-detail-action:hover {
    background: rgba(58, 42, 34, 0.06);
  }

  .floorplans-detail-action:focus-visible {
    outline: 2px solid currentColor;
    outline-offset: 2px;
  }

  .floorplans-detail-action::after {
    content: "";
    display: block;
    flex: 0 0 auto;
    margin-left: 0.625rem;
    background-position: center;
    background-repeat: no-repeat;
    background-size: contain;
  }

