---
import FadeSlideshow from "../react/FadeSlideshow.jsx";
import { getWpImage } from "../../lib/wp/get-wp-image.js";

// 1. Get the raw props
const { images } = Astro.props;

// 2. Transform + LOCALIZE all WP image URLs
const formattedSlides = Array.isArray(images)
  ? images.map((item, index) => {
      const rawImg = item?.image;
      if (!rawImg) return null;

      const srcXL   = rawImg.sizes?.intch_xl  || rawImg.url;
      const srcLG   = rawImg.sizes?.intch_lg  || rawImg.url;
      const srcMED  = rawImg.sizes?.intch_med || rawImg.url;
      const srcSM   = rawImg.sizes?.intch_sm  || rawImg.url;

      const smartImg = {
        xl:    srcXL  ? getWpImage(srcXL)  : null,
        large: srcLG  ? getWpImage(srcLG)  : null,
        med:   srcMED ? getWpImage(srcMED) : null,
        small: srcSM  ? getWpImage(srcSM)  : null,
      };

      return {
        id: rawImg.id || rawImg.ID || index,
        smartImg,
        alt: rawImg.alt || item.caption || "Slideshow image",
        caption: item.caption || null,
      };
    })
  : [];

// 3. Filter out broken slides
const validSlides = formattedSlides.filter(Boolean);
---

<section class="full-width-slideshow-wrap relative w-full h-[calc(var(--jsVhUnits100)*.8-var(--headerHeight))]">
  {validSlides.length > 0 ? (
    <FadeSlideshow 
      client:visible 
      slides={validSlides} 
      duration={4000}
	  client:idle
    />
  ) : (
    <div class="flex items-center justify-center w-full h-full flex-col left-[var(--containerPadding)] text-[1.08rem] ">
      <p>No images found</p>
    </div>
  )}
</section>