---
import FadeSlideshow from "../react/FadeSlideshow.jsx";

// 1. Get the raw props
const { images, layout_settings, _sectionPlaceBelow, _sectionBgColorClass } = Astro.props;

function normalizeSectionTitle(title: string | null | undefined): string | null {
  if (typeof title !== "string") return null;

  const normalized = title
    .replace(/<br\s*\/?>\s*(?:\r?\n\s*)*/gi, "<br />")
    .replace(/\r?\n/g, "<br />")
    .trim();

  return normalized || null;
}

// 2. Module-level section content (fallback when slides don't override)
const moduleSectionContent = {
  section_title: normalizeSectionTitle(layout_settings?.section_title),
  section_h3: layout_settings?.section_h2 || null,
  section_text: layout_settings?.section_text || null,
};

// 3. Transform + LOCALIZE all WP image URLs
const formattedSlides = Array.isArray(images)
  ? images.map((item, index) => {
      const rawImg = item?.image;
      if (!rawImg) return null;

      const srcXL   = rawImg.sizes?.intch_xl  || rawImg.url;
      const srcLG   = rawImg.sizes?.intch_lg  || rawImg.url;
      const srcMED  = rawImg.sizes?.intch_med || rawImg.url;
      const srcSM   = rawImg.sizes?.intch_sm  || rawImg.url;

      const smartImg = {
        xl:    srcXL  ? srcXL  : null,
        large: srcLG  ? srcLG : null,
        med:   srcMED ? srcMED : null,
        small: srcSM  ? srcSM  : null,
      };

      return {
        id: rawImg.id || rawImg.ID || index,
        smartImg,
        alt: rawImg.alt || item.caption || "Slideshow image",
        caption: item.caption || null,
        // Per-slide section text (overrides module-level when present)
        section_title: normalizeSectionTitle(item.section_title),
        section_h3: item.section_h3 || null,
        section_text: item.section_text || null,
      };
    })
  : [];

// 4. Filter out broken slides
const validSlides = formattedSlides.filter((s): s is NonNullable<typeof s> => Boolean(s));

// 5. Check if any slide has per-slide section overrides
const hasSlideOverrides = validSlides.some(s => s.section_title || s.section_h3 || s.section_text);

// 6. Find the tallest section content by text length (server-side heuristic)
function stripHtml(str: string | null): string {
  return (str || '').replace(/<[^>]+>/g, '');
}
let tallestSectionIndex = 0;
if (hasSlideOverrides) {
  let maxLen = 0;
  validSlides.forEach((s, i) => {
    const title = stripHtml(s.section_title || moduleSectionContent.section_title);
    const h3 = stripHtml(s.section_h3 || moduleSectionContent.section_h3);
    const text = stripHtml(s.section_text || moduleSectionContent.section_text);
    const len = title.length + h3.length + text.length;
    if (len > maxLen) { maxLen = len; tallestSectionIndex = i; }
  });
}
---

{validSlides.length > 0 ? (
  <FadeSlideshow 
    client:visible 
    slides={validSlides} 
    duration={4000}
    {...(hasSlideOverrides ? {
      sectionContent: moduleSectionContent,
      placeBelow: !!_sectionPlaceBelow,
      sectionBgColorClass: _sectionBgColorClass || null,
      tallestSectionIndex,
    } : {})}
  />
) : (
  <div class="flex items-center justify-center w-full h-full flex-col left-[var(--containerPadding)] text-[1.08rem] ">
    <p>No images found</p>
  </div>
)}
