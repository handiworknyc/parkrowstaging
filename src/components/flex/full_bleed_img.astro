---
import CFVideo from "../ui/CFVideo.astro";
import { isHeroFullBleedRowIndex } from "../../lib/wp/hero";

const vars = { ...Astro.props };
const v = vars.video;


const { prevLayout, nextLayout, ...props } = Astro.props;


// ✅ 1. Check Row Index to determine Critical status
const currentIndex = vars.rowIndex;
const firstIsSplash = vars.firstIsSplash === true;
const isCritical = isHeroFullBleedRowIndex({
  rowIndex: currentIndex,
  firstIsSplash,
  width: vars.width,
});
const hasDesktopStream =
  typeof v?.[0]?.cf_stream_video === "string" &&
  v[0].cf_stream_video.trim().length > 0;
const hasCriticalMobileStream =
  isCritical &&
  typeof v?.[0]?.cf_stream_mob === "string" &&
  v[0].cf_stream_mob.trim().length > 0;

// ✅ 2. Detect panorama mode
const isPanorama = vars.panorama === true;

const locoSpeedAttr = isCritical || prevLayout?.name === "splash_video"
  ? { "data-scroll data-scroll-speed": "-.4" }
  : {};

// --- 1. Data Processing --- //
const rawContent = vars.content || [];
const hasContent = rawContent.length > 0;

const processedContent = rawContent.map((item) => ({
  title: item.title || "",
  text: item.text || "",
  twoColList: item.two_col_list || false,
  listItems: item.list
    ? item.list.split(/\r?\n/).filter((li) => li.trim())
    : [],
}));

// --- 2. Generate Content HTML (Columns) --- //
const contentColumnsHTML = processedContent
  .map((item, index) => {
    let cssClass = "min-[1240px]:col-4 min-[990px]:col-5 max-[990px]:col-12 column-content";

    if (processedContent.length === 1) {
      cssClass = "min-[1024px]:col-5 column-content";
    }  else if (index === 1) {
		const mobileMt = !item.title ? "max-[990px]:mt-6" : "max-[990px]:mt-20";
		cssClass = `column-content min-[1050px]:col-4 min-[990px]:col-5 min-[1050px]:push-2 min-[990px]:push-1 ${mobileMt} max-[990px]:col-12`;
	}

    const ulClass = `section-text ${
      item.twoColList ? "two-col-list" : ""
    }`.trim();

    return `
      <div class="${cssClass}">
        ${item.title ? `<h3 class='figure-h3'>${item.title}</h3>` : ""}
        ${item.text ? `<div class='section-text'>${item.text}</div>` : ""}
        ${
          item.listItems.length > 0
            ? `
          <ul class='${ulClass}'>
            ${item.listItems.map((li) => `<li>${li}</li>`).join("")}
          </ul>
        `
            : ""
        }
      </div>
    `;
  })
  .join("");

// --- 3. CSS Class Generation --- //
const caption = vars.caption || "";
const captionPos = vars.caption_pos || "left";
const alignMap = {
  left: "text-left",
  center: "text-center",
  right: "text-right",
};
const captionAlignClass = alignMap[captionPos] || "text-left";

let colClass = null;

// ------------------------------------
// Column widths
// ------------------------------------
if (vars.width === "11 columns") {
  colClass = "min-[1400px]:col-11 col-12";
}

if (vars.width === "10 columns") {
  colClass = "min-[1400px]:col-10 col-12";
}

if (vars.width === "9 columns") {
  colClass = "min-[1400px]:col-9 min-[1240px]:col-10 col-12";

  if (vars.align === "left") {
    colClass += " max-[1400px]:min-[660px]:bleed-left max-[660px]:bleed-x";
  }
}

// ------------------------------------
// Static push map
// ------------------------------------
const PUSH_MAP = {
  "1": "min-[1400px]:push-1",
  "2": "min-[1400px]:push-2 max-[1400px]:min-[660px]:bleed-right max-[660px]:bleed-x max-[1400px]:align-right",
  "3": "min-[700px]:push-3",
  "4": "min-[700px]:push-4",
  "5": "min-[700px]:push-5",
};

let pushClass = null;
if (vars.width === "9 columns" && vars.push) {
  pushClass = PUSH_MAP[vars.push] || null;
}

// ------------------------------------
// Bleed flag (explicit bleed option)
// ------------------------------------
let bleedClass = null;
if (vars.width !== "full" && vars.bleed === true) {
  if (vars.align === "left") bleedClass = "bleed-left";
  else if (vars.align === "right") bleedClass = "bleed-right";
  else bleedClass = "bleed-x";
}

// ------------------------------------
// Corner-based responsive bleed (≤1240px)
// ------------------------------------
let cornerBleedClass = null;

if (vars.round_corner && vars.corner_pos && !vars.bleed) {
  if (vars.corner_pos === "left") {
    cornerBleedClass = "max-[1240px]:min-[660px]:bleed-right max-[660px]:bleed-x";
  } else if (vars.corner_pos === "right") {
    cornerBleedClass = "max-[1240px]:min-[660px]:bleed-left max-[660px]:bleed-x";
  }
}

// ------------------------------------
// ✅ Detect bleed-left at ≤1240px
// ------------------------------------
const needsLeftPadAt1240 =
  bleedClass === "bleed-left" ||
  cornerBleedClass === "max-[1240px]:min-[660px]:bleed-left max-[660px]:bleed-x";

const leftPadClass = needsLeftPadAt1240
  ? "max-[1240px]:pl-[var(--containerPadding)]"
  : null;

/* Caption wrapper */
const captionWrapperClass = [
  "full-bleed-caption",
  "max-[1300px]:mt-4 max-[1300px]:mb-4 min-[1300px]:mt-5",
  captionAlignClass,
  vars.bleed === true ? "hw-contain" : null,
  leftPadClass,
]
  .filter(Boolean)
  .join(" ");

const layoutClasses = [
'full-bleed-column',
  colClass,
  pushClass,
  bleedClass,
  cornerBleedClass,
  vars.width !== "full" ? `align-${vars.align}` : null,
];

const videoClasses = [
  "hw-bg-vid",
  "hw-player-parent",
  "img-load-par",
  "pr",
  "full-bleed-img-inner",
  vars.round_corner && "round-corner",
  `corner-pos-${vars.corner_pos}`,
  !hasDesktopStream && !hasCriticalMobileStream && "no-video",
];
---

{vars.width !== "full" ? (
  /* --- LAYOUT: BOXED --- */
  <div class="hw-contain">
    <div class="row">
      <div class:list={layoutClasses}>
        <div class:list={videoClasses}>
          {v && (
            <CFVideo
              video={v}
              critical={isCritical}
              panorama={isPanorama}
              enableResponsivePoster={isCritical}
            />
          )}
        </div>

        {caption && <div class={captionWrapperClass}>{caption}</div>}

        {hasContent && (
          <div
            class={[
              "full-bleed-content-wrap",
              "mt-16",
              leftPadClass,
            ]
              .filter(Boolean)
              .join(" ")}
          >
            <div class="row" set:html={contentColumnsHTML} />
          </div>
        )}
      </div>
    </div>
  </div>
) : (
  /* --- LAYOUT: FULL WIDTH --- */
  <>

  <div class="full-bleed-column">
    <div class:list={videoClasses} {...locoSpeedAttr}>
      {v && (
        <CFVideo
          video={v}
          critical={isCritical}
          panorama={isPanorama}
          enableResponsivePoster={isCritical}
        />
      )}
    </div>

    {(caption || hasContent) && (
      <div class={`hw-contain ${captionWrapperClass}`}>
        <div class="row">
          <div class="min-[1240px]:push-1 col-11">
            {caption && <div>{caption}</div>}

            {hasContent && (
              <div
                class={[
                  "full-bleed-content-wrap",
                  "mt-16",
                  leftPadClass,
                ]
                  .filter(Boolean)
                  .join(" ")}
              >
                <div class="row" set:html={contentColumnsHTML} />
              </div>
            )}
          </div>
        </div>
      </div>
    )}
	</div>
  </>
)}
