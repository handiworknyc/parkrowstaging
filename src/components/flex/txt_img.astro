---
import CFVideo from "../ui/CFVideo.astro";

const vars = { ...Astro.props };

// ---------------------------------------------
// 1. VIDEO
// ---------------------------------------------
const video = vars.video?.[0] || null;

// ---------------------------------------------
// 2. TEXT CONTENT
// ---------------------------------------------
const title = vars.title || "";
const text = vars.text || "";
const listItems = (vars.list || "")
  .split(/\r?\n/)
  .filter((li) => li.trim());

// ---------------------------------------------
// 3. CAPTION
// ---------------------------------------------
const caption = vars.caption || "";
const captionPos = vars.caption_pos || "left";

const alignMap = {
  left: "text-left",
  center: "text-center",
  right: "text-right",
};
const captionAlignClass = alignMap[captionPos] || "text-left";

const captionWrapperClass = [
  "full-bleed-caption",
  "mt-5",
  captionAlignClass,
  vars.bleed === true ? "hw-contain" : null,
].filter(Boolean).join(" ");

// ---------------------------------------------
// 4. ALIGNMENT (LEFT / RIGHT)
// ---------------------------------------------
const isRight = vars.align === "right";
const rowAlignClass = isRight ? "align-right" : "align-left";

// ---------------------------------------------
// 5. BLEED CLASS (Match side of alignment)
// ---------------------------------------------
const bleedClass = isRight ? "bleed-right" : "bleed-left";
---

<div class="hw-contain">
  <div
    class:list={[
      "row",
      "flex",
      "curvy-video-row",
      rowAlignClass
    ]}
  >

    <!-- ---------------- VIDEO (LEFT / RIGHT) ---------------- -->
    <div class:list={[
      "min-[700px]:col-8",
      bleedClass,
    ]}>
      <div class="hw-bg-vid hw-player-parent img-load-par pr full-bleed-img-inner">
        {video && <CFVideo video={[video]} />}
      </div>

      {caption && <div class={captionWrapperClass}>{caption}</div>}
    </div>

    <!-- ---------------- CONTENT (TEXT) ---------------- -->
    <div
      class:list={[
        `self-end`,
        "min-[700px]:col-3",
        "min-[700px]:push-1",
      ]}
    >

      {title && <h3 class="figure-h3 mb-5" set:html={title} />}

      {text && (
        <div class="section-text mb-6" set:html={text} />
      )}

      {listItems.length > 0 && (
        <ul class="section-text two-col-list">
          {listItems.map((li) => <li>{li}</li>)}
        </ul>
      )}

    </div>

  </div>
</div>
