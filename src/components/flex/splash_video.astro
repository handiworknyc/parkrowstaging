			<path fill='white' d="M230.902 253.634C208.943 282.449 178.106 299.787 138.642 299.787C99.1775 299.787 68.0681 282.449 46.1086 253.634C24.149 224.819 13.1801 191.064 13.1801 151.87C13.1801 112.675 24.1599 79.1811 46.1086 50.3663C68.0573 21.812 98.9052 4.46229 138.631 4.46229C178.356 4.46229 208.943 21.8011 230.891 50.3554C252.851 79.1703 263.82 112.925 263.82 151.859C263.82 190.793 252.84 224.808 230.891 253.623M236.316 44.6554C209.106 14.7983 176.701 0 138.62 0C100.539 0 67.8939 14.7983 40.684 44.6554C13.4851 74.5017 0 110.07 0 151.87C0 193.67 13.4851 229.487 40.684 259.345C67.8939 289.202 100.528 304 138.62 304C176.711 304 209.106 289.202 236.316 259.345C263.526 229.487 277 193.659 277 151.87C277 110.081 263.515 74.5017 236.316 44.6554Z" fill="black"/>
			</g>
			<defs>
			<clipPath id="clip0_25_1456">
			<rect width="277" height="304" fill="white"/>
			</clipPath>
			</defs>
			</svg>

			<div class="splash-down-arrow figure tac caps c-white">
				Discover Park Row
				<svg xmlns="http://www.w3.org/2000/svg" width="15" height="48" viewBox="0 0 15 48" fill="none">
				<path d="M8.36401 1C8.36401 0.447715 7.9163 -2.41411e-08 7.36401 0C6.81173 2.41411e-08 6.36401 0.447715 6.36401 1L8.36401 1ZM6.65691 47.7071C7.04743 48.0976 7.6806 48.0976 8.07112 47.7071L14.4351 41.3431C14.8256 40.9526 14.8256 40.3195 14.4351 39.9289C14.0446 39.5384 13.4114 39.5384 13.0209 39.9289L7.36402 45.5858L1.70716 39.9289C1.31664 39.5384 0.683472 39.5384 0.292948 39.9289C-0.0975768 40.3195 -0.0975768 40.9526 0.292948 41.3431L6.65691 47.7071ZM6.36401 1L6.36402 47L8.36402 47L8.36401 1L6.36401 1Z" fill="white"/>
				</svg>
			</div>
		</div>

    </div>
  </>
)}

<script is:client>
  let splashDismissed = false;
  let splashLoaded = false;

  let cleanup = [];
  let splashObserver = null;
  let revealTimer = null;
  let idleDismissTimer = null;

  const REVEAL_DELAY = 850;
  const IDLE_DISMISS_DELAY = 6500;

  window.hwSplashActive = false;

  function initSplashDismiss() {
    if (!document.body.classList.contains("first-load")) return;
    if (!document.body.classList.contains("home")) return;

    window.hwSplashActive = true;

    const splash = document.querySelector("[data-splash-video]");
    const splashpar = document.querySelector(".splash_video-module");

    if (!splash || !splashpar) return;

    observeSplashLazyLoaded(splash, splashpar);
  }

  function observeSplashLazyLoaded(splash, splashpar) {
    if (splashLoaded) return;

    const markLoaded = () => {
      if (splashLoaded) return;

      splashLoaded = true;
      document.documentElement.classList.add("splash-loaded");

      clearTimeout(revealTimer);
      revealTimer = setTimeout(revealHomeUI, REVEAL_DELAY);

      attachDismissListeners(splash, splashpar);
      startIdleDismissTimer(splashpar);

      splashObserver?.disconnect();
      splashObserver = null;
    };

    if (document.querySelector(".splash_video-module .child-lazy-loaded")) {
      markLoaded();
      return;
    }

    splashObserver = new MutationObserver(() => {
      if (document.querySelector(".splash_video-module .child-lazy-loaded")) {
        markLoaded();
      }
    });

    splashObserver.observe(document.body, {
      subtree: true,
      childList: true,
      attributes: true,
      attributeFilter: ["class"],
    });
  }

  function startIdleDismissTimer(splashpar) {
    clearTimeout(idleDismissTimer);

    idleDismissTimer = setTimeout(() => {
      if (splashDismissed) return;

      splashDismissed = true;
      splashpar.classList.add("splash-dismissed");

      window.dispatchEvent(
        new CustomEvent("splash:dismiss", {
          detail: { source: "idle-timeout" },
        })
      );

      cleanup.forEach((fn) => fn());
      cleanup.length = 0;

      idleDismissTimer = null;
    }, IDLE_DISMISS_DELAY);
  }

  function attachDismissListeners(splash, splashpar) {
    if (splashDismissed) return;

    let dismissTimer = null;

    const dismiss = () => {
      if (splashDismissed) return;

      splashDismissed = true;

      clearTimeout(dismissTimer);
      clearTimeout(idleDismissTimer);
      idleDismissTimer = null;

      dismissTimer = setTimeout(() => {
        splashpar.classList.add("splash-dismissed");

        window.dispatchEvent(
          new CustomEvent("splash:dismiss", {
            detail: { source: "scroll-intent" },
          })
        );

        cleanup.forEach((fn) => fn());
        cleanup.length = 0;

        dismissTimer = null;
      }, 350);
    };

    const onWheel = () => dismiss();
    const onTouch = () => dismiss();
    const onKey = (e) => {
      if (
        e.key === "ArrowDown" ||
        e.key === "ArrowUp" ||
        e.key === "PageDown" ||
        e.key === "PageUp" ||
        e.key === " "
      ) {
        dismiss();
      }
    };

    window.addEventListener("wheel", onWheel, { passive: true });
    window.addEventListener("touchmove", onTouch, { passive: true });
    window.addEventListener("keydown", onKey);

    cleanup.push(
      () => window.removeEventListener("wheel", onWheel),
      () => window.removeEventListener("touchmove", onTouch),
      () => window.removeEventListener("keydown", onKey)
    );
  }

  function revealHomeUI() {
    if (!document.body.classList.contains("home")) return;

    const header = document.getElementById("header");
    const secondModule = document.querySelector(
      ".full_bleed_img-module.rowindex-2"
    );

    if (header) header.style.visibility = "visible";
    if (secondModule) secondModule.style.visibility = "visible";
  }

  initSplashDismiss();
  document.addEventListener("astro:page-load", initSplashDismiss);

  document.addEventListener("astro:before-preparation", () => {
    cleanup.forEach((fn) => fn());
    cleanup.length = 0;

    splashObserver?.disconnect();
    splashObserver = null;

    clearTimeout(revealTimer);
    clearTimeout(idleDismissTimer);
    revealTimer = null;
    idleDismissTimer = null;

    splashLoaded = false;
    splashDismissed = false;
  });
</script>
