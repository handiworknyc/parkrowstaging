<script>
  import initStickyHeader from "/src/scripts/sticky-header.ts";
  initStickyHeader();

  var theheader = document.getElementById("header"),
    ogheaderheight = theheader.offsetHeight;
</script>

<script is:client>
  function initNav() {
    const toggle = document.querySelector(".nav-toggle");
    const modal = document.querySelector("#main-nav[data-nav-modal]");
    if (!toggle || !modal) return;

    const ul = modal.querySelector("ul");
    const body = document.body;

    // Avoid double-binding after repeated transitions
    if (toggle._navBound) return;
    toggle._navBound = true;

    // ---------------------------
    // Helpers
    // ---------------------------
    function clearStates() {
      body.classList.remove(
        "modal-opening",
        "modal-opened",
        "modal-closing",
        "modal-closed"
      );
    }

    function openMenu() {
      clearStates();
      body.classList.add("modal-opening");

      toggle.classList.add("active");
      modal.classList.add("open");
      body.classList.add("modal-open");

      if (ul) ul.classList.add("sal-animate");
    }

    function closeMenu() {
      clearStates();
      body.classList.add("modal-closing");

      toggle.classList.remove("active");
      modal.classList.remove("open");
      body.classList.remove("modal-open");

      if (ul) ul.classList.remove("sal-animate");
    }

    toggle.addEventListener("click", () => {
      modal.classList.contains("open") ? closeMenu() : openMenu();
    });

    modal.addEventListener("click", (e) => {
      if (e.target.closest("a")) closeMenu();
    });

    modal.addEventListener("transitionend", () => {
      clearStates();
      if (modal.classList.contains("open")) {
        body.classList.add("modal-opened");
      } else {
        body.classList.add("modal-closed");
      }
    });
  }

  // Run once on initial load
  document.addEventListener("DOMContentLoaded", initNav);

  // Run again after every view transition
  document.addEventListener("astro:page-load", initNav);
</script>
