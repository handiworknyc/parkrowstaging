---
import { getHeaderMenu } from "../lib/wp/getHeaderMenu";

// -----------------------------------------------------------------------------
// SETTINGS
// -----------------------------------------------------------------------------
const WP_BASE_URL = (import.meta.env.WP_BASE_URL || "").trim();

// -----------------------------------------------------------------------------
// ⚡ GLOBAL NAV CACHE (ALWAYS IN-MEMORY, NEVER REBUILT)
// -----------------------------------------------------------------------------
let _cachedHeaderMenu = null;

// -----------------------------------------------------------------------------
// Normalize host (for same-origin checks)
// -----------------------------------------------------------------------------
function normalizeHost(host) {
  return String(host || "")
    .replace(/^www\./i, "")
    .toLowerCase();
}

// -----------------------------------------------------------------------------
// Rewrite WP absolute URLs → Local relative
// -----------------------------------------------------------------------------
function rewriteMenuUrls(html, wpBase) {
  if (!html) return html;

  let base;
  try {
    base = new URL(wpBase);
  } catch {
    return html;
  }

  return html.replace(/href=(['"])([^'"]+)\1/gi, (full, quote, href) => {
    try {
      if (/^(mailto:|tel:|sms:|javascript:|#)/i.test(href)) return full;

      if (/^https?:\/\//i.test(href)) {
        const u = new URL(href);
        // Only rewrite internal links
        if (normalizeHost(u.hostname) === normalizeHost(base.hostname)) {
          return `href=${quote}${u.pathname}${u.search}${u.hash}${quote}`;
        }
      }

      return full;
    } catch {
      return full;
    }
  });
}

// -----------------------------------------------------------------------------
// Decode JSON-stringified HTML IF needed
// -----------------------------------------------------------------------------
function decodePossiblyJsonString(str) {
  if (!str) return "";
  try {
    const parsed = JSON.parse(str);
    if (typeof parsed === "string") return parsed;
  } catch {}
  return str;
}

// -----------------------------------------------------------------------------
// 👍 Fetch menu ONCE per server lifetime
//    (eliminates ALL navigation delays)
// -----------------------------------------------------------------------------
if (!_cachedHeaderMenu) {
  let raw = "";
  try {
    raw = await getHeaderMenu();
  } catch (err) {
    console.error("[SiteNav] Failed getHeaderMenu:", err?.message);
  }

  raw = decodePossiblyJsonString(raw);
  _cachedHeaderMenu = rewriteMenuUrls(raw, WP_BASE_URL);
}

// Expose final menu
const headerMenu = _cachedHeaderMenu;
---


