---
export const prerender = false;

import InquirePage from "../../components/templates/InquirePage.astro";
import NotFound from "../../components/templates/NotFound.astro";
import { getFlexiblePageByUri } from "../../lib/api";
import { fetchPreviewFlexiblePageByUriOrId } from "../../lib/wp/preview";
import { resolvePreviewAccess } from "../../lib/wp/previewAccess";

const uri = "/inquire/";
const previewAccess = resolvePreviewAccess(Astro.url, Astro.cookies);
const publishedPage = getFlexiblePageByUri(uri);
const page = previewAccess.shouldUsePreview
  ? await fetchPreviewFlexiblePageByUriOrId(uri, publishedPage?.id)
  : publishedPage;

if (!page) {
  Astro.response.status = 404;
  Astro.response.statusText = "Not found";
}
---

{page ? (
  <InquirePage page={page} isPreview={previewAccess.shouldUsePreview} />
) : (
  <NotFound />
)}
