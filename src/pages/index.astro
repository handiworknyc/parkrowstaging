---
// src/pages/index.astro
export const prerender = false;
import BaseLayout from "../layouts/MainLayout.astro";
import LayoutRenderer from "../lib/wp/LayoutRenderer.astro";
import { getFlexiblePageByUri, getKnownFlexiblePageByUri } from "../lib/api";
import { fetchPreviewFlexiblePageByUriOrId } from "../lib/wp/preview";
import PageContent from "../components/wp/PageContent.astro";
import NotFound from "../components/templates/NotFound.astro";

// ✅ IMPORT HELPER FUNCTIONS
import { normalizeLayouts } from "../lib/wp/normalize";
import { getLcpImage, getLcpVideo, hasSplashVideo } from "../lib/wp/lcp";
import { getPreloads } from "../lib/wp/preloads"; // <--- NEW IMPORT
import {
  PREVIEW_CACHE_CONTROL,
  resolvePreviewAccess,
} from "../lib/wp/previewAccess";
import { getFlexiblePageContentHtml, getFlexiblePageMeta } from "../lib/wp/page";

const previewAccess = resolvePreviewAccess(Astro.url, Astro.cookies);
const publishedPage = getFlexiblePageByUri("/");
const knownPage = getKnownFlexiblePageByUri("/");
const page = previewAccess.shouldUsePreview
  ? await fetchPreviewFlexiblePageByUriOrId("/", knownPage?.id)
  : publishedPage;

if (!page) {
  Astro.response.status = 404;
  Astro.response.statusText = "Not found";
}

const pageMeta = getFlexiblePageMeta(page, "Park Row");
const layouts = page?.layouts ?? [];
const contentHtml = getFlexiblePageContentHtml(page);

let lcpData = null;
let lcpVideo = null;
let preloads = []; // <--- NEW
let hasHomeSplash = false;

if (layouts.length > 0) {
  const rows = normalizeLayouts(layouts);
  lcpData = getLcpImage(rows);
  lcpVideo = getLcpVideo(rows);
  hasHomeSplash = hasSplashVideo(rows);
  
  // ✅ GENERATE PRELOADS
  preloads = getPreloads(rows);
}

---

<BaseLayout 
  title={pageMeta.title}
  description={pageMeta.description}
  seo={pageMeta.seo}
  cacheControl={previewAccess.shouldUsePreview ? PREVIEW_CACHE_CONTROL : undefined}
  noIndex={previewAccess.shouldUsePreview}
  isPreview={previewAccess.shouldUsePreview}
  lcp={lcpData} 
  lcpVideo={lcpVideo} 
  preloads={preloads}
  hasSplashVideo={hasHomeSplash}
>
  {page
    ? layouts.length
      ? <LayoutRenderer layouts={layouts} skipSplash={previewAccess.shouldUsePreview} />
      : <PageContent html={contentHtml} />
    : <NotFound />}
</BaseLayout>
