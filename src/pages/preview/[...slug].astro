---
export const prerender = false;

import BaseLayout from "../../layouts/MainLayout.astro";
import LayoutRenderer from "../../lib/wp/LayoutRenderer.astro";
import { fetchPreviewFlexiblePageByUri } from "../../lib/wp/preview";
import PageContent from "../../components/wp/PageContent.astro";
import {
  PREVIEW_CACHE_CONTROL,
  resolvePreviewAccess,
} from "../../lib/wp/previewAccess";
import { getFlexiblePageContentHtml, getFlexiblePageMeta } from "../../lib/wp/page";
const previewAccess = resolvePreviewAccess(Astro.url, Astro.cookies, "/");
const canRenderPreview =
  previewAccess.shouldUsePreview || previewAccess.hasPreviewSession;

const slugValue = Astro.params.slug;
const slug = Array.isArray(slugValue)
  ? slugValue.join("/")
  : slugValue || "";
const uri = slug ? `/${slug}/` : "/";

let page = null;

if (canRenderPreview) {
  page = await fetchPreviewFlexiblePageByUri(uri);
} else {
  Astro.response.status = 404;
  Astro.response.statusText = "Not found";
}

if (canRenderPreview && !page) {
  Astro.response.status = 404;
  Astro.response.statusText = "Not found";
}

const contentHtml = getFlexiblePageContentHtml(page);
const pageMeta = getFlexiblePageMeta(page, "Preview");
---

{canRenderPreview && page ? (
  <BaseLayout
    title={pageMeta.title}
    description={pageMeta.description}
    seo={pageMeta.seo}
    cacheControl={PREVIEW_CACHE_CONTROL}
    noIndex={true}
    isPreview={true}
  >
    {page.layouts?.length ? (
      <LayoutRenderer layouts={page.layouts} />
    ) : (
      <PageContent html={contentHtml} />
    )}
  </BaseLayout>
) : (
  "Page Not found"
)}
