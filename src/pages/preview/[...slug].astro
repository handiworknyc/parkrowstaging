---
export const prerender = false;

import BaseLayout from "../../layouts/MainLayout.astro";
import LayoutRenderer from "../../lib/wp/LayoutRenderer.astro";
import { fetchPreviewFlexiblePageByUri } from "../../lib/wp/preview";
import PageContent from "../../components/wp/PageContent.astro";
import { getFlexiblePageContentHtml, getFlexiblePageMeta } from "../../lib/wp/page";

const PREVIEW_SECRET = (
  process.env.PREVIEW_SECRET ||
  ""
).trim();
const PREVIEW_COOKIE = "hw_preview";

const previewToken = (Astro.url.searchParams.get("preview") || "").trim();
const previewCookie = (Astro.cookies.get(PREVIEW_COOKIE)?.value || "").trim();

if (
  PREVIEW_SECRET &&
  previewToken === PREVIEW_SECRET &&
  previewCookie !== PREVIEW_SECRET
) {
  Astro.cookies.set(PREVIEW_COOKIE, PREVIEW_SECRET, {
    httpOnly: true,
    sameSite: "lax",
    secure: Astro.url.protocol === "https:",
    path: "/preview",
    maxAge: 60 * 60 * 12,
  });
}

const hasPreviewAccess =
  !PREVIEW_SECRET ||
  previewToken === PREVIEW_SECRET ||
  previewCookie === PREVIEW_SECRET;

const slugValue = Astro.params.slug;
const slug = Array.isArray(slugValue)
  ? slugValue.join("/")
  : slugValue || "";
const uri = slug ? `/${slug}/` : "/";

let page = null;

if (hasPreviewAccess) {
  page = await fetchPreviewFlexiblePageByUri(uri);
} else {
  Astro.response.status = 404;
  Astro.response.statusText = "Not found";
}

if (hasPreviewAccess && !page) {
  Astro.response.status = 404;
  Astro.response.statusText = "Not found";
}

const contentHtml = getFlexiblePageContentHtml(page);
const pageMeta = getFlexiblePageMeta(page, "Preview");
---

{hasPreviewAccess && page ? (
  <BaseLayout
    title={pageMeta.title}
    description={pageMeta.description}
    seo={pageMeta.seo}
    cacheControl="private, no-store, max-age=0, must-revalidate"
    noIndex={true}
  >
    {page.layouts?.length ? (
      <LayoutRenderer layouts={page.layouts} />
    ) : (
      <PageContent html={contentHtml} />
    )}
  </BaseLayout>
) : (
  "Page Not found"
)}
