---
export const prerender = false;

import InquirePage from "../../../components/templates/InquirePage.astro";
import NotFound from "../../../components/templates/NotFound.astro";
import { getFlexiblePageByUri, getKnownFlexiblePageByUri } from "../../../lib/api";
import { areTranslatedRoutesEnabled } from "../../../lib/wp/getHideLanguage";
import { fetchPreviewFlexiblePageByUriOrId } from "../../../lib/wp/preview";
import { resolvePreviewAccess } from "../../../lib/wp/previewAccess";

const translationsEnabled = areTranslatedRoutesEnabled();
const uri = "/inquire/";
const previewAccess = resolvePreviewAccess(Astro.url, Astro.cookies);
const publishedPage = translationsEnabled ? getFlexiblePageByUri(uri) : null;
const knownPage = translationsEnabled ? getKnownFlexiblePageByUri(uri) : null;
const page = translationsEnabled
  ? previewAccess.shouldUsePreview
    ? await fetchPreviewFlexiblePageByUriOrId(uri, knownPage?.id)
    : publishedPage
  : null;

if (!translationsEnabled || !page) {
  Astro.response.status = 404;
  Astro.response.statusText = "Not found";
}
---

{translationsEnabled && page ? (
  <InquirePage
    lang="zh"
    page={page}
    isPreview={previewAccess.shouldUsePreview}
  />
) : (
  <NotFound />
)}
