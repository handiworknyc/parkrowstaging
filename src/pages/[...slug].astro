---
// src/pages/[...slug].astro
import BaseLayout from "../layouts/MainLayout.astro";
import LayoutRenderer from "../lib/wp/LayoutRenderer.astro";
import { getAllFlexiblePagePaths, getFlexiblePageByUri } from "../lib/api";
export const prerender = true;

// ✅ IMPORT LCP HELPERS
import { normalizeLayouts } from "../lib/wp/normalize";
import { getLcpImage, toLocalCache } from "../lib/wp/lcp"; 

export async function getStaticPaths() {
  return getAllFlexiblePagePaths();
}

const { slug = [] } = Astro.params;
const uri = "/" + (Array.isArray(slug) ? slug.join("/") : slug) + "/";
const page = await getFlexiblePageByUri(uri);

if (!page) {
  Astro.response.status = 404;
  Astro.response.statusText = "Not found";
}

/* ---------------------------------------------------------
   LCP & PRELOAD CALCULATION
--------------------------------------------------------- */
let lcpData = null;
let carouselPreloads = [];
let slideshowPreloads = [];

if (page && page.layouts) {
  const rows = normalizeLayouts(page.layouts);

  lcpData = getLcpImage(rows);

  /* ───────────────────────────────────────────
     EXISTING CAROUSEL (UNCHANGED)
  ─────────────────────────────────────────── */
  carouselPreloads = rows
    .filter((r) => r.name === "carousel")
    .flatMap((r) => r.data.images || [])
    .map((item) => {
      const imgData = item.image || item || {}; 
      const targetUrl = (imgData.sizes && imgData.sizes.intch_med) 
        ? imgData.sizes.intch_med 
        : (imgData.url || imgData.src);

      return toLocalCache(targetUrl);
    })
    .filter(Boolean);

  /* ───────────────────────────────────────────
     NEW: FULL WIDTH SLIDESHOW (SRCSET AWARE)
  ─────────────────────────────────────────── */
  slideshowPreloads = rows
    .filter((r) => r.name === "full_width_slideshow")
    .flatMap((r) => r.data.images || [])
    .map((item) => {
      const img = item.image || item || {};
      if (!img.url) return null;

      const sizes = img.sizes || {};

      const srcXL  = sizes.intch_xl  || img.url;
      const srcLG  = sizes.intch_lg  || img.url;
      const srcMED = sizes.intch_med || img.url;
      const srcSM  = sizes.intch_sm  || img.url;

      const xl  = srcXL  ? toLocalCache(srcXL)  : null;
      const lg  = srcLG  ? toLocalCache(srcLG)  : null;
      const med = srcMED ? toLocalCache(srcMED) : null;
      const sm  = srcSM  ? toLocalCache(srcSM)  : null;

      const imagesrcset = [
        xl  && `${xl} 2048w`,
        lg  && `${lg} 1600w`,
        med && `${med} 1200w`,
        sm  && `${sm} 800w`,
      ].filter(Boolean).join(", ");

      const href = xl || lg || med || sm;

      return href
        ? {
            href,
            imagesrcset,
            imagesizes: "(max-width: 1200px) 100vw, 100vw",
            type: "image/webp",
          }
        : null;
    })
    .filter(Boolean);
}


---

{
  page ? (
    <BaseLayout 
      title={page.title} 
      lcp={lcpData} 
      preloads={[
		...carouselPreloads.map((href) => ({ href })),
		...slideshowPreloads
	  ]}
    >
      <LayoutRenderer layouts={page.layouts || []} />
    </BaseLayout>
  ) : (
    "Page Not found"
  )
}