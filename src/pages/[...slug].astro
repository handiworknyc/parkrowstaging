---
// src/pages/[...slug].astro
import BaseLayout from "../layouts/MainLayout.astro";
import LayoutRenderer from "../lib/wp/LayoutRenderer.astro";
import { getAllFlexiblePagePaths, getFlexiblePageByUri } from "../lib/api";
export const prerender = true;

// ✅ IMPORT HELPER FUNCTIONS
import { normalizeLayouts } from "../lib/wp/normalize";
import { getLcpImage } from "../lib/wp/lcp"; 
import { getPreloads } from "../lib/wp/preloads"; // <--- NEW IMPORT

export async function getStaticPaths() {
  return getAllFlexiblePagePaths();
}

const { slug = [] } = Astro.params;
const uri = "/" + (Array.isArray(slug) ? slug.join("/") : slug) + "/";
const page = await getFlexiblePageByUri(uri);

if (!page) {
  Astro.response.status = 404;
  Astro.response.statusText = "Not found";
}

/* ---------------------------------------------------------
   LCP & PRELOAD CALCULATION
--------------------------------------------------------- */
let lcpData = null;
let preloads = [];

if (page && page.layouts) {
  const rows = normalizeLayouts(page.layouts);

  lcpData = getLcpImage(rows);
  
  // ✅ ONE LINE TO RULE THEM ALL
  preloads = getPreloads(rows);
}

---

{
  page ? (
    <BaseLayout 
      title={page.title} 
      lcp={lcpData} 
      preloads={preloads}
    >
      <LayoutRenderer layouts={page.layouts || []} />
    </BaseLayout>
  ) : (
    "Page Not found"
  )
}