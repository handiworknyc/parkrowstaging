---
/**
 * src/lib/wp/LayoutRenderer.astro
 * Static JSON flexible layout renderer
 */

import { normalizeLayouts } from "./normalize";
import type { NormRow } from "./normalize";
import pageOrder from "../../content/wp/page-order.json";

/* ---------------- Types ---------------- */
interface Props {
  layouts?: any[];
  taxContext?: string | null;
  pageId?: number | null;
  pageSlug?: string | null;
}

interface LayoutSettings {
  section_title?: string;
  section_h2?: string;
  section_text?: string;
  green_bg?: boolean;
  section_text_below?: boolean;
  bg_color?: string;
}

interface CommonContext {
  postId: number | null;
  currentPost: any;
  termId: null;
  taxonomy: null;
  currentTerm: null;
  rowIndex: number;
  prevLayout: NormRow | null;
  nextLayout: NormRow | null;
}

/* ---------------- Props ---------------- */
const {
  layouts = [],
  taxContext = null,
  pageId = null,
  pageSlug = null,
} = Astro.props as Props;

/* ---------------- Component Loading ---------------- */
const modules = import.meta.glob("/src/components/flex/*.astro", {
  eager: true,
});

const COMPONENT_MAP: Record<string, any> = {};

for (const [path, mod] of Object.entries(modules)) {
  const filename = path.split("/").pop()?.replace(/\.astro$/i, "") || "";
  COMPONENT_MAP[filename] = (mod as any).default;
}

function getComponent(name: string) {
  return COMPONENT_MAP[name] || null;
}

/* ---------------- Helper Functions ---------------- */
function safeHtml(val: any): string {
  if (!val) return "";
  if (typeof val === "string") return val;
  return val?.htmlParts?.join?.("") ?? "";
}

function stripSlashes(str: string): string {
  try {
    if (str.startsWith("http")) {
      const u = new URL(str);
      str = u.pathname;
    }
    return str.replace(/^\/+|\/+$/g, "");
  } catch {
    return str;
  }
}

function toKebab(s: string): string {
  return s.replace(/_/g, "-");
}

function isAltBgContext(taxContext: string | null, firstLayout: string): boolean {
  return (
    taxContext === "service" ||
    taxContext === "service-area" ||
    firstLayout === "service_area_banner"
  );
}

function computeBgWrapClass(
  row: NormRow,
  rowindex: number,
  altBgContext: boolean
): string | null {
  const ls = row.data?.layout_settings as LayoutSettings | undefined;
  const bgColor = typeof ls?.bg_color === "string" ? ls.bg_color.trim() : "";

  if (bgColor && bgColor !== "none") {
    return /\bbg-1\b/.test(bgColor.toLowerCase()) ? bgColor : `${bgColor}bg-1`;
  }

  if (altBgContext && rowindex >= 2) {
    return rowindex % 2 === 0 ? "whitebg-1" : "mintbg-1";
  }

  return null;
}

function buildSectionClasses(
  row: NormRow,
  idx: number,
  prevRow: NormRow | null,
  hasHeaderContent: boolean,
  placeHeaderBelow: boolean,
  nextHasSectionContent: boolean,
  firstIsSplash: boolean
): string {
  const rowindex = idx + 1;
  const isFullBleedImage = row.name === "full_bleed_img";
  const rawContent = row.data?.content || [];
  const isSecondRowAlsoRowOne = firstIsSplash && idx === 1;

  const classes = [
    "flex-bg",
    ...row.meta.classes,
    prevRow?.name ? `prev-${toKebab(prevRow.name)}` : "",
    hasHeaderContent ? "has-section-content" : "no-section-content",
    row.name === "splash_video" ? "full_bleed_img-module" : "",
    placeHeaderBelow ? "header-below" : "header-at-top",
    nextHasSectionContent ? "next-has-section-content" : "next-no-section-content",
    isFullBleedImage && rawContent.length === 0 ? "image-only" : "",
    `rowindex-${isSecondRowAlsoRowOne ? 1 : rowindex}`,
  ];

  return classes.filter(Boolean).join(" ");
}

function isLongSectionTitle(title: string): boolean {
  const lines = title
    .split(/<br\s*\/?>/i)
    .map((l) => l.replace(/<[^>]+>/g, "").trim());
  return lines.some((l) => l.length >= 18);
}

/* ---------------- Navigation Helper ---------------- */
function getNextPage(currentPath: string) {
  if (taxContext) return null;

  const currentPathClean = stripSlashes(decodeURIComponent(currentPath));
  const reversedPageOrder = [...pageOrder].reverse();

  const currentIndex = reversedPageOrder.findIndex(
    (p) => stripSlashes(p.uri) === currentPathClean
  );

  if (currentIndex === -1) return null;

  const nextPage =
    currentIndex < reversedPageOrder.length - 1
      ? reversedPageOrder[currentIndex + 1]
      : reversedPageOrder[0];

  return {
    page: nextPage,
    slug: stripSlashes(nextPage.uri).replace(/\//g, "-"),
  };
}

/* ---------------- Data Prep ---------------- */
const rows = normalizeLayouts(Array.isArray(layouts) ? layouts : []);
const firstLayout = rows[0]?.name ?? "";
const firstIsSplash = firstLayout === "splash_video";
const altBgContext = isAltBgContext(taxContext, firstLayout);
const nextPageData = getNextPage(Astro.url.pathname);

const commonCtxBase = {
  postId: pageId ?? null,
  currentPost: null,
  termId: null,
  taxonomy: null,
  currentTerm: null,
};
---

{rows.length === 0 && (
  <div class="prose mx-auto my-12 text-center opacity-70">
    <p>No content yet.</p>
  </div>
)}

{rows.map((row, idx) => {
  const Comp = getComponent(row.name);
  const rowindex = idx + 1;
  const prevRow = idx > 0 ? rows[idx - 1] : null;
  const nextRow = idx < rows.length - 1 ? rows[idx + 1] : null;

  const nextLs = nextRow?.data?.layout_settings as LayoutSettings | undefined;
  const nextHasSectionContent = !!(
    nextLs?.section_title ||
    nextLs?.section_h2 ||
    nextLs?.section_text
  );

  const commonCtx: CommonContext = {
    ...commonCtxBase,
    rowIndex: rowindex,
    prevLayout: prevRow,
    nextLayout: nextRow,
  };

  const preHtmlString = safeHtml(row.meta.preHtml);
  const ls = row.data?.layout_settings as LayoutSettings | undefined;

  const {
    section_title = "",
    section_h2 = "",
    section_text = "",
    green_bg = false,
    section_text_below = false,
  } = ls || {};

  const hasHeaderContent = !!(section_title || section_h2 || section_text);
  const placeHeaderBelow = section_text_below === true;
  const isLongTitle = section_title ? isLongSectionTitle(section_title) : false;

  const sectionClass = buildSectionClasses(
    row,
    idx,
    prevRow,
    hasHeaderContent,
    placeHeaderBelow,
    nextHasSectionContent,
    firstIsSplash
  );
const bgWrapClass = computeBgWrapClass(row, rowindex, altBgContext);
const bgColorClass = green_bg ? "bg-green c-white" : "";

const headerInnerClass = [
  "flex-section-content",
  "hw-contain",
  !(section_h2 || section_text) ? "title-only" : "",
].filter(Boolean).join(" ");

const headerInner = (
  <div class={headerInnerClass}>
    <div class="row">
      <div class="min-[1400px]:push-1 min-[1400px]:col-10 min-[1180px]:col-11 col-12 flex">
        <div class="row">
          {section_title && (
            <h2
              class={`antiga section-title min-[1400px]:col-5 min-[960px]:col-6 col-12 min-[960px]:mb-0 min-[700px]:mb-7 ${
                isLongTitle ? "long-title" : ""
              }`}
              set:html={section_title}
            />
          )}

          <div class="section-text-wrap max-[960px]:ml-0 ml-auto min-[1400px]:col-5 min-[1100px]:col-5 min-[960px]:col-6 max-[1180px]:min-[1100px]:push-1 col-12">
            {section_h2 && (
              <h3
                class="figure figure-h3 min-[960px]:mt-0 min-[700px]:mt-5 max-[699px]:mt-[4.75rem]"
                set:html={section_h2}
              />
            )}

            {section_text && (
              <div class="section-text" set:html={section_text} />
            )}
          </div>
        </div>
      </div>
    </div>
  </div>
);

const headerContent = hasHeaderContent
  ? bgColorClass
    ? <div class={bgColorClass}>{headerInner}</div>
    : headerInner
  : null;


  return (
    <section id={row.meta.id || undefined} class={sectionClass}>
      {preHtmlString && <div set:html={preHtmlString} />}

      {bgWrapClass ? (
        <div class={bgWrapClass}>
          <div class={`flex-bg-inner z-[100] pr ${row.meta?.ofh ? "ofh" : ""}`}>
            {!placeHeaderBelow && headerContent}
            {Comp && <Comp {...row.data} {...commonCtx} />}
            {placeHeaderBelow && headerContent}
          </div>
        </div>
      ) : (
        <>
          {!placeHeaderBelow && headerContent}
          {Comp && <Comp {...row.data} {...commonCtx} />}
          {placeHeaderBelow && headerContent}
        </>
      )}
    </section>
  );
})}

{nextPageData && (
  <section
    id={`next-link-${nextPageData.slug}`}
    class="next-page-section py-20 text-right"
  >
    <div class="hw-contain">
      <a href={nextPageData.page.uri} class="figure c-pink caps next-link">
        {nextPageData.page.title}
      </a>
    </div>
  </section>
)}