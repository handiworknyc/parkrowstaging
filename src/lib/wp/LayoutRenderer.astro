---
/**
 * src/lib/wp/LayoutRenderer.astro
 * Fixes "Objects are not valid as a React child" error
 * Renders flexible content rows
 */

import { normalizeLayouts } from "./normalize";
import type { NormRow } from "./normalize";
import { getEnv, toBase64 } from "../env.ts";

// ✅ IMPORT PAGE ORDER
import pageOrder from "../../content/wp/page-order.json";

/* ---------------- Props ---------------- */
interface Props {
  layouts?: any[];
  taxContext?: string | null;
  pageId?: number | null;
  pageSlug?: string | null;
}

let {
  layouts = [],
  taxContext = null,
  pageId = null,
  pageSlug = null,
} = Astro.props as Props;

/* ---------------- Env ---------------- */
const WP_BASE = import.meta.env.WP_BASE_URL || "";
const WP_AUTH_BASIC = getEnv("WP_AUTH_BASIC") || "";
const ROUTE_SLUG = Astro.params?.slug as string | undefined;

const authHeaders = WP_AUTH_BASIC
  ? { Authorization: `Basic ${toBase64(WP_AUTH_BASIC)}` }
  : {};

const WP_FIELDS = "_fields=id,acf,slug,title,type";

/* ---------------- Helpers ---------------- */
function safeHtml(val: any): string {
  if (!val) return "";
  if (typeof val === "string") return val;
  if (typeof val === "object" && val.htmlParts) {
    return Array.isArray(val.htmlParts) ? val.htmlParts.join("") : "";
  }
  return "";
}

function ensureWebpDeep(obj: any): any {
  if (!obj) return obj;
  if (typeof obj === "string") {
    return obj.replace(/\.(jpg|png)$/i, (ext) => `${ext}.webp`);
  }
  if (Array.isArray(obj)) {
    return obj.map(ensureWebpDeep);
  }
  if (typeof obj === "object") {
    const out: any = {};
    for (const [key, val] of Object.entries(obj)) {
      out[key] = ensureWebpDeep(val);
    }
    return out;
  }
  return obj;
}

async function fetchJson(url: string) {
  const finalUrl = url.includes("?")
    ? `${url}&${WP_FIELDS}`
    : `${url}?${WP_FIELDS}`;
  try {
    const res = await fetch(finalUrl, {
      headers: { Accept: "application/json", ...authHeaders },
    });
    if (!res.ok) return null;
    return await res.json();
  } catch (e) {
    console.error(`[LayoutRenderer] Fetch failed: ${finalUrl}`, e);
    return null;
  }
}

/* ---------------- Main Logic ---------------- */
let currentPost: any = null;

if (!WP_BASE) {
  console.error("[LayoutRenderer] Missing WP_BASE_URL");
} else {
  if (pageId) {
    const data = await fetchJson(`${WP_BASE}/wp-json/wp/v2/pages/${pageId}`);
    if (data) currentPost = data;
  } else {
    const effSlug =
      pageSlug ||
      ROUTE_SLUG ||
      import.meta.env.PUBLIC_HOME_SLUG ||
      "home";
    if (effSlug) {
      const data = await fetchJson(
        `${WP_BASE}/wp-json/wp/v2/pages?slug=${encodeURIComponent(effSlug)}`
      );
      if (Array.isArray(data) && data[0]) {
        currentPost = data[0];
      }
    }
  }
}

/* ---------------- Data Prep ---------------- */
const postId = currentPost?.id ?? null;
const fetchedLayouts = currentPost?.acf?.layouts ?? null;
const effectiveLayouts =
  Array.isArray(fetchedLayouts) && fetchedLayouts.length > 0
    ? fetchedLayouts
    : layouts;

const rows: NormRow[] = normalizeLayouts(effectiveLayouts);

/* ---------------- Component Map ---------------- */
const modules = import.meta.glob("/src/components/flex/*.astro", {
  eager: true,
});
const COMPONENT_MAP: Record<string, any> = {};

const toKebab = (s: string) =>
  s.replace(/[_\s]+/g, "-")
    .replace(/([a-z0-9])([A-Z])/g, "$1-$2")
    .toLowerCase();
const toSnake = (s: string) =>
  s.replace(/[-\s]+/g, "_")
    .replace(/([a-z0-9])([A-Z])/g, "$1_$2")
    .toLowerCase();
const toCamel = (s: string) => {
  const base = s.replace(/[-_ ]+(\w)/g, (_, c) =>
    c ? c.toUpperCase() : ""
  );
  return base.charAt(0).toLowerCase() + base.slice(1);
};

for (const [p, mod] of Object.entries(modules)) {
  const file = p.split("/").pop()?.replace(/\.astro$/i, "") || "";
  const component = (mod as any).default;
  COMPONENT_MAP[file] = component;
  COMPONENT_MAP[toKebab(file)] = component;
  COMPONENT_MAP[toSnake(file)] = component;
  COMPONENT_MAP[toCamel(file)] = component;
}

function getComponent(name: string) {
  return (
    COMPONENT_MAP[name] ||
    COMPONENT_MAP[toKebab(name)] ||
    COMPONENT_MAP[toSnake(name)] ||
    null
  );
}

/* ---------------- Render Helpers ---------------- */
const firstLayout = rows[0]?.name ?? "";

function isAltBgContext(): boolean {
  return (
    taxContext === "service" ||
    taxContext === "service-area" ||
    firstLayout === "service_area_banner"
  );
}

function computeBgWrapClass(row: NormRow, rowindex: number): string | null {
  const ls = (row as any)?.data?.layout_settings ?? {};
  const bgColor: string =
    typeof ls?.bg_color === "string" ? ls.bg_color.trim() : "";

  if (bgColor && bgColor !== "none") {
    if (/\bbg-1\b/.test(bgColor.toLowerCase())) return bgColor;
    return `${bgColor}bg-1`;
  }

  if (isAltBgContext() && rowindex >= 2) {
    return rowindex % 2 === 0 ? "whitebg-1" : "mintbg-1";
  }
  return null;
}

const commonCtxBase = {
  postId,
  currentPost,
  termId: null,
  taxonomy: null,
  currentTerm: null,
};

/* ---------------------------------------------------------
   ✅ 2. NEXT PAGE CALCULATIONS (ROBUST FIX)
--------------------------------------------------------- */
let nextPage: any = null;
let nextSlug = "none"; 

// Helper to strip slashes/domains for clean comparison
function stripSlashes(str: string) {
  try {
    // If it's a full URL, get pathname
    if (str.startsWith("http")) {
      const u = new URL(str);
      str = u.pathname;
    }
    return str.replace(/^\/+|\/+$/g, "");
  } catch {
    return str;
  }
}

if (!taxContext) {
  const currentPathClean = stripSlashes(decodeURIComponent(Astro.url.pathname));

  // Reverse order (so we go forward in your specific list)
  const reversedPageOrder = [...pageOrder].reverse();

  const currentIndex = reversedPageOrder.findIndex((p) => {
    return stripSlashes(p.uri) === currentPathClean;
  });

  if (currentIndex >= 0) {
    if (currentIndex < reversedPageOrder.length - 1) {
      nextPage = reversedPageOrder[currentIndex + 1];
    } else {
      // Loop back to start
      nextPage = reversedPageOrder[0];
    }
  }

  // Generate a safe slug for the ID so Astro knows it's a new element
  if (nextPage) {
    nextSlug = stripSlashes(nextPage.uri).replace(/\//g, "-");
  }
}
---

{rows.length === 0 && (
  <div class="prose mx-auto my-12 text-center opacity-70">
    <p>No content yet.</p>
  </div>
)}

{rows.map((row, idx) => {

  /* 🔥 Apply WebP conversion BEFORE passing data to components */
  row.data = ensureWebpDeep(row.data);

  const Comp = getComponent(row.name);
  const rowindex = idx + 1;
  const commonCtx = { ...commonCtxBase, rowIndex: rowindex };
  const preHtmlString = safeHtml(row.meta.preHtml);

  /* ---------------------------------------------------------
   * 1. Extract Layout Settings
   * --------------------------------------------------------- */
  const ls = row.data?.layout_settings || {};
  const {
    section_title,
    section_h2,
    section_text,
    green_bg,
    section_text_below
  } = ls;

  const placeHeaderBelow = section_text_below === true;

  /* ---------------------------------------------------------
   * 2. Determine Classes
   * --------------------------------------------------------- */
  const hasHeaderContent = !!(section_title || section_h2 || section_text);
  const contentStatusClass = hasHeaderContent
    ? "has-section-content"
    : "no-section-content";

  const bgColorClass = green_bg ? "bg-green c-white" : "";

  const isFullBleedImage = row.name === "full_bleed_img";
  const rawContent = row.data?.content || [];
  const hasContent = rawContent.length > 0;
  const imageOnlyClass = isFullBleedImage && !hasContent ? "image-only" : "";

  const sectionClass = `flex-bg ${row.meta.classes.join(" ")} ${contentStatusClass} ${imageOnlyClass}`.trim();

  const bgWrapClass = computeBgWrapClass(row, rowindex);

  /* ---------------------------------------------------------
   * 3. Header HTML
   * --------------------------------------------------------- */
  const hasTextContent = section_h2 || section_text;
  const headerWrapperClass = `flex-section-content hw-contain ${bgColorClass} ${
    !hasTextContent ? "title-only" : ""
  }`.trim();

  const headerContent = hasHeaderContent ? (
    <div class={headerWrapperClass}>
      <div class="row">
        <div class="push-1 col-10 flex">
          <div class="row">
            {section_title && (
              <h2 class="antiga section-title col-5" set:html={section_title} />
            )}

            <div class="section-text-wrap ml-auto col-5">
              {section_h2 && <h3 class="figure figure-h3" set:html={section_h2} />}
              {section_text && (
                <div class="section-text" set:html={section_text} />
              )}
            </div>
          </div>
        </div>
      </div>
    </div>
  ) : null;

  /* ---------------------------------------------------------
   * 4. Render
   * --------------------------------------------------------- */
  return (
    <section id={row.meta.id || undefined} class={sectionClass}>
      {preHtmlString && <div set:html={preHtmlString} />}

      {bgWrapClass ? (
        <div class={bgWrapClass}>
          <div
            class={`flex-bg-inner z-[100] pr ${
              row.meta?.ofh ? "ofh" : ""
            }`}
          >
            {!placeHeaderBelow && headerContent}

            {Comp ? (
              <Comp {...row.data} {...commonCtx} />
            ) : (
              <div class="mx-auto my-8 max-w-5xl rounded-xl border p-4">
                <p class="font-semibold">
                  Unknown layout: <code>{row.name}</code>
                </p>
                <p class="text-sm mt-1">
                  Create <code>src/components/flex/{toSnake(row.name)}.astro</code>
                </p>
              </div>
            )}

            {placeHeaderBelow && headerContent}
          </div>
        </div>
      ) : (
        <>
          {!placeHeaderBelow && headerContent}

          {Comp ? (
            <Comp {...row.data} {...commonCtx} />
          ) : (
            <div class="mx-auto my-8 max-w-5xl rounded-xl border p-4">
              <p class="font-semibold">
                Unknown layout: <code>{row.name}</code>
              </p>
              <p class="text-sm mt-1">
                Create <code>src/components/flex/{toSnake(row.name)}.astro</code>
              </p>
            </div>
          )}

          {placeHeaderBelow && headerContent}
        </>
      )}
    </section>
  );
})}

{/* ✅ 3. RENDER NEXT PAGE LINK */}
{/* FIX: We use a dynamic 'id' based on the next slug.
    This guarantees Astro sees it as a NEW element during View Transition,
    forcing a tear-down and rebuild with the correct content.
*/}
{nextPage && (
  <section 
    id={`next-link-${nextSlug}`}
    class="next-page-section py-20 text-right"
  >
    <div class="hw-contain">
      <a href={nextPage.uri} class="figure c-pink caps next-link">
        {nextPage.title}
      </a>
    </div>
  </section>
)}