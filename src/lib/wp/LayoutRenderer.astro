---
/**
 * src/lib/wp/LayoutRenderer.astro
 * Static-only flexible layout renderer
 * No WordPress runtime fetches
 */

import { normalizeLayouts } from "./normalize";
import type { NormRow } from "./normalize";

// ✅ page order manifest generated by sync-flex-rest
import pageOrder from "../../content/wp/page-order.json";

/* ---------------- Props ---------------- */
interface Props {
  layouts?: any[];
  taxContext?: string | null;
  pageId?: number | null;
  pageSlug?: string | null;
}

const {
  layouts = [],
  taxContext = null,
  pageId = null,
  pageSlug = null,
} = Astro.props as Props;

/* ---------------- Helpers ---------------- */
function safeHtml(val: any): string {
  if (!val) return "";
  if (typeof val === "string") return val;
  if (typeof val === "object" && val.htmlParts) {
    return Array.isArray(val.htmlParts) ? val.htmlParts.join("") : "";
  }
  return "";
}

function ensureWebpDeep(obj: any): any {
  if (!obj) return obj;

  if (typeof obj === "string") {
    return obj.replace(/\.(jpg|png)$/i, (ext) => `${ext}.webp`);
  }

  if (Array.isArray(obj)) {
    return obj.map(ensureWebpDeep);
  }

  if (typeof obj === "object") {
    const out: any = {};
    for (const [k, v] of Object.entries(obj)) {
      out[k] = ensureWebpDeep(v);
    }
    return out;
  }

  return obj;
}

/* ---------------- Layout Prep ---------------- */
const effectiveLayouts = Array.isArray(layouts) ? layouts : [];
const rows: NormRow[] = normalizeLayouts(effectiveLayouts);

/* ---------------- Component Map ---------------- */
const modules = import.meta.glob("/src/components/flex/*.astro", {
  eager: true,
});

const COMPONENT_MAP: Record<string, any> = {};

const toKebab = (s: string) =>
  s
    .replace(/[_\s]+/g, "-")
    .replace(/([a-z0-9])([A-Z])/g, "$1-$2")
    .toLowerCase();

const toSnake = (s: string) =>
  s
    .replace(/[-\s]+/g, "_")
    .replace(/([a-z0-9])([A-Z])/g, "$1_$2")
    .toLowerCase();

const toCamel = (s: string) => {
  const base = s.replace(/[-_ ]+(\w)/g, (_, c) =>
    c ? c.toUpperCase() : ""
  );
  return base.charAt(0).toLowerCase() + base.slice(1);
};

for (const [p, mod] of Object.entries(modules)) {
  const file = p.split("/").pop()?.replace(/\.astro$/i, "") || "";
  const component = (mod as any).default;

  COMPONENT_MAP[file] = component;
  COMPONENT_MAP[toKebab(file)] = component;
  COMPONENT_MAP[toSnake(file)] = component;
  COMPONENT_MAP[toCamel(file)] = component;
}

function getComponent(name: string) {
  return (
    COMPONENT_MAP[name] ||
    COMPONENT_MAP[toKebab(name)] ||
    COMPONENT_MAP[toSnake(name)] ||
    null
  );
}

/* ---------------- Context ---------------- */
const firstLayout = rows[0]?.name ?? "";

function isAltBgContext(): boolean {
  return (
    taxContext === "service" ||
    taxContext === "service-area" ||
    firstLayout === "service_area_banner"
  );
}

function computeBgWrapClass(row: NormRow, rowindex: number): string | null {
  const ls = (row as any)?.data?.layout_settings ?? {};
  const bgColor =
    typeof ls?.bg_color === "string" ? ls.bg_color.trim() : "";

  if (bgColor && bgColor !== "none") {
    if (/\bbg-1\b/.test(bgColor.toLowerCase())) return bgColor;
    return `${bgColor}bg-1`;
  }

  if (isAltBgContext() && rowindex >= 2) {
    return rowindex % 2 === 0 ? "whitebg-1" : "mintbg-1";
  }

  return null;
}

function prevLayoutClass(prevRow: NormRow | null): string {
  return prevRow?.name ? `prev-${toKebab(prevRow.name)}` : "";
}

const commonCtxBase = {
  postId: pageId,
  currentPost: null,
  termId: null,
  taxonomy: null,
  currentTerm: null,
};

/* ---------------- Next Page Logic ---------------- */
let nextPage: any = null;
let nextSlug = "none";

function stripSlashes(str: string) {
  try {
    if (str.startsWith("http")) {
      const u = new URL(str);
      str = u.pathname;
    }
    return str.replace(/^\/+|\/+$/g, "");
  } catch {
    return str;
  }
}

if (!taxContext) {
  const currentPath = stripSlashes(decodeURIComponent(Astro.url.pathname));
  const reversed = [...pageOrder].reverse();

  const index = reversed.findIndex(
    (p) => stripSlashes(p.uri) === currentPath
  );

  if (index >= 0) {
    nextPage =
      index < reversed.length - 1
        ? reversed[index + 1]
        : reversed[0];
  }

  if (nextPage) {
    nextSlug = stripSlashes(nextPage.uri).replace(/\//g, "-");
  }
}

const firstIsSplash = rows[0]?.name === "splash_video";
---

{rows.length === 0 && (
  <div class="prose mx-auto my-12 text-center opacity-70">
    <p>No content yet.</p>
  </div>
)}

{rows.map((row, idx) => {
  row.data = ensureWebpDeep(row.data);

  const Comp = getComponent(row.name);
  const rowindex = idx + 1;

  const prevRow = idx > 0 ? rows[idx - 1] : null;
  const nextRow = idx < rows.length - 1 ? rows[idx + 1] : null;

  const nextLs = nextRow?.data?.layout_settings || {};
  const nextHasSectionContent =
    !!(nextLs.section_title || nextLs.section_h2 || nextLs.section_text);

  const commonCtx = {
    ...commonCtxBase,
    rowIndex: rowindex,
    prevLayout: prevRow,
    nextLayout: nextRow,
  };

  const preHtmlString = safeHtml(row.meta.preHtml);
  const ls = row.data?.layout_settings || {};

  const {
    section_title,
    section_h2,
    section_text,
    green_bg,
    section_text_below,
  } = ls;

  const placeHeaderBelow = section_text_below === true;

  const hasHeaderContent =
    !!(section_title || section_h2 || section_text);

  const isLongTitle =
    section_title
      ?.split(/<br\s*\/?>/i)
      .some((l: string) => l.replace(/<[^>]+>/g, "").trim().length >= 18) ??
    false;

  const sectionClass = `
    flex-bg
    ${row.meta.classes.join(" ")}
    ${prevLayoutClass(prevRow)}
    ${hasHeaderContent ? "has-section-content" : "no-section-content"}
    ${row.name === "splash_video" ? "full_bleed_img-module" : ""}
    ${placeHeaderBelow ? "header-below" : "header-at-top"}
    ${nextHasSectionContent ? "next-has-section-content" : "next-no-section-content"}
    ${
      row.name === "full_bleed_img" &&
      (row.data?.content || []).length === 0
        ? "image-only"
        : ""
    }
    rowindex-${firstIsSplash && idx === 1 ? 1 : rowindex}
  `.trim();

  const bgWrapClass = computeBgWrapClass(row, rowindex);

  const headerContent = hasHeaderContent ? (
    <div
      class={`flex-section-content hw-contain ${
        green_bg ? "bg-green c-white" : ""
      } ${!(section_h2 || section_text) ? "title-only" : ""}`}
    >
      <div class="row">
        <div class="min-[1400px]:push-1 min-[1400px]:col-10 col-12 flex">
          <div class="row">
            {section_title && (
              <h2
                class={`antiga section-title ${
                  isLongTitle ? "long-title" : ""
                }`}
                set:html={section_title}
              />
            )}

            <div class="section-text-wrap ml-auto col-12">
              {section_h2 && (
                <h3
                  class="figure figure-h3"
                  set:html={section_h2}
                />
              )}
              {section_text && (
                <div class="section-text" set:html={section_text} />
              )}
            </div>
          </div>
        </div>
      </div>
    </div>
  ) : null;

  return (
    <section id={row.meta.id || undefined} class={sectionClass}>
      {preHtmlString && <div set:html={preHtmlString} />}

      {bgWrapClass ? (
        <div class={bgWrapClass}>
          <div class={`flex-bg-inner z-[100] ${row.meta?.ofh ? "ofh" : ""}`}>
            {!placeHeaderBelow && headerContent}
            {Comp && <Comp {...row.data} {...commonCtx} />}
            {placeHeaderBelow && headerContent}
          </div>
        </div>
      ) : (
        <>
          {!placeHeaderBelow && headerContent}
          {Comp && <Comp {...row.data} {...commonCtx} />}
          {placeHeaderBelow && headerContent}
        </>
      )}
    </section>
  );
})}

{nextPage && (
  <section
    id={`next-link-${nextSlug}`}
    class="next-page-section py-20 text-right"
  >
    <div class="hw-contain">
      <a href={nextPage.uri} class="figure c-pink caps next-link">
        {nextPage.title}
      </a>
    </div>
  </section>
)}
