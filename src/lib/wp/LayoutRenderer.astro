---
/**
 * src/lib/wp/LayoutRenderer.astro
 * Static JSON flexible layout renderer with language support
 */

import { normalizeLayouts } from "./normalize";
import type { NormRow } from "./normalize";
import pageOrder from "../../content/wp/page-order.json";
import { getLocalizedField } from "../language";

/* ---------------- Types ---------------- */
interface Props {
  layouts?: any[];
  taxContext?: string | null;
  pageId?: number | null;
  pageSlug?: string | null;
  lang?: 'en' | 'zh';
  skipSplash?: boolean;
}

interface LayoutSettings {
  section_title?: string;
  section_title_chinese?: string;
  section_h2?: string;
  section_h2_chinese?: string;
  section_text?: string;
  section_text_chinese?: string;
  green_bg?: boolean;
  section_text_below?: boolean;
  bg_color?: string;
}

interface CommonContext {
  postId: number | null;
  currentPost: any;
  termId: null;
  taxonomy: null;
  currentTerm: null;
  rowIndex: number;
  prevLayout: NormRow | null;
  nextLayout: NormRow | null;
  lang: 'en' | 'zh'; // Add language to context
}

interface OrderedPageLink {
  uri: string;
  title: string;
  title_chinese?: string;
}

/* ---------------- Props ---------------- */
const {
  layouts = [],
  taxContext = null,
  pageId = null,
  pageSlug = null,
  lang = 'en', // default safety
  skipSplash = false,
} = Astro.props as Props;


/* ---------------- Component Loading ---------------- */
const modules = import.meta.glob("/src/components/flex/*.astro", {
  eager: true,
});
const pageModules = import.meta.glob("/src/content/wp/pages/*.json", {
  eager: true,
});

const COMPONENT_MAP: Record<string, any> = {};
const PAGE_DATA_BY_URI = new Map<string, Record<string, any>>();

for (const [path, mod] of Object.entries(modules)) {
  const filename = path.split("/").pop()?.replace(/\.astro$/i, "") || "";
  COMPONENT_MAP[filename] = (mod as any).default;
}

for (const mod of Object.values(pageModules)) {
  const data = ((mod as any)?.default ?? mod) as Record<string, any> | null;
  if (data?.uri) {
    PAGE_DATA_BY_URI.set(stripSlashes(String(data.uri)), data);
  }
}

function getComponent(name: string) {
  return COMPONENT_MAP[name] || null;
}

/* ---------------- Helper Functions ---------------- */
function safeHtml(val: any): string {
  if (!val) return "";
  if (typeof val === "string") return val;
  return val?.htmlParts?.join?.("") ?? "";
}

function stripSlashes(str: string): string {
  try {
    if (str.startsWith("http")) {
      const u = new URL(str);
      str = u.pathname;
    }
    return str.replace(/^\/+|\/+$/g, "");
  } catch {
    return str;
  }
}

function toKebab(s: string): string {
  return s.replace(/_/g, "-");
}

function getPageStatus(page: Record<string, any> | null | undefined): string {
  return typeof page?.status === "string" ? page.status.toLowerCase() : "";
}

function isPublishedPage(page: Record<string, any> | null | undefined): boolean {
  const status = getPageStatus(page);
  return status ? status === "publish" : true;
}

function buildOrderedPublishedPages(): OrderedPageLink[] {
  const orderedPages = Array.isArray(pageOrder) ? pageOrder : [];

  return orderedPages.flatMap((entry) => {
    if (!entry?.uri || !entry?.title) {
      return [];
    }

    const syncedPage = PAGE_DATA_BY_URI.get(stripSlashes(String(entry.uri)));
    if (!syncedPage || !isPublishedPage(syncedPage)) {
      return [];
    }

    const title =
      typeof syncedPage.title === "string" && syncedPage.title.trim()
        ? syncedPage.title.trim()
        : String(entry.title).trim();

    if (!title) {
      return [];
    }

    return [
      {
        uri: typeof syncedPage.uri === "string" ? syncedPage.uri : String(entry.uri),
        title,
        title_chinese:
          typeof syncedPage.title_chinese === "string" && syncedPage.title_chinese.trim()
            ? syncedPage.title_chinese.trim()
            : undefined,
      },
    ];
  });
}

const orderedPublishedPages = buildOrderedPublishedPages();


function localizeValue(value: any, lang: 'en' | 'zh') {
  // Arrays = ACF repeater
  if (Array.isArray(value)) {
    return value.map(item => localizeValue(item, lang));
  }

  // Objects = nested ACF groups / repeater rows
  if (value && typeof value === 'object') {
    const out: Record<string, any> = {};

    for (const [key, val] of Object.entries(value)) {
      // Skip language-specific source fields
      if (key.endsWith('_chinese')) continue;

      // Localize nested values
      out[key] = localizeValue(
        getLocalizedField(value, key, lang),
        lang
      );
    }

    return out;
  }

  // Primitives (string, number, boolean, null)
  return value;
}

function localizeRowData(data: any, lang: 'en' | 'zh') {
  if (!data || typeof data !== 'object') return data;
  if (lang === 'en') return data; // optional shortcut
  return localizeValue(data, lang);
}




function isAltBgContext(taxContext: string | null, firstLayout: string): boolean {
  return (
    taxContext === "service" ||
    taxContext === "service-area" ||
    firstLayout === "service_area_banner"
  );
}

function computeBgWrapClass(
  row: NormRow,
  rowindex: number,
  altBgContext: boolean
): string | null {
  const ls = row.data?.layout_settings as LayoutSettings | undefined;
  const bgColor = typeof ls?.bg_color === "string" ? ls.bg_color.trim() : "";

  if (bgColor && bgColor !== "none") {
    return /\bbg-1\b/.test(bgColor.toLowerCase()) ? bgColor : `${bgColor}bg-1`;
  }

  if (altBgContext && rowindex >= 2) {
    return rowindex % 2 === 0 ? "whitebg-1" : "mintbg-1";
  }

  return null;
}

function buildSectionClasses(
  row: NormRow,
  idx: number,
  prevRow: NormRow | null,
  hasHeaderContent: boolean,
  placeHeaderBelow: boolean,
  nextHasSectionContent: boolean,
  firstIsSplash: boolean,
  isLastLayout: boolean,
  width?: string,
  panorama?: boolean
): string {
  const rowindex = idx + 1;
  const isFullBleedImage = row.name === "full_bleed_img";
  const rawContent = row.data?.content || [];
  const isSecondRowAlsoRowOne = firstIsSplash && idx === 1;

  const normalizedWidth =
    typeof width === "string"
      ? width.trim().toLowerCase()
      : "";

  const classes = [
    "flex-bg",
    ...row.meta.classes,

    normalizedWidth === "full" && "really-full",
    panorama === true && "panorama",

    prevRow?.name ? `prev-${toKebab(prevRow.name)}` : "",
    hasHeaderContent ? "has-section-content" : "no-section-content",
    row.name === "splash_video" ? "full_bleed_img-module" : "",
    placeHeaderBelow ? "header-below" : "header-at-top",
    nextHasSectionContent
      ? "next-has-section-content"
      : "next-no-section-content",
    isFullBleedImage && rawContent.length === 0 ? "image-only" : "",
    isLastLayout ? "last-layout" : "",
    `rowindex-${isSecondRowAlsoRowOne ? 1 : rowindex}`,
  ];

  return classes.filter(Boolean).join(" ");
}

function isLongSectionTitle(title: string): boolean {
  const lines = title
    .split(/<br\s*\/?>/i)
    .map((l) => l.replace(/<[^>]+>/g, "").trim());
  return lines.some((l) => l.length >= 18);
}

/* ---------------- Navigation Helper ---------------- */
function getNextPage(currentPath: string) {
  if (taxContext) return null;

  const currentPathClean = stripSlashes(decodeURIComponent(currentPath));
  const currentPage = PAGE_DATA_BY_URI.get(currentPathClean);
  if (currentPage && !isPublishedPage(currentPage)) {
    return null;
  }

  if (orderedPublishedPages.length < 2) return null;

  const reversedPageOrder = [...orderedPublishedPages].reverse();

  const currentIndex = reversedPageOrder.findIndex(
    (p) => stripSlashes(p.uri) === currentPathClean
  );

  if (currentIndex === -1) return null;

  const nextPage =
    currentIndex < reversedPageOrder.length - 1
      ? reversedPageOrder[currentIndex + 1]
      : reversedPageOrder[0];

  if (!nextPage || stripSlashes(nextPage.uri) === currentPathClean) {
    return null;
  }

  return {
    page: nextPage,
    slug: stripSlashes(nextPage.uri).replace(/\//g, "-"),
  };
}

/* ---------------- Data Prep ---------------- */
const allRows = normalizeLayouts(Array.isArray(layouts) ? layouts : []);
const rows = skipSplash ? allRows.filter(r => r.name !== "splash_video") : allRows;
const firstLayout = rows[0]?.name ?? "";
const firstIsSplash = firstLayout === "splash_video";
const altBgContext = isAltBgContext(taxContext, firstLayout);

const rawPath = Astro.url.pathname.replace(/^\/zh/, '') || '/';
const nextPageData = getNextPage(rawPath);

const commonCtxBase = {
  postId: pageId ?? null,
  currentPost: null,
  termId: null,
  taxonomy: null,
  currentTerm: null,
  lang, // Pass language to all components
};
---

{rows.length === 0 && (
  <div class="prose mx-auto my-12 text-center opacity-70">
    <p>No content yet.</p>
  </div>
)}

{rows.map((row, idx) => {
  const Comp = getComponent(row.name);
  const rowindex = idx + 1;
  const prevRow = idx > 0 ? rows[idx - 1] : null;
  const nextRow = idx < rows.length - 1 ? rows[idx + 1] : null;

  const nextLs = nextRow?.data?.layout_settings as LayoutSettings | undefined;
  const nextHasSectionContent = !!(
    getLocalizedField(nextLs, 'section_title', lang) ||
    getLocalizedField(nextLs, 'section_h2', lang) ||
    getLocalizedField(nextLs, 'section_text', lang)
  );

  const commonCtx: CommonContext = {
    ...commonCtxBase,
    rowIndex: rowindex,
    prevLayout: prevRow,
    nextLayout: nextRow,
  };

  const preHtmlString = safeHtml(row.meta.preHtml);
  const ls = row.data?.layout_settings as LayoutSettings | undefined;

  // Get localized layout settings
  const section_title = getLocalizedField(ls, 'section_title', lang);
  const section_h2 = getLocalizedField(ls, 'section_h2', lang);
  const section_text = getLocalizedField(ls, 'section_text', lang);
  const green_bg = ls?.green_bg || false;
  const section_text_below = ls?.section_text_below || false;

  const hasHeaderContent = !!(section_title || section_h2 || section_text);
  const placeHeaderBelow = section_text_below === true;
  const isLongTitle = section_title ? isLongSectionTitle(section_title) : false;

  const sectionClass = buildSectionClasses(
    row,
    idx,
    prevRow,
    hasHeaderContent,
    placeHeaderBelow,
    nextHasSectionContent,
    firstIsSplash,
    idx === rows.length - 1,
    row.data?.width,
    row.data?.panorama
  );

  const bgWrapClass = computeBgWrapClass(row, rowindex, altBgContext);
  const bgColorClass = green_bg ? "bg-green c-white" : "";

  const headerInnerClass = [
    "flex-section-content",
    "hw-contain",
    !(section_h2 || section_text) ? "title-only" : "",
  ]
    .filter(Boolean)
    .join(" ");

  const headerInner = (
    <div class={headerInnerClass}>
      <div class="row">
        <div class="min-[1400px]:push-1 min-[1400px]:col-10 min-[1180px]:col-11 col-12 flex">
          <div class="row">
            {section_title && (
              <h2
                class={`antiga section-title min-[1400px]:col-5 min-[960px]:col-6 col-12 min-[960px]:mb-0 min-[700px]:mb-7 ${
                  isLongTitle ? "long-title" : ""
                }`}
                set:html={section_title}
              />
            )}

            <div class="section-text-wrap max-[960px]:ml-0 ml-auto min-[1400px]:col-5 min-[1100px]:col-5 min-[960px]:col-6 max-[1180px]:min-[1100px]:push-1 col-12">
              {section_h2 && (
                <h3
                  class="figure figure-h3 min-[960px]:mt-0 min-[700px]:mt-5 max-[699px]:mt-[4.75rem]"
                  set:html={section_h2}
                />
              )}

              {section_text && (
                <div class="section-text" set:html={section_text} />
              )}
            </div>
          </div>
        </div>
      </div>
    </div>
  );

  // Check if full_width_slideshow has per-slide section overrides
  const slideshowHasSlideOverrides = row.name === "full_width_slideshow" &&
    Array.isArray(row.data?.images) &&
    row.data.images.some((img: any) => img?.section_title || img?.section_h3 || img?.section_text);

  // When per-slide overrides exist, suppress static header — the React component handles it
  const headerContent = (hasHeaderContent && !slideshowHasSlideOverrides)
    ? bgColorClass
      ? <div class={bgColorClass}>{headerInner}</div>
      : headerInner
    : null;

	const localizedData = localizeRowData(row.data, lang);

	// Pass section content positioning to slideshow when it has per-slide overrides
	if (slideshowHasSlideOverrides) {
		localizedData._sectionPlaceBelow = placeHeaderBelow;
		localizedData._sectionBgColorClass = bgColorClass || null;
	}


  return (
    <section id={row.meta.id || undefined} class={sectionClass}>
      {preHtmlString && <div set:html={preHtmlString} />}

      {bgWrapClass ? (
        <div class={bgWrapClass}>
          <div class={`flex-bg-inner z-[100] pr ${row.meta?.ofh ? "ofh" : ""}`}>
            {!placeHeaderBelow && headerContent}
			

			{Comp && <Comp {...localizedData} {...commonCtx} />}

            {placeHeaderBelow && headerContent}
          </div>
        </div>
      ) : (
        <>
          {!placeHeaderBelow && headerContent}


			{Comp && <Comp {...localizedData} {...commonCtx} />}

          {placeHeaderBelow && headerContent}
        </>
      )}
    </section>
  );
})}

{nextPageData && (
  <section
    id={`next-link-${nextPageData.slug}`}
    class="next-page-section py-20 text-right"
  >
    <div class="hw-contain">
      <a
        href={lang === 'zh' ? `/zh${nextPageData.page.uri}` : nextPageData.page.uri}
        class="figure c-pink caps next-link"
      >
        {lang === 'zh' && nextPageData.page.title_chinese
          ? nextPageData.page.title_chinese
          : nextPageData.page.title}
      </a>
    </div>
  </section>
)}
