---
// mainlayout.astro
import { ClientRouter } from "astro:transitions";
import SiteFooter from "../components/SiteFooter.astro";
import SiteNav from "../components/SiteNav.astro";
import PromoPopup from "../components/PromoPopup.astro";    
import videoJsUrl from "/src/scripts/videojs.js?url";

// Critical CSS
import "../styles/global.scss";

// Below-the-fold CSS
import belowCssUrl from "@/styles/below.scss?url";

// URL for critical script
import headerCriticalUrl from "@/scripts/header-critical.js?url";

const WP_BASE_URL = import.meta.env.WP_BASE_URL;

/* ---------------- Props Interface ---------------- */
interface PreloadItem {
  href: string;
  imagesrcset?: string;
  imagesizes?: string;
  type?: string;
}

interface Props {
  title?: string;
  description?: string;
  lcp?: PreloadItem | null;
  lcpVideo?: {
    href: string; // HLS (.m3u8) URL only
  } | null;

  // carousel = string[], full_width_slideshow = PreloadItem[]
  preloads?: (string | PreloadItem)[];
}

const {
  title = "",
  description = "",
  lcp = null,
  lcpVideo = null,
  preloads = [],
} = Astro.props;

const pathname = Astro.url.pathname;
const segments = pathname.split("/").filter(Boolean);
const bodyClasses = segments.length ? segments.join(" ") : "home";

Astro.response.headers.set(
  "Cache-Control",
  "public, max-age=2700, s-maxage=2700, stale-while-revalidate=12000"
);

Astro.response.headers.set(
  "Netlify-CDN-Cache-Control",
  "public, max-age=2700, stale-while-revalidate=12000"
);
---

<html lang="en" style="view-transition-name: main-content">
<head>
  <meta charset="utf-8" />
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <meta name="viewport" content="width=device-width" />
  <meta name="generator" content={Astro.generator} />
  <title>{title}</title>

  {description && <meta name="description" content={description} />}

  {/* 🚀 LCP PRELOAD (CURRENT PAGE) */}
  {lcp && (
    <link 
      rel="preload"
      as="image"
      fetchpriority="high"
      href={lcp.href}
      imagesrcset={lcp.imagesrcset}
      imagesizes={lcp.imagesizes}
      type={lcp.type}
    />
  )}

  <link rel="modulepreload" href={videoJsUrl} />

  {/* ────────────────────────────────────────────────────────────────
      LCP VIDEO (HLS WARMUP)
  ───────────────────────────────────────────────────────────────── */}
  {lcpVideo && (
    <>
      <link rel="preconnect"
        href="https://customer-kzf3pwxulwy9bd0t.cloudflarestream.com"
        crossorigin />

      <link rel="dns-prefetch"
        href="https://customer-kzf3pwxulwy9bd0t.cloudflarestream.com" />

      <link rel="prefetch"
        as="fetch"
        href={lcpVideo.href}
        crossorigin="anonymous" />
    </>
  )}


  <script>
    import "../scripts/smart-image";
  </script>

  <style define:vars={{ wpBaseUrl: `url('${WP_BASE_URL}')` }}>
    :root {
      --wp-base-url: var(--wpBaseUrl);
    }
  </style>

  <script src={headerCriticalUrl} defer></script>

  <ClientRouter prefetch="load" />

  <script>
    document.addEventListener("astro:before-swap", (ev) => {
      ev.newDocument.body.classList.remove("first-load");
    });
  </script>

	<script>
	import Lenis from 'lenis';

	let lenis;

	// Initialize Lenis
	const initLenis = () => {
		// Prevent creating multiple instances if one already exists
		if (lenis) return;

		lenis = new Lenis({
		lerp: .2, // Smoothness (0-1). Lower is smoother.
		smoothWheel: true, // Enable smooth scrolling for mouse wheel
		});

		// The animation loop
		function raf(time) {
		lenis.raf(time);
		requestAnimationFrame(raf);
		}

		requestAnimationFrame(raf);
	};

	// Run on initial load and after every View Transition swap
	document.addEventListener('astro:page-load', initLenis);
	
	// Optional: Handle anchor links with smooth scroll
	// This prevents the native jump and uses Lenis's smooth scroll instead
	document.addEventListener('click', (e) => {
		const target = e.target.closest('a[href^="#"]');
		if (target) {
		e.preventDefault();
		const id = target.getAttribute('href');
		if (id === '#') return;
		lenis.scrollTo(id);
		}
	});
	</script>
</head>

<body class={`first-load ${bodyClasses}`}>
  <main>
    <SiteNav />
    <div class="switcher">
      <slot />
    </div>
  </main>

  <SiteFooter />

  <link rel="stylesheet" href={belowCssUrl} media="print" onload="this.media='all'" />

  <script is:client>
    if (window.__isSafari) {
      document.documentElement.classList.add("disable-vt");

      document.addEventListener("click", (e) => {
        const a = e.target.closest("a[href]");
        if (!a) return;

        const url = a.getAttribute("href");
        if (
          (url.startsWith("http") && !url.startsWith(location.origin)) ||
          url.startsWith("#") ||
          url.startsWith("mailto:") ||
          url.startsWith("tel:") ||
          url.startsWith("javascript:")
        ) return;

        e.preventDefault();
        window.location.href = url;
      });
    }
  </script>

  <PromoPopup />
</body>
</html>
