---
// mainlayout.astro
import { ClientRouter } from "astro:transitions";
import SiteFooter from "../components/SiteFooter.astro";
import SiteNav from "../components/SiteNav.astro";
import PromoPopup from "../components/PromoPopup.astro";    
import videoJsUrl from "/src/scripts/videojs.js?url";

// Critical CSS
import "../styles/global.scss";

// Below-the-fold CSS
import belowCssUrl from "@/styles/below.scss?url";

// URL for critical script
import headerCriticalUrl from "@/scripts/header-critical.js?url";

const WP_BASE_URL = import.meta.env.WP_BASE_URL;

/* ---------------- Props Interface ---------------- */
interface PreloadItem {
  href: string;
  imagesrcset?: string;
  imagesizes?: string;
  type?: string;
}

interface Props {
  title?: string;
  description?: string;
  lcp?: PreloadItem | null;
  lcpVideo?: {
    href: string; // HLS (.m3u8) URL only
  } | null;

  // carousel = string[], full_width_slideshow = PreloadItem[]
  preloads?: (string | PreloadItem)[];
}

const {
  title = "",
  description = "",
  lcp = null,
  lcpVideo = null,
  preloads = [],
} = Astro.props;

const pathname = Astro.url.pathname;
const segments = pathname.split("/").filter(Boolean);
const bodyClasses = segments.length ? segments.join(" ") : "home";

Astro.response.headers.set(
  "Cache-Control",
  "public, max-age=2700, s-maxage=2700, stale-while-revalidate=12000"
);

Astro.response.headers.set(
  "Netlify-CDN-Cache-Control",
  "public, max-age=2700, stale-while-revalidate=12000"
);
---

<html lang="en" style="view-transition-name: main-content">
<head>
  <meta charset="utf-8" />
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <meta name="viewport" content="width=device-width" />
  <meta name="generator" content={Astro.generator} />
  <title>{title}</title>

  {description && <meta name="description" content={description} />}

  {/* 🚀 LCP PRELOAD (CURRENT PAGE) */}
  {lcp && (
    <link 
      rel="preload"
      as="image"
      fetchpriority="high"
      href={lcp.href}
      imagesrcset={lcp.imagesrcset}
      imagesizes={lcp.imagesizes}
      type={lcp.type}
    />
  )}

  <link rel="modulepreload" href={videoJsUrl} />

  {/* ────────────────────────────────────────────────────────────────
      LCP VIDEO (HLS WARMUP)
  ───────────────────────────────────────────────────────────────── */}
  {lcpVideo && (
    <>
      <link rel="preconnect"
        href="https://customer-iyfwlpktwxjf4onx.cloudflarestream.com"
        crossorigin />

      <link rel="dns-prefetch"
        href="https://customer-iyfwlpktwxjf4onx.cloudflarestream.com" />

      <link rel="prefetch"
        as="fetch"
        href={lcpVideo.href}
        crossorigin="anonymous" />
    </>
  )}

{/* ────────────────────────────────────────────────────────────────
    CAROUSEL + FULL WIDTH SLIDESHOW PRELOADER (WITH LOGGING)
──────────────────────────────────────────────────────────────── */}
<script is:inline define:vars={{ preloads }}>
  window.addEventListener("critImgLoaded", () => {
    console.log("[Preload] critImgLoaded fired");
    console.log("[Preload] Incoming preloads:", preloads);

    if (!preloads || preloads.length === 0) {
      console.warn("[Preload] No preload items found");
      return;
    }

    const run = window.requestIdleCallback || ((cb) => setTimeout(cb, 1));

    run(() => {
      console.log("[Preload] Starting preload queue…");

      preloads.forEach((p, i) => {
        if (!p) {
          console.warn(`[Preload] Skipping empty preload at index ${i}`);
          return;
        }

        // ─────────────────────────────
        // Legacy carousel preload
        // ─────────────────────────────
        if (typeof p === "string") {
          console.log(`[Preload][Carousel]`, p);
          const img = new Image();
          img.src = p;
          return;
        }

        // ─────────────────────────────
        // SRCSET slideshow preload
        // ─────────────────────────────
        if (p.href) {
          console.log(`[Preload][Slideshow]`, {
            href: p.href,
            srcset: p.imagesrcset,
            sizes: p.imagesizes,
            type: p.type
          });

          const link = document.createElement("link");
          link.rel = "preload";
          link.as = "image";
          link.href = p.href;

          if (p.imagesrcset) link.setAttribute("imagesrcset", p.imagesrcset);
          if (p.imagesizes) link.setAttribute("imagesizes", p.imagesizes);
          if (p.type) link.setAttribute("type", p.type);

          document.head.appendChild(link);
          return;
        }

        console.warn("[Preload] Unknown preload entry:", p);
      });

      console.log("[Preload] Queue complete");
    });
  }, { once: true });
</script>


  {/* ────────────────────────────────────────────────────────────────
      PREFETCH MAP LOGIC (SRCSET PARSER)
  ───────────────────────────────────────────────────────────────── */}
  <script is:client>
    (async () => {
      function getBestImage(srcset) {
        if (!srcset) return null;

        const candidates = srcset.split(",").map(s => {
          const parts = s.trim().split(/\s+/);
          const url = parts[0];
          const wDesc = parts.length > 1 ? parts[1] : null;
          let width = 0;
          if (wDesc && wDesc.endsWith("w")) width = parseInt(wDesc, 10);
          return { url, width };
        });

        candidates.sort((a, b) => a.width - b.width);
        const targetWidth = window.innerWidth * (window.devicePixelRatio || 1);
        const best = candidates.find(c => c.width >= targetWidth);
        return best ? best.url : candidates[candidates.length - 1].url;
      }

      try {
        const req = await fetch("/prefetch-map.json", { cache: "no-store" });
        if (!req.ok) return;

        const map = await req.json();
        const assets = new Set();

        map.forEach((entry) => {
          if (!entry.lcp) return;

          if (entry.lcp.imagesrcset) {
            const bestUrl = getBestImage(entry.lcp.imagesrcset);
            if (bestUrl) assets.add(bestUrl);
          } else if (entry.lcp.href) {
            assets.add(entry.lcp.href);
          }

          if (entry.video) assets.add(entry.video);
        });

        window.__PREFETCH_ASSETS__ = Array.from(assets);
        console.log("[Prefetch] Asset list prepared:", window.__PREFETCH_ASSETS__);
      } catch (err) {
        console.warn("Prefetch map failed:", err);
      }
    })();
  </script>

  {/* ────────────────────────────────────────────────────────────────
      SW PREFETCH HANDSHAKE
  ───────────────────────────────────────────────────────────────── */}
  <script is:client>
    if ("serviceWorker" in navigator) {
      navigator.serviceWorker.register("/sw.js").then((reg) => {
        navigator.serviceWorker.addEventListener("message", (event) => {
          if (event.data === "request-prefetch-list") {
            if (window.__PREFETCH_ASSETS__?.length) {
              reg.active?.postMessage({ prefetchAssets: window.__PREFETCH_ASSETS__ });
            }
          }
        });

        function notifySW(worker) {
          worker.postMessage("prefetch");
        }

        if (reg.active) notifySW(reg.active);
        else {
          reg.addEventListener("updatefound", () => {
            const w = reg.installing;
            w.addEventListener("statechange", () => {
              if (w.state === "activated") notifySW(w);
            });
          });
        }
      });
    }
  </script>

  <script>
    import "../scripts/smart-image";
  </script>

  <style define:vars={{ wpBaseUrl: `url('${WP_BASE_URL}')` }}>
    :root {
      --wp-base-url: var(--wpBaseUrl);
    }
  </style>

  <script src={headerCriticalUrl} defer></script>

  <ClientRouter prefetch="load" />

  <script>
    document.addEventListener("astro:before-swap", (ev) => {
      ev.newDocument.body.classList.remove("first-load");
    });
  </script>

<script>
  import LocomotiveScroll from "locomotive-scroll";

  let locoScroll = null;
  let scrollUnlocked = false;
  let unlockTimer = null;
  let splashUnlockTimer = null;

  const SPLASH_FADE_DURATION = 800; // ms (match splash fade)

  /* ------------------------------------
     HELPERS
  ------------------------------------ */
  function isHome() {
    return document.body.classList.contains("home");
  }

  function isFirstLoad() {
    return document.body.classList.contains("first-load");
  }

  /* ------------------------------------
     SCROLL CONTROL
  ------------------------------------ */
  function unlockScroll(source = "unknown") {
    if (!isFirstLoad()) return;
    if (scrollUnlocked) return;

    scrollUnlocked = true;
    document.body.classList.add("scroll-unlocked");

    clearTimeout(unlockTimer);
    clearTimeout(splashUnlockTimer);
    unlockTimer = null;
    splashUnlockTimer = null;

    if (locoScroll) {
      locoScroll.start();
    }
  }

  /* ------------------------------------
     INIT LOCOMOTIVE
  ------------------------------------ */
  function initLocoScroll() {
    const el = document.querySelector("main");
    if (!el) return;

    if (locoScroll) {
      locoScroll.destroy();
      locoScroll = null;
    }

    locoScroll = new LocomotiveScroll({
      el,
      smooth: true,
      lenisOptions: {
        lerp: 0,
        duration: 0.5,
      },
      smartphone: { smooth: true },
      tablet: { smooth: true },
    });

    window.locoScroll = locoScroll;

    // 🔒 Lock ONLY on first load + home
    if (isHome() && isFirstLoad() && !scrollUnlocked) {
      requestAnimationFrame(() => {
        locoScroll.stop();
      });

      clearTimeout(unlockTimer);

      // Absolute failsafe
      unlockTimer = setTimeout(() => {
        unlockScroll("timeout");
      }, 6600);
    } else {
      // Never force lock/unlock on non-first loads
      locoScroll.start();
    }
  }

  /* ------------------------------------
     ASTRO LIFECYCLE
  ------------------------------------ */
  document.addEventListener("astro:page-load", () => {
    setTimeout(initLocoScroll, 50);
  });

  document.addEventListener("astro:before-preparation", () => {
    locoScroll?.stop();
  });

  document.addEventListener("astro:after-swap", () => {
    if (!locoScroll) return;

    if (!isFirstLoad()) {
      locoScroll.start();
      return;
    }

    scrollUnlocked ? locoScroll.start() : locoScroll.stop();
  });

  /* ------------------------------------
     SPLASH → SCROLL CONTRACT
  ------------------------------------ */
  window.addEventListener("splash:dismiss", (e) => {
    if (!isHome() || !isFirstLoad() || scrollUnlocked) return;

    clearTimeout(unlockTimer);
    unlockTimer = null;

    clearTimeout(splashUnlockTimer);
    splashUnlockTimer = setTimeout(() => {
      unlockScroll(e?.detail?.source || "splash");
    }, SPLASH_FADE_DURATION);
  });

  /* ------------------------------------
     ANCHOR LINKS
  ------------------------------------ */
  document.addEventListener("click", (e) => {
    const a = e.target.closest('a[href^="#"]');
    if (!a || !locoScroll) return;

    const id = a.getAttribute("href");
    if (!id || id === "#") return;

    const target = document.querySelector(id);
    if (!target) return;

    e.preventDefault();
    locoScroll.scrollTo(target);
  });
</script>



</head>

<body class={`first-load ${bodyClasses}`}>
  <main>
    <SiteNav />

    <div class="switcher">
      <slot />
    </div>

	<div class="mob-bottom-bar" transition:persist>
		<div class="hw-contain flex-wrap items-center">
			<a class="icon-arrow-right icon-after border-btn white">
				Inquire
			</a>

			<a class='ml-auto c-white mob-bar-phone' href="tel:">425-555-1234</a>
		</div>
	</div>

	<div id="mob-bottom-sentinel"></div>
  </main>


  <SiteFooter />

  <link rel="stylesheet" href={belowCssUrl} media="print" onload="this.media='all'" />

  <script is:client>
    if (window.__isSafari) {
      document.documentElement.classList.add("disable-vt");

      document.addEventListener("click", (e) => {
        const a = e.target.closest("a[href]");
        if (!a) return;

        const url = a.getAttribute("href");
        if (
          (url.startsWith("http") && !url.startsWith(location.origin)) ||
          url.startsWith("#") ||
          url.startsWith("mailto:") ||
          url.startsWith("tel:") ||
          url.startsWith("javascript:")
        ) return;

        e.preventDefault();
        window.location.href = url;
      });
    }
  </script>

  <PromoPopup />
</body>
</html>
