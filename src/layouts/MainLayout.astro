---
// mainlayout.astro
import { ClientRouter } from "astro:transitions";
import SiteFooter from "../components/SiteFooter.astro";
import SiteNav from "../components/SiteNav.astro";
import PromoPopup from "../components/PromoPopup.astro";

import videoJsUrl from "/src/scripts/videojs.js?url";
import belowCssUrl from "@/styles/below.scss?url";
import headerCriticalUrl from "@/scripts/header-critical.js?url";

import "../styles/global.scss";

/* ---------------- Types ---------------- */
interface PreloadItem {
  href: string;
  imagesrcset?: string;
  imagesizes?: string;
  type?: string;
}

interface Props {
  title?: string;
  description?: string;
  lcp?: PreloadItem | null;
  lcpVideo?: {
    href: string;
  } | null;
  preloads?: (string | PreloadItem)[];
}

/* ---------------- Props & Config ---------------- */
const {
  title = "",
  description = "",
  lcp = null,
  lcpVideo = null,
  preloads = [],
} = Astro.props;

const WP_BASE_URL = import.meta.env.WP_BASE_URL;
const CLOUDFLARE_STREAM_DOMAIN = "https://customer-iyfwlpktwxjf4onx.cloudflarestream.com";

const pathname = Astro.url.pathname;
const segments = pathname.split("/").filter(Boolean);
const bodyClasses = segments.length ? segments.join(" ") : "home";

const cacheControl = "public, max-age=2700, s-maxage=2700, stale-while-revalidate=12000";
Astro.response.headers.set("Cache-Control", cacheControl);
Astro.response.headers.set("Netlify-CDN-Cache-Control", cacheControl);
---

<html lang="en" style="view-transition-name: main-content">
<head>
  <meta charset="utf-8" />
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <meta name="viewport" content="width=device-width" />
  <meta name="generator" content={Astro.generator} />
  <title>{title}</title>
  {description && <meta name="description" content={description} />}

  {/* LCP Image Preload */}
  {lcp && (
    <link 
      rel="preload"
      as="image"
      fetchpriority="high"
      href={lcp.href}
      imagesrcset={lcp.imagesrcset}
      imagesizes={lcp.imagesizes}
      type={lcp.type}
    />
  )}

  <link rel="modulepreload" href={videoJsUrl} />

	{/* LCP Video (HLS Warmup) */}
	{lcpVideo && (
	<>
		<link rel="preconnect" href={CLOUDFLARE_STREAM_DOMAIN} crossorigin />
		<link rel="dns-prefetch" href={CLOUDFLARE_STREAM_DOMAIN} />
		{/* 🔑 CHANGED: prefetch → preload, added fetchpriority */}
		<link 
		rel="preload" 
		as="fetch" 
		href={lcpVideo.href} 
		type="application/vnd.apple.mpegurl"
		fetchpriority="high"
		crossorigin
		/>
	</>
	)}

  {/* Carousel/Slideshow Preloader */}
  <script is:inline define:vars={{ preloads }}>
    const DEBUG = false;
    const log = (...args) => DEBUG && console.log("[Preload]", ...args);

    window.addEventListener("critImgLoaded", () => {
      log("critImgLoaded fired");
      log("Incoming preloads:", preloads);

      if (!preloads?.length) {
        log("No preload items found");
        return;
      }

      const run = window.requestIdleCallback || ((cb) => setTimeout(cb, 1));

      run(() => {
        log("Starting preload queue...");

        preloads.forEach((p, i) => {
          if (!p) {
            log(`Skipping empty preload at index ${i}`);
            return;
          }

          // Legacy carousel (string URL)
          if (typeof p === "string") {
            log("[Carousel]", p);
            const img = new Image();
            img.src = p;
            return;
          }

          // Slideshow (srcset)
          if (p.href) {
            log("[Slideshow]", {
              href: p.href,
              srcset: p.imagesrcset,
              sizes: p.imagesizes,
              type: p.type
            });

            const link = document.createElement("link");
            link.rel = "preload";
            link.as = "image";
            link.href = p.href;

            if (p.imagesrcset) link.setAttribute("imagesrcset", p.imagesrcset);
            if (p.imagesizes) link.setAttribute("imagesizes", p.imagesizes);
            if (p.type) link.setAttribute("type", p.type);

            document.head.appendChild(link);
            return;
          }

          log("Unknown preload entry:", p);
        });

        log("Queue complete");
      });
    }, { once: true });
  </script>

  {/* Prefetch Map Logic */}
  <script is:client>
    (async () => {
      function getBestImage(srcset) {
        if (!srcset) return null;

        const candidates = srcset.split(",").map(s => {
          const parts = s.trim().split(/\s+/);
          const url = parts[0];
          const wDesc = parts.length > 1 ? parts[1] : null;
          const width = wDesc?.endsWith("w") ? parseInt(wDesc, 10) : 0;
          return { url, width };
        });

        candidates.sort((a, b) => a.width - b.width);
        const targetWidth = window.innerWidth * (window.devicePixelRatio || 1);
        const best = candidates.find(c => c.width >= targetWidth);
        return best ? best.url : candidates[candidates.length - 1].url;
      }

      try {
        const res = await fetch("/prefetch-map.json", { cache: "no-store" });
        if (!res.ok) return;

        const map = await res.json();
        const assets = new Set();

        map.forEach((entry) => {
          if (!entry.lcp) return;

          const url = entry.lcp.imagesrcset 
            ? getBestImage(entry.lcp.imagesrcset)
            : entry.lcp.href;

          if (url) assets.add(url);
          if (entry.video) assets.add(entry.video);
        });

        window.__PREFETCH_ASSETS__ = Array.from(assets);
      } catch (err) {
        console.warn("Prefetch map failed:", err);
      }
    })();
  </script>

  {/* Service Worker Prefetch */}
  <script is:client>
    if ("serviceWorker" in navigator) {
      navigator.serviceWorker.register("/sw.js").then((reg) => {
        navigator.serviceWorker.addEventListener("message", (event) => {
          if (event.data === "request-prefetch-list" && window.__PREFETCH_ASSETS__?.length) {
            reg.active?.postMessage({ prefetchAssets: window.__PREFETCH_ASSETS__ });
          }
        });

        const notifySW = (worker) => worker.postMessage("prefetch");

        if (reg.active) {
          notifySW(reg.active);
        } else {
          reg.addEventListener("updatefound", () => {
            const w = reg.installing;
            w.addEventListener("statechange", () => {
              if (w.state === "activated") notifySW(w);
            });
          });
        }
      });
    }
  </script>

  <script>
    import "../scripts/smart-image";
  </script>

  <style define:vars={{ wpBaseUrl: `url('${WP_BASE_URL}')` }}>
    :root {
      --wp-base-url: var(--wpBaseUrl);
    }
  </style>

  <script src={headerCriticalUrl} defer></script>

  <ClientRouter prefetch="load" />

  <script>
    document.addEventListener("astro:before-swap", (ev) => {
      ev.newDocument.body.classList.remove("first-load");
    });
  </script>

  {/* Locomotive Scroll */}
  <script>
    import LocomotiveScroll from "locomotive-scroll";

    const CONFIG = {
      SPLASH_FADE_DURATION: 800,
      UNLOCK_TIMEOUT: 6600,
      LOCO_INIT_DELAY: 50,
    };

    const state = {
      locoScroll: null,
      scrollUnlocked: false,
      unlockTimer: null,
      splashUnlockTimer: null,
    };

    /* Helpers */
    const isHome = () => document.body.classList.contains("home");
    const isFirstLoad = () => document.body.classList.contains("first-load");

    function clearTimers() {
      clearTimeout(state.unlockTimer);
      clearTimeout(state.splashUnlockTimer);
      state.unlockTimer = null;
      state.splashUnlockTimer = null;
    }

    function unlockScroll(source = "unknown") {
      if (!isFirstLoad() || state.scrollUnlocked) return;

      state.scrollUnlocked = true;
      document.body.classList.add("scroll-unlocked");
      clearTimers();

      state.locoScroll?.start();
    }

    function initLocoScroll() {
      const el = document.querySelector("main");
      if (!el) return;

      state.locoScroll?.destroy();

      state.locoScroll = new LocomotiveScroll({
        el,
        smooth: true,
        lenisOptions: {
          lerp: 0,
          duration: 0.5,
        },
        smartphone: { smooth: true },
        tablet: { smooth: true },
      });

      window.locoScroll = state.locoScroll;

      // Dispatch ready event for other scripts
      document.dispatchEvent(
        new CustomEvent("loco:ready", { 
          detail: { instance: state.locoScroll } 
        })
      );

      // Lock only on first load + home
      if (isHome() && isFirstLoad() && !state.scrollUnlocked) {
        requestAnimationFrame(() => {
          state.locoScroll.stop();
        });

        clearTimers();
        state.unlockTimer = setTimeout(() => {
          unlockScroll("timeout");
        }, CONFIG.UNLOCK_TIMEOUT);
      } else {
        state.locoScroll.start();
      }
    }

    /* Astro Lifecycle */
    document.addEventListener("astro:page-load", () => {
      setTimeout(initLocoScroll, CONFIG.LOCO_INIT_DELAY);
    });

    document.addEventListener("astro:before-preparation", () => {
      state.locoScroll?.stop();
    });

    document.addEventListener("astro:after-swap", () => {
      if (!state.locoScroll) return;

      if (!isFirstLoad()) {
        state.locoScroll.start();
      } else {
        state.scrollUnlocked ? state.locoScroll.start() : state.locoScroll.stop();
      }
    });

    /* Splash Integration */
    window.addEventListener("splash:dismiss", (e) => {
      if (!isHome() || !isFirstLoad() || state.scrollUnlocked) return;

      clearTimers();
      state.splashUnlockTimer = setTimeout(() => {
        unlockScroll(e?.detail?.source || "splash");
      }, CONFIG.SPLASH_FADE_DURATION);
    });

    /* Anchor Link Handling */
    document.addEventListener("click", (e) => {
      const a = e.target.closest('a[href^="#"]');
      if (!a || !state.locoScroll) return;

      const id = a.getAttribute("href");
      if (!id || id === "#") return;

      const target = document.querySelector(id);
      if (!target) return;

      e.preventDefault();
      state.locoScroll.scrollTo(target);
    });
  </script>
</head>

<body class={`first-load ${bodyClasses}`}>
  <main>
    <SiteNav />

    <div class="switcher">
      <slot />
    </div>

    <div class="mob-bottom-bar" transition:persist>
      <div class="hw-contain flex-wrap items-center">
        <a class="icon-arrow-right icon-after border-btn white">
          Inquire
        </a>
        <a class="ml-auto c-white mob-bar-phone" href="tel:425-555-1234">
          425-555-1234
        </a>
      </div>
    </div>

    <div id="mob-bottom-sentinel"></div>
  </main>

  <SiteFooter />

  <link rel="stylesheet" href={belowCssUrl} media="print" onload="this.media='all'" />

  {/* Safari View Transitions Fallback */}
  <script is:client>
    if (window.__isSafari) {
      document.documentElement.classList.add("disable-vt");

      document.addEventListener("click", (e) => {
        const a = e.target.closest("a[href]");
        if (!a) return;

        const url = a.getAttribute("href");
        const isExternal = url.startsWith("http") && !url.startsWith(location.origin);
        const isSpecial = url.startsWith("#") || 
                         url.startsWith("mailto:") || 
                         url.startsWith("tel:") || 
                         url.startsWith("javascript:");

        if (isExternal || isSpecial) return;

        e.preventDefault();
        window.location.href = url;
      });
    }
  </script>

  <PromoPopup />
</body>
</html>