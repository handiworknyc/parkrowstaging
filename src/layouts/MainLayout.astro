---
//mainlayout.astro
import { ClientRouter } from "astro:transitions";
import SiteFooter from "../components/SiteFooter.astro";
import SiteNav from "../components/SiteNav.astro";

import { loadManifest } from "@/lib/loadManifest";
import { findCFVideoChunk } from "@/lib/findCFVideo";

const manifest = loadManifest();
const cfvideoChunk = findCFVideoChunk(manifest);

console.log("[SSR] Preload CFVideo chunk:", cfvideoChunk);

//import videoJsRuntime from "video.js?url";
//import qualityLevelsRuntime from "videojs-contrib-quality-levels?url";

//import VideoPrefetch from "../components/global/VideoPrefetch.astro";

// Critical CSS
import "../styles/global.scss";

// Below-the-fold CSS
import belowCssUrl from "@/styles/below.scss?url";

// URL for critical script
import headerCriticalUrl from "@/scripts/header-critical.js?url";

const WP_BASE_URL = import.meta.env.WP_BASE_URL;

/* ---------------- Props Interface ---------------- */
interface Props {
  title?: string;
  description?: string;
  lcp?: {
    href: string;
    imagesrcset?: string;
    imagesizes?: string;
  } | null;
  lcpVideo?: {
    href: string;
  } | null;
}

const { title = "", description = "", lcp = null, lcpVideo = null } = Astro.props;

const pathname = Astro.url.pathname;
const segments = pathname.split("/").filter(Boolean);
const bodyClasses = segments.length ? segments.join(" ") : "home";

---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="viewport" content="width=device-width" />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>

    {description && <meta name="description" content={description} />}

	{cfvideoChunk && (
	<link rel="modulepreload" href={cfvideoChunk} />
	)}

    {/* 🚀 LCP PRELOAD: High priority preload for hero image */}
	{lcp && (
	<link 
		rel="preload"
		as="image"
		fetchpriority="high"
		href={lcp.href}
		imagesrcset={lcp.imagesrcset}
		imagesizes={lcp.imagesizes}
		type={lcp.type}
	/>
	)}

	{lcpVideo && (
	<>
		{/* 1. DNS + TCP + TLS warmup */}
		<link rel="preconnect" href="https://customer-kzf3pwxulwy9bd0t.cloudflarestream.com" crossorigin />

		{/* 2. Early connection for the exact subdomain (required for speed) */}
		<link rel="dns-prefetch" href="https://customer-kzf3pwxulwy9bd0t.cloudflarestream.com" />

		{/* 3. Warm HLS manifest early without blocking render */}
		<link 
		rel="prefetch" 
		as="fetch" 
		href={`${lcpVideo.href}`} 
		crossorigin="anonymous" 
		/>
	</>
	)}

<script is:client>
(async () => {
  try {
    const req = await fetch("/prefetch-map.json", { cache: "no-store" });
    if (!req.ok) return;

    const map = await req.json();

    // Build image + video list without duplicates
    const assets = new Set();

    map.forEach((entry) => {
      if (entry.image) assets.add(entry.image);
      if (entry.video) assets.add(entry.video);
    });

    window.__PREFETCH_ASSETS__ = Array.from(assets);

    console.log("[Prefetch] Asset list prepared:", window.__PREFETCH_ASSETS__);
  } catch (err) {
    console.warn("Prefetch map failed:", err);
  }
})();
</script>


<script is:client>
if ("serviceWorker" in navigator) {
  navigator.serviceWorker.register("/sw.js").then((reg) => {

    // STEP 1 — Handle SW asking for the asset list
    navigator.serviceWorker.addEventListener("message", (event) => {
      if (event.data === "request-prefetch-list") {
        // Send the asset list from the page into the SW
        if (window.__PREFETCH_ASSETS__ && window.__PREFETCH_ASSETS__.length) {
          reg.active?.postMessage({
            prefetchAssets: window.__PREFETCH_ASSETS__,
          });
        }
      }
    });

    // STEP 2 — Trigger SW to begin prefetch handshake
    function notifySW(worker) {
      // Tell SW: "Ask me for the list"
      worker.postMessage("prefetch");
    }

    // STEP 3 — Send the message to proper worker
    if (reg.active) {
      notifySW(reg.active);
    } else {
      // Wait for install → activate
      reg.addEventListener("updatefound", () => {
        const newWorker = reg.installing;
        newWorker.addEventListener("statechange", () => {
          if (newWorker.state === "activated") {
            notifySW(newWorker);
          }
        });
      });
    }
  });
}
</script>



    <script>
      import "../scripts/smart-image";
     // import "../scripts/gsap-global";
    </script>

    <style define:vars={{ wpBaseUrl: `url('${WP_BASE_URL}')` }}>
      :root {
        --wp-base-url: var(--wpBaseUrl);
      }
    </style>

    <script src={headerCriticalUrl} defer></script>

    <ClientRouter prefetch="viewport" />

	
	<script>		
		document.addEventListener('astro:before-swap', (ev) => {
			ev.newDocument.body.classList.remove('first-load');
		});
	</script>
  </head>

<body class={`first-load ${bodyClasses}`}>
    <main>
      <SiteNav />
      <div class="switcher" style="view-transition-name: main-content">
        <slot />
      </div>
    </main>

    <SiteFooter />

    {/* below-the-fold CSS */}
    <link
      rel="stylesheet"
      href={belowCssUrl}
      media="print"
      onload="this.media='all'"
    />


	<script is:client>
	if (window.__isSafari) {
		// Kill all view transition effects completely
		document.documentElement.classList.add("disable-vt");

		// Intercept all internal <a> clicks and force real navigation
		document.addEventListener("click", (e) => {
			const a = e.target.closest("a[href]");
			if (!a) return;

			const url = a.getAttribute("href");

			// Skip external links, mailto, #hash, javascript:void(0)
			if (
				url.startsWith("http") && !url.startsWith(location.origin)
				|| url.startsWith("#")
				|| url.startsWith("mailto:")
				|| url.startsWith("tel:")
				|| url.startsWith("javascript:")
			) {
				return;
			}

			// STOP Astro ClientRouter
			e.preventDefault();

			// Hard navigation — NO FLASH, NO TRANSITION, NO FLICKER
			window.location.href = url;
		});
	}

	// Keep your first-load reset
	document.addEventListener("astro:before-swap", (ev) => {
		ev.newDocument.body.classList.remove("first-load");
	});
	</script>

  </body>
</html>
