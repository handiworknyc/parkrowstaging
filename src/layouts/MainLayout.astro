---
//mainlayout.astro
import { ClientRouter, fade } from "astro:transitions";
import SiteFooter from "../components/SiteFooter.astro";
import SiteNav from "../components/SiteNav.astro";
import PromoPopup from "../components/PromoPopup.astro";	
import videoJsUrl from "/src/scripts/videojs.js?url";

// Critical CSS
import "../styles/global.scss";

// Below-the-fold CSS
import belowCssUrl from "@/styles/below.scss?url";

// URL for critical script
import headerCriticalUrl from "@/scripts/header-critical.js?url";

const WP_BASE_URL = import.meta.env.WP_BASE_URL;

/* ---------------- Props Interface ---------------- */
interface Props {
  title?: string;
  description?: string;
  lcp?: {
    href: string;
    imagesrcset?: string;
    imagesizes?: string;
  } | null;
  lcpVideo?: {
    href: string;
    mp4?: string;      // <── ADDED SUPPORT FOR LCP MP4
  } | null;
}

const { title = "", description = "", lcp = null, lcpVideo = null } = Astro.props;

const pathname = Astro.url.pathname;
const segments = pathname.split("/").filter(Boolean);
const bodyClasses = segments.length ? segments.join(" ") : "home";

Astro.response.headers.set ( 
	'Cache-Control',
	'public, max-age=2700, s-maxage=2700, stale-while-revalidate=12000',
)

Astro.response.headers.set(
	'Netlify-CDN-Cache-Control',
	'public, max-age=2700, stale-while-revalidate=12000',
)

---

<html lang="en">
<head>
  <meta charset="utf-8" />
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <meta name="viewport" content="width=device-width" />
  <meta name="generator" content={Astro.generator} />
  <title>{title}</title>

  {description && <meta name="description" content={description} />}

  {/* 🚀 LCP PRELOAD (IMAGE) */}
  {lcp && (
    <link 
      rel="preload"
      as="image"
      fetchpriority="high"
      href={lcp.href}
      imagesrcset={lcp.imagesrcset}
      imagesizes={lcp.imagesizes}
      type={lcp.type}
    />
  )}

  <link rel="modulepreload" href={videoJsUrl} />

  {/* ────────────────────────────────────────────────────────────────
      LCP VIDEO (HLS WARMUP — REMOVABLE IF MP4 CACHED)
  ───────────────────────────────────────────────────────────────── */}
  {lcpVideo && (
    <>
      <link id="lcp-preconnect" rel="preconnect"
        href="https://customer-kzf3pwxulwy9bd0t.cloudflarestream.com"
        crossorigin />

      <link id="lcp-dns" rel="dns-prefetch"
        href="https://customer-kzf3pwxulwy9bd0t.cloudflarestream.com" />

      <link id="lcp-hls-prefetch"
        rel="prefetch"
        as="fetch"
        href={lcpVideo.href}
        crossorigin="anonymous" />
    </>
  )}

  {/* ────────────────────────────────────────────────────────────────
      CONDITIONAL REMOVE HLS PREFETCH IF MP4 EXISTS IN SW CACHE
  ───────────────────────────────────────────────────────────────── */}
  {lcpVideo?.mp4 && (
    <script is:client>
      (async () => {
        try {
          const mp4Url = "{lcpVideo.mp4}";

          const cache = await caches.open("videos-mp4");
          const match = await cache.match(mp4Url);

          if (match) {
            console.log("[LCP] MP4 already cached → removing HLS warmup");

            document.getElementById("lcp-hls-prefetch")?.remove();
            document.getElementById("lcp-preconnect")?.remove();
            document.getElementById("lcp-dns")?.remove();

            // Add MP4 preload
            const preload = document.createElement("link");
            preload.rel = "preload";
            preload.as = "video";
            preload.href = mp4Url;
            preload.type = "video/mp4";
            preload.fetchPriority = "high";
            document.head.appendChild(preload);

          } else {
            console.log("[LCP] MP4 not cached → keeping HLS warmup");
          }

        } catch (err) {
          console.warn("[LCP] Cache check error:", err);
        }
      })();
    </script>
  )}

  {/* ────────────────────────────────────────────────────────────────
      PREFETCH MAP → pass image/video URLs to SW
  ───────────────────────────────────────────────────────────────── */}
  <script is:client>
    (async () => {
      try {
        const req = await fetch("/prefetch-map.json", { cache: "no-store" });
        if (!req.ok) return;

        const map = await req.json();
        const assets = new Set();

        map.forEach((entry) => {
          if (entry.image) assets.add(entry.image);
          if (entry.video) assets.add(entry.video);
          if (entry.video_mp4) assets.add(entry.video_mp4);
        });

        window.__PREFETCH_ASSETS__ = Array.from(assets);

        console.log("[Prefetch] Asset list prepared:", window.__PREFETCH_ASSETS__);
      } catch (err) {
        console.warn("Prefetch map failed:", err);
      }
    })();
  </script>

  {/* ────────────────────────────────────────────────────────────────
      SW PREFETCH HANDSHAKE
  ───────────────────────────────────────────────────────────────── */}
  <script is:client>
    if ("serviceWorker" in navigator) {
      navigator.serviceWorker.register("/sw.js").then((reg) => {

        navigator.serviceWorker.addEventListener("message", (event) => {
          if (event.data === "request-prefetch-list") {
            if (window.__PREFETCH_ASSETS__?.length) {
              reg.active?.postMessage({
                prefetchAssets: window.__PREFETCH_ASSETS__,
              });
            }
          }
        });

        function notifySW(worker) {
          worker.postMessage("prefetch");
        }

        if (reg.active) {
          notifySW(reg.active);
        } else {
          reg.addEventListener("updatefound", () => {
            const newWorker = reg.installing;
            newWorker.addEventListener("statechange", () => {
              if (newWorker.state === "activated") notifySW(newWorker);
            });
          });
        }
      });
    }
  </script>

  {/* ────────────────────────────────────────────────────────────────
      Listen for mp4Ready → forward to videojs
  ───────────────────────────────────────────────────────────────── */}
  <script is:client>
    navigator.serviceWorker?.addEventListener("message", (event) => {
      const data = event.data;
      if (!data?.mp4Ready) return;

      const { videoId, mp4Url } = data.mp4Ready;
      console.log("[MAIN] mp4Ready →", videoId, mp4Url);

      window.dispatchEvent(
        new CustomEvent("cfvideo-mp4-ready", {
          detail: { videoId, mp4Url }
        })
      );
    });
  </script>

  <script>
    import "../scripts/smart-image";
  </script>

  <style define:vars={{ wpBaseUrl: `url('${WP_BASE_URL}')` }}>
    :root {
      --wp-base-url: var(--wpBaseUrl);
    }
  </style>

  <script src={headerCriticalUrl} defer></script>

  <ClientRouter prefetch="viewport" />

  <script>
    document.addEventListener('astro:before-swap', (ev) => {
      ev.newDocument.body.classList.remove('first-load');
    });
  </script>
</head>

<body class={`first-load ${bodyClasses}`}>
  <main>
    <SiteNav />
    <div class="switcher" transition:animate={fade({duration: '1s'})}>
      <slot />
    </div>
  </main>

  <SiteFooter />

  <link rel="stylesheet" href={belowCssUrl} media="print" onload="this.media='all'" />
  
  <script is:client>
    if (window.__isSafari) {
      document.documentElement.classList.add("disable-vt");

      document.addEventListener("click", (e) => {
        const a = e.target.closest("a[href]");
        if (!a) return;

        const url = a.getAttribute("href");
        if (
          (url.startsWith("http") && !url.startsWith(location.origin)) ||
          url.startsWith("#") ||
          url.startsWith("mailto:") ||
          url.startsWith("tel:") ||
          url.startsWith("javascript:")
        ) {
          return;
        }

        e.preventDefault();
        window.location.href = url;
      });
    }
  </script>

  <PromoPopup />

</body>
</html>