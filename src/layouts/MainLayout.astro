---
// mainlayout.astro
import { ClientRouter } from "astro:transitions";
import SiteFooter from "../components/SiteFooter.astro";
import SiteNav from "../components/SiteNav.astro";
import PromoPopup from "../components/PromoPopup.astro";    
import videoJsUrl from "/src/scripts/videojs.js?url";

// Critical CSS
import "../styles/global.scss";

// Below-the-fold CSS
import belowCssUrl from "@/styles/below.scss?url";

// URL for critical script
import headerCriticalUrl from "@/scripts/header-critical.js?url";

const WP_BASE_URL = import.meta.env.WP_BASE_URL;

/* ---------------- Props Interface ---------------- */
interface PreloadItem {
  href: string;
  imagesrcset?: string;
  imagesizes?: string;
  type?: string;
}

interface Props {
  title?: string;
  description?: string;
  lcp?: PreloadItem | null;
  lcpVideo?: {
    href: string; // HLS (.m3u8) URL only
  } | null;

  // carousel = string[], full_width_slideshow = PreloadItem[]
  preloads?: (string | PreloadItem)[];
}

const {
  title = "",
  description = "",
  lcp = null,
  lcpVideo = null,
  preloads = [],
} = Astro.props;

const pathname = Astro.url.pathname;
const segments = pathname.split("/").filter(Boolean);
const bodyClasses = segments.length ? segments.join(" ") : "home";

Astro.response.headers.set(
  "Cache-Control",
  "public, max-age=2700, s-maxage=2700, stale-while-revalidate=12000"
);

Astro.response.headers.set(
  "Netlify-CDN-Cache-Control",
  "public, max-age=2700, stale-while-revalidate=12000"
);
---

<html lang="en" style="view-transition-name: main-content">
<head>
  <meta charset="utf-8" />
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <meta name="viewport" content="width=device-width" />
  <meta name="generator" content={Astro.generator} />
  <title>{title}</title>

  {description && <meta name="description" content={description} />}

  {/* 🚀 LCP PRELOAD (CURRENT PAGE) */}
  {lcp && (
    <link 
      rel="preload"
      as="image"
      fetchpriority="high"
      href={lcp.href}
      imagesrcset={lcp.imagesrcset}
      imagesizes={lcp.imagesizes}
      type={lcp.type}
    />
  )}

  <link rel="modulepreload" href={videoJsUrl} />

  {/* ────────────────────────────────────────────────────────────────
      LCP VIDEO (HLS WARMUP)
  ───────────────────────────────────────────────────────────────── */}
  {lcpVideo && (
    <>
      <link rel="preconnect"
        href="https://customer-kzf3pwxulwy9bd0t.cloudflarestream.com"
        crossorigin />

      <link rel="dns-prefetch"
        href="https://customer-kzf3pwxulwy9bd0t.cloudflarestream.com" />

      <link rel="prefetch"
        as="fetch"
        href={lcpVideo.href}
        crossorigin="anonymous" />
    </>
  )}

{/* ────────────────────────────────────────────────────────────────
    CAROUSEL + FULL WIDTH SLIDESHOW PRELOADER (WITH LOGGING)
──────────────────────────────────────────────────────────────── */}
<script is:inline define:vars={{ preloads }}>
  window.addEventListener("critImgLoaded", () => {
    console.log("[Preload] critImgLoaded fired");
    console.log("[Preload] Incoming preloads:", preloads);

    if (!preloads || preloads.length === 0) {
      console.warn("[Preload] No preload items found");
      return;
    }

    const run = window.requestIdleCallback || ((cb) => setTimeout(cb, 1));

    run(() => {
      console.log("[Preload] Starting preload queue…");

      preloads.forEach((p, i) => {
        if (!p) {
          console.warn(`[Preload] Skipping empty preload at index ${i}`);
          return;
        }

        // ─────────────────────────────
        // Legacy carousel preload
        // ─────────────────────────────
        if (typeof p === "string") {
          console.log(`[Preload][Carousel]`, p);
          const img = new Image();
          img.src = p;
          return;
        }

        // ─────────────────────────────
        // SRCSET slideshow preload
        // ─────────────────────────────
        if (p.href) {
          console.log(`[Preload][Slideshow]`, {
            href: p.href,
            srcset: p.imagesrcset,
            sizes: p.imagesizes,
            type: p.type
          });

          const link = document.createElement("link");
          link.rel = "preload";
          link.as = "image";
          link.href = p.href;

          if (p.imagesrcset) link.setAttribute("imagesrcset", p.imagesrcset);
          if (p.imagesizes) link.setAttribute("imagesizes", p.imagesizes);
          if (p.type) link.setAttribute("type", p.type);

          document.head.appendChild(link);
          return;
        }

        console.warn("[Preload] Unknown preload entry:", p);
      });

      console.log("[Preload] Queue complete");
    });
  }, { once: true });
</script>


  {/* ────────────────────────────────────────────────────────────────
      PREFETCH MAP LOGIC (SRCSET PARSER)
  ───────────────────────────────────────────────────────────────── */}
  <script is:client>
    (async () => {
      function getBestImage(srcset) {
        if (!srcset) return null;

        const candidates = srcset.split(",").map(s => {
          const parts = s.trim().split(/\s+/);
          const url = parts[0];
          const wDesc = parts.length > 1 ? parts[1] : null;
          let width = 0;
          if (wDesc && wDesc.endsWith("w")) width = parseInt(wDesc, 10);
          return { url, width };
        });

        candidates.sort((a, b) => a.width - b.width);
        const targetWidth = window.innerWidth * (window.devicePixelRatio || 1);
        const best = candidates.find(c => c.width >= targetWidth);
        return best ? best.url : candidates[candidates.length - 1].url;
      }

      try {
        const req = await fetch("/prefetch-map.json", { cache: "no-store" });
        if (!req.ok) return;

        const map = await req.json();
        const assets = new Set();

        map.forEach((entry) => {
          if (!entry.lcp) return;

          if (entry.lcp.imagesrcset) {
            const bestUrl = getBestImage(entry.lcp.imagesrcset);
            if (bestUrl) assets.add(bestUrl);
          } else if (entry.lcp.href) {
            assets.add(entry.lcp.href);
          }

          if (entry.video) assets.add(entry.video);
        });

        window.__PREFETCH_ASSETS__ = Array.from(assets);
        console.log("[Prefetch] Asset list prepared:", window.__PREFETCH_ASSETS__);
      } catch (err) {
        console.warn("Prefetch map failed:", err);
      }
    })();
  </script>

  {/* ────────────────────────────────────────────────────────────────
      SW PREFETCH HANDSHAKE
  ───────────────────────────────────────────────────────────────── */}
  <script is:client>
    if ("serviceWorker" in navigator) {
      navigator.serviceWorker.register("/sw.js").then((reg) => {
        navigator.serviceWorker.addEventListener("message", (event) => {
          if (event.data === "request-prefetch-list") {
            if (window.__PREFETCH_ASSETS__?.length) {
              reg.active?.postMessage({ prefetchAssets: window.__PREFETCH_ASSETS__ });
            }
          }
        });

        function notifySW(worker) {
          worker.postMessage("prefetch");
        }

        if (reg.active) notifySW(reg.active);
        else {
          reg.addEventListener("updatefound", () => {
            const w = reg.installing;
            w.addEventListener("statechange", () => {
              if (w.state === "activated") notifySW(w);
            });
          });
        }
      });
    }
  </script>

  <script>
    import "../scripts/smart-image";
  </script>

  <style define:vars={{ wpBaseUrl: `url('${WP_BASE_URL}')` }}>
    :root {
      --wp-base-url: var(--wpBaseUrl);
    }
  </style>

  <script src={headerCriticalUrl} defer></script>

  <ClientRouter prefetch="load" />

  <script>
    document.addEventListener("astro:before-swap", (ev) => {
      ev.newDocument.body.classList.remove("first-load");
    });
  </script>

	<script>
	import Lenis from 'lenis';

	let lenis;

	// Initialize Lenis
	const initLenis = () => {
		// Prevent creating multiple instances if one already exists
		if (lenis) return;

		lenis = new Lenis({
		lerp: .2, // Smoothness (0-1). Lower is smoother.
		smoothWheel: true, // Enable smooth scrolling for mouse wheel
		});

		// The animation loop
		function raf(time) {
		lenis.raf(time);
		requestAnimationFrame(raf);
		}

		requestAnimationFrame(raf);
	};

	// Run on initial load and after every View Transition swap
	document.addEventListener('astro:page-load', initLenis);
	
	// Optional: Handle anchor links with smooth scroll
	// This prevents the native jump and uses Lenis's smooth scroll instead
	document.addEventListener('click', (e) => {
		const target = e.target.closest('a[href^="#"]');
		if (target) {
		e.preventDefault();
		const id = target.getAttribute('href');
		if (id === '#') return;
		lenis.scrollTo(id);
		}
	});
	</script>
</head>

<body class={`first-load ${bodyClasses}`}>
  <main>
    <SiteNav />
    <div class="switcher">
      <slot />
    </div>
  </main>

  <SiteFooter />

  <link rel="stylesheet" href={belowCssUrl} media="print" onload="this.media='all'" />

  <script is:client>
    if (window.__isSafari) {
      document.documentElement.classList.add("disable-vt");

      document.addEventListener("click", (e) => {
        const a = e.target.closest("a[href]");
        if (!a) return;

        const url = a.getAttribute("href");
        if (
          (url.startsWith("http") && !url.startsWith(location.origin)) ||
          url.startsWith("#") ||
          url.startsWith("mailto:") ||
          url.startsWith("tel:") ||
          url.startsWith("javascript:")
        ) return;

        e.preventDefault();
        window.location.href = url;
      });
    }
  </script>

  <PromoPopup />
</body>
</html>
