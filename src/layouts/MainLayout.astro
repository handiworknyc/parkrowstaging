	---
	// mainlayout.astro
	import { ClientRouter } from "astro:transitions";
	import SiteFooter from "../components/SiteFooter.astro";
	import SiteNav from "../components/SiteNav.astro";
	import PromoPopup from "../components/PromoPopup.astro";
	import { getSocialPhone, toTelHref } from "../lib/wp/getSocialMedia";
	import {
		getResponsiveCriticalVideoPreloadUrls,
		getResponsiveCriticalVideoPreloadVariants,
	} from "@/lib/video/stream";

	import videoJsUrl from "/src/scripts/videojs.js?url";
	import belowCssUrl from "@/styles/below.scss?url";
	import headerCriticalUrl from "@/scripts/header-critical.js?url";

	import "../styles/global.scss";

	/* ---------------- Types ---------------- */
	interface PreloadItem {
	href: string;
	imagesrcset?: string;
	imagesizes?: string;
	type?: string;
	media?: string;
	}

	interface SeoImage {
		url: string;
		width?: number | null;
		height?: number | null;
		alt?: string;
	}

	interface PageSeo {
		title?: string;
		description?: string;
		image?: SeoImage | null;
	}

	interface Props {
		title?: string;
		description?: string;
		seo?: PageSeo | null;
		lcp?: PreloadItem | PreloadItem[] | null;
		lcpVideo?: {
			href?: string | null;
			mobileHref?: string | null;
			mobileBreakpoint?: number | null;
		} | null;
		preloads?: (string | PreloadItem)[];
		lang?: 'en' | 'zh';
		cacheControl?: string;
		noIndex?: boolean;
		isPreview?: boolean;
		hasSplashVideo?: boolean;
	}

	/* ---------------- Props & Config ---------------- */
	const {
	title = "",
	description = "",
	seo = null,
	lcp = null,
	lcpVideo = null,
	preloads = [],
	lang = 'en',
	cacheControl: cacheControlProp = "",
	noIndex = false,
	isPreview = false,
	hasSplashVideo = false,
	} = Astro.props;


	const WP_BASE_URL = import.meta.env.WP_BASE_URL;
	const socialPhone = await getSocialPhone();
	const socialPhoneHref = toTelHref(socialPhone);

	const CLOUDFLARE_STREAM_DOMAIN = "https://customer-iyfwlpktwxjf4onx.cloudflarestream.com";
	const CLOUDFLARE_DELIVERY_DOMAIN = "https://videodelivery.net";

	function normalizeMetaText(value: unknown): string {
		return typeof value === "string" ? value.trim() : "";
	}

	function normalizePositiveInteger(value: unknown): number | null {
		const numeric = Number(value);
		return Number.isInteger(numeric) && numeric > 0 ? numeric : null;
	}

	const siteUrl = Astro.site ? new URL(Astro.site.toString()) : Astro.url;

	function toAbsoluteUrl(raw: string): string {
		const normalized = normalizeMetaText(raw);
		if (!normalized) return "";

		try {
			return new URL(normalized, siteUrl).toString();
		} catch {
			return normalized;
		}
	}

	function normalizePrefetchPath(pathname: string): string {
		let normalized = (pathname || "/").trim();
		if (!normalized.startsWith("/")) normalized = `/${normalized}`;
		if (!normalized.endsWith("/")) normalized = `${normalized}/`;
		return normalized;
	}

	function extractSrcSetUrls(srcset?: string): string[] {
		if (!srcset) return [];

		return Array.from(
			new Set(
				srcset
					.split(",")
					.map((candidate) => candidate.trim().split(/\s+/)[0])
					.filter(Boolean)
			)
		);
	}

	function collectPreloadedAssetUrls(
		currentLcp: PreloadItem | PreloadItem[] | null,
		currentLcpVideo: {
			href?: string | null;
			mobileHref?: string | null;
			mobileBreakpoint?: number | null;
		} | null,
		currentPreloads: (string | PreloadItem)[]
	): string[] {
		const assets = new Set<string>();

		const lcpItems = Array.isArray(currentLcp)
			? currentLcp
			: currentLcp
				? [currentLcp]
				: [];

		lcpItems.forEach((item) => {
			if (!item?.href) return;
			assets.add(item.href);
			extractSrcSetUrls(item.imagesrcset).forEach((url) => assets.add(url));
		});

		if (currentLcpVideo) {
			getResponsiveCriticalVideoPreloadUrls(currentLcpVideo).forEach((url) =>
				assets.add(url)
			);
		}

		currentPreloads.forEach((item) => {
			if (!item) return;

			if (typeof item === "string") {
				assets.add(item);
				return;
			}

			if (item.href) assets.add(item.href);
			extractSrcSetUrls(item.imagesrcset).forEach((url) => assets.add(url));
		});

		return Array.from(assets);
	}

	const rawPathname = Astro.url.pathname;

	// Normalize path for layout logic (strip /zh)
	const normalizedPathname =
	lang === 'zh' ? rawPathname.replace(/^\/zh/, '') || '/' : rawPathname;
	const canonicalPath = lang === 'zh' ? `/zh${normalizedPathname}` : normalizedPathname;
	const canonicalHref = toAbsoluteUrl(canonicalPath);
	const alternateEnHref = toAbsoluteUrl(normalizedPathname);
	const alternateZhHref = toAbsoluteUrl(`/zh${normalizedPathname === '/' ? '' : normalizedPathname}`);
	const currentPrefetchPath = normalizePrefetchPath(normalizedPathname);
	const isFloorplansPage =
		currentPrefetchPath === "/floor-plans/" || currentPrefetchPath === "/floorplans/";
	const floorplansTransitionBypassPaths = [
		"/floor-plans/",
		"/floorplans/",
		"/zh/floor-plans/",
		"/zh/floorplans/",
	];
	const lcpEntries = Array.isArray(lcp) ? lcp.filter(Boolean) : lcp ? [lcp] : [];
	const criticalVideoPreloadVariants = getResponsiveCriticalVideoPreloadVariants(lcpVideo);
	const shouldWarmCriticalVideo = criticalVideoPreloadVariants.length > 0;
	const preloadedAssetUrls = collectPreloadedAssetUrls(lcp, lcpVideo, preloads);
	const metaTitle = normalizeMetaText(seo?.title) || title;
	const metaDescription = normalizeMetaText(seo?.description) || description;
	const metaImageUrl = toAbsoluteUrl(seo?.image?.url || "");
	const metaImageWidth = normalizePositiveInteger(seo?.image?.width);
	const metaImageHeight = normalizePositiveInteger(seo?.image?.height);
	const metaImageAlt = metaImageUrl
		? normalizeMetaText(seo?.image?.alt) || metaTitle
		: "";
	const twitterCard = metaImageUrl ? "summary_large_image" : "summary";

	const segments = normalizedPathname.split("/").filter(Boolean);
	const bodyClasses = segments.length ? segments.join(" ") : "home";
	const htmlClasses = [
		isPreview ? "" : "first-load",
		bodyClasses,
		!isPreview && hasSplashVideo ? "splash-scroll-lock" : "",
	]
		.filter(Boolean)
		.join(" ");


	const cacheControl = cacheControlProp || "public, max-age=2700, s-maxage=2700, stale-while-revalidate=12000";
	Astro.response.headers.set("Cache-Control", cacheControl);
	Astro.response.headers.set("Netlify-CDN-Cache-Control", cacheControl);
	if (noIndex) {
		Astro.response.headers.set("X-Robots-Tag", "noindex, nofollow");
	}
	---

	<html
		lang={lang}
		style="view-transition-name: main-content"
		class={htmlClasses}
		>

	<head>
	<meta charset="utf-8" />

	
	{/* 🔒 CRITICAL: Scroll lock MUST run before EVERYTHING else */}
		<script
			is:inline
			define:vars={{ initialSplashActive: !isPreview && hasSplashVideo }}
		>
			window.HW = {};
			HW.$html = document.documentElement;
			window.__hwSplashInitialCandidate = initialSplashActive;
			window.__syncHwSplashActive = () => {
				const html = document.documentElement;
				window.hwSplashActive =
					window.__hwSplashInitialCandidate === true &&
					html.classList.contains("home") &&
					html.classList.contains("first-load") &&
					html.classList.contains("splash-scroll-lock");
				return window.hwSplashActive;
			};
			window.__syncHwSplashActive();
		</script>

	<script is:inline>
		(() => {
			const storageKey = "parkrow-cookie-consent";
			const consentAttr = "data-cookie-consent";

			const readConsent = () => {
				try {
					return window.localStorage.getItem(storageKey);
				} catch {
					return null;
				}
			};

			const syncKnownTrackers = (value) => {
				const granted = value === "accepted";

				if (typeof window.gtag === "function") {
					window.gtag("consent", "update", {
						analytics_storage: granted ? "granted" : "denied",
						ad_storage: granted ? "granted" : "denied",
						ad_user_data: granted ? "granted" : "denied",
						ad_personalization: granted ? "granted" : "denied",
					});
				}

				if (Array.isArray(window.dataLayer)) {
					window.dataLayer.push({
						event: "parkrow_cookie_consent",
						parkrow_cookie_consent: value || "pending",
					});
				}
			};

			const applyConsent = (value) => {
				if (value) {
					document.documentElement.setAttribute(consentAttr, value);
				} else {
					document.documentElement.removeAttribute(consentAttr);
				}

				syncKnownTrackers(value);
			};

			const writeConsent = (value) => {
				if (value !== "accepted" && value !== "rejected") return;

				try {
					window.localStorage.setItem(storageKey, value);
				} catch {}

				applyConsent(value);
				window.dispatchEvent(
					new CustomEvent("parkrow:cookie-consent", {
						detail: { value },
					})
				);
			};

			applyConsent(readConsent());

			window.ParkRowConsent = {
				storageKey,
				read: readConsent,
				write: writeConsent,
				allowsTracking() {
					return readConsent() === "accepted";
				},
			};
		})();
	</script>

	{/* ⚡️ PRIORITY 1: Preload VideoJS immediately (Network) */}
	{shouldWarmCriticalVideo && (
		<link rel="modulepreload" href={videoJsUrl} fetchpriority="high" />
	)}
		
	{/* ⚡️ PRIORITY 2: Import VideoJS immediately (Execution/Parsing) */}
	{/* This forces the browser to parse the heavy library NOW, not later */}
	{shouldWarmCriticalVideo && (
		<script>
			import "/src/scripts/videojs.js";
		</script>
	)}

		
	<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
	<link
		rel="preload"
		href="/fonts/HankenGrotesk-Light.woff2"
		as="font"
		type="font/woff2"
		crossorigin
	/>
	<link
		rel="preload"
		href="/fonts/HankenGrotesk-Regular.woff2"
		as="font"
		type="font/woff2"
		crossorigin
	/>
	<link
		rel="preload"
		href="/fonts/HankenGrotesk-SemiBold.woff2"
		as="font"
		type="font/woff2"
		crossorigin
	/>
	<link
		rel="preload"
		href="/fonts/Antiga-Regular.woff2"
		as="font"
		type="font/woff2"
		crossorigin
	/>
	<link
		rel="preload"
		href="/fonts/Figure-ExtendedRegular.woff2"
		as="font"
		type="font/woff2"
		crossorigin
	/>
	<meta name="viewport" content="width=device-width" />
	<meta name="generator" content={Astro.generator} />
	{noIndex && <meta name="robots" content="noindex, nofollow" />}
	<title>{metaTitle}</title>

	<link
	rel="canonical"
	href={canonicalHref}
	/>

	<link
	rel="alternate"
	hreflang="en"
	href={alternateEnHref}
	/>

	<link
	rel="alternate"
	hreflang="zh"
	href={alternateZhHref}
	/>

	{metaDescription && <meta name="description" content={metaDescription} />}
	{metaTitle && <meta property="og:title" content={metaTitle} />}
	{metaDescription && <meta property="og:description" content={metaDescription} />}
	<meta property="og:type" content="website" />
	<meta property="og:url" content={canonicalHref} />
	<meta name="twitter:card" content={twitterCard} />
	{metaTitle && <meta name="twitter:title" content={metaTitle} />}
	{metaDescription && <meta name="twitter:description" content={metaDescription} />}
	{metaImageUrl && <meta property="og:image" content={metaImageUrl} />}
	{metaImageWidth && <meta property="og:image:width" content={String(metaImageWidth)} />}
	{metaImageHeight && <meta property="og:image:height" content={String(metaImageHeight)} />}
	{metaImageAlt && <meta property="og:image:alt" content={metaImageAlt} />}
	{metaImageUrl && <meta name="twitter:image" content={metaImageUrl} />}
	{metaImageAlt && <meta name="twitter:image:alt" content={metaImageAlt} />}

	{/* LCP Image Preload */}
	{lcpEntries.map((item) => (
		<link 
		rel="preload"
		as="image"
		fetchpriority="high"
		href={item.href}
		imagesrcset={item.imagesrcset}
		imagesizes={item.imagesizes}
		type={item.type}
		media={item.media}
		/>
	))}

	{/* LCP Video (Full Warmup) */}
	{criticalVideoPreloadVariants.length > 0 && (
		<>
			{/* 1. Manifest Domain */}
			<link rel="preconnect" href={CLOUDFLARE_STREAM_DOMAIN} crossorigin />
			<link rel="dns-prefetch" href={CLOUDFLARE_STREAM_DOMAIN} />

			{/* 2. ⚡️ Segment Domain (The Heavy Lifter) */}
			<link rel="preconnect" href={CLOUDFLARE_DELIVERY_DOMAIN} crossorigin />
			<link rel="dns-prefetch" href={CLOUDFLARE_DELIVERY_DOMAIN} />

			{/* 3. ⚡️ Viewport-matched preload so the player and preload share the same URL */}
			{criticalVideoPreloadVariants.map((variant) => (
				<link 
				rel="preload" 
				as="fetch" 
				href={variant.href}
				media={variant.media}
				type="application/vnd.apple.mpegurl"
				fetchpriority="high"
				crossorigin
				/>
			))}
		</>
	)}

	{/* Carousel/Slideshow Preloader */}
	<script is:inline define:vars={{ preloads }}>
		const DEBUG = false;
		const log = (...args) => DEBUG && console.log("[Preload]", ...args);

		window.addEventListener("critImgLoaded", () => {
		log("critImgLoaded fired");
		log("Incoming preloads:", preloads);

		if (!preloads?.length) {
			log("No preload items found");
			return;
		}

		const run = window.requestIdleCallback || ((cb) => setTimeout(cb, 1));

		run(() => {
			log("Starting preload queue...");
			const seen = new Set();

			preloads.forEach((p, i) => {
			if (!p) {
				log(`Skipping empty preload at index ${i}`);
				return;
			}

			// Legacy carousel (string URL)
			if (typeof p === "string") {
				if (seen.has(p)) return;
				seen.add(p);
				log("[Carousel]", p);
				const img = new Image();
				img.src = p;
				return;
			}

			// Slideshow (srcset)
			if (p.href) {
				const key = [p.href, p.imagesrcset || "", p.imagesizes || ""].join("|");
				if (seen.has(key)) return;
				seen.add(key);
				log("[Slideshow]", {
				href: p.href,
				srcset: p.imagesrcset,
				sizes: p.imagesizes,
				type: p.type
				});

				const link = document.createElement("link");
				link.rel = "preload";
				link.as = "image";
				link.href = p.href;

				if (p.imagesrcset) link.setAttribute("imagesrcset", p.imagesrcset);
				if (p.imagesizes) link.setAttribute("imagesizes", p.imagesizes);
				if (p.type) link.setAttribute("type", p.type);

				document.head.appendChild(link);
				return;
			}

			log("Unknown preload entry:", p);
			});

			log("Queue complete");
		});
		}, { once: true });
	</script>

	{/* Prefetch Map Logic */}
	<script
		is:inline
		define:vars={{
			prefetchContext: {
				currentPath: currentPrefetchPath,
				preloadedAssets: preloadedAssetUrls,
			},
		}}
	>
		window.__HW_PREFETCH_CONTEXT__ = prefetchContext;
	</script>

	<script>
		import {
			buildStreamUrl,
			getClientBandwidthHintForViewport,
		} from "/src/lib/video/stream";

		const PREFETCH_CONFIG = {
			idleTimeoutMs: 2000,
			splashSettleTimeoutMs: 8000,
		};

		function waitForWindowLoad() {
			if (document.readyState === "complete") {
				return Promise.resolve();
			}

			return new Promise((resolve) => {
				window.addEventListener("load", () => resolve(), { once: true });
			});
		}

		function waitForIdle(timeout = PREFETCH_CONFIG.idleTimeoutMs) {
			return new Promise((resolve) => {
				if ("requestIdleCallback" in window) {
					window.requestIdleCallback(() => resolve(), { timeout });
					return;
				}

				setTimeout(resolve, 1);
			});
		}

		function waitForEventOrTimeout(target, eventName, timeoutMs) {
			return new Promise((resolve) => {
				let done = false;
				let timeoutId = null;

				const finish = () => {
					if (done) return;
					done = true;

					if (timeoutId) clearTimeout(timeoutId);
					target.removeEventListener(eventName, finish);
					resolve();
				};

				target.addEventListener(eventName, finish, { once: true });
				timeoutId = setTimeout(finish, timeoutMs);
			});
		}

		async function waitForCurrentPageSettled() {
			await waitForWindowLoad();

			const isSplashPage =
				document.documentElement.classList.contains("home") &&
				!!document.querySelector("[data-splash-video]");

			if (
				isSplashPage &&
				window.hwSplashActive === true &&
				!document.documentElement.classList.contains("splash-dismissed")
			) {
				await waitForEventOrTimeout(
					window,
					"splash:dismiss",
					PREFETCH_CONFIG.splashSettleTimeoutMs
				);
			}

			await waitForIdle();
		}

		function getBestImage(srcset) {
			if (!srcset) return null;

			const candidates = srcset.split(",").map((candidate) => {
				const parts = candidate.trim().split(/\s+/);
				const url = parts[0];
				const wDesc = parts.length > 1 ? parts[1] : null;
				const width = wDesc?.endsWith("w") ? parseInt(wDesc, 10) : 0;
				return { url, width };
			});

			candidates.sort((a, b) => a.width - b.width);
			const targetWidth = window.innerWidth * (window.devicePixelRatio || 1);
			const best = candidates.find((candidate) => candidate.width >= targetWidth);
			return best ? best.url : candidates[candidates.length - 1]?.url || null;
		}

		function normalizePrefetchPath(pathname) {
			let normalized = (pathname || "/").trim();
			if (!normalized.startsWith("/")) normalized = `/${normalized}`;
			if (!normalized.endsWith("/")) normalized = `${normalized}/`;
			return normalized;
		}

		window.__HW_PREFETCH_READY_PROMISE__ = (async () => {
			const context = window.__HW_PREFETCH_CONTEXT__ || {};
			const currentPath = normalizePrefetchPath(context.currentPath);
			const skipAssets = new Set(
				Array.isArray(context.preloadedAssets) ? context.preloadedAssets : []
			);
			const emptyState = {
				assets: [],
				skipAssets: Array.from(skipAssets),
			};

			try {
				await waitForCurrentPageSettled();

				const res = await fetch("/prefetch-map.json", { cache: "no-store" });
				if (!res.ok) {
					window.__HW_PREFETCH_READY__ = emptyState;
					return emptyState;
				}

				const map = await res.json();
				const assets = new Set();

				map.forEach((entry) => {
					if (!entry?.lcp && !entry?.video) return;
					if (normalizePrefetchPath(entry.path) === currentPath) return;

					const imageUrl = entry.lcp?.imagesrcset
						? getBestImage(entry.lcp.imagesrcset)
						: entry.lcp?.href;

					if (imageUrl && !skipAssets.has(imageUrl)) {
						assets.add(imageUrl);
					}

					if (entry.video) {
						const hintedVideoUrl = buildStreamUrl(
							entry.video,
							getClientBandwidthHintForViewport(window.innerWidth)
						);

						if (hintedVideoUrl && !skipAssets.has(hintedVideoUrl)) {
							assets.add(hintedVideoUrl);
						}
					}
				});

				const prefetchAssets = Array.from(assets);
				const prefetchSkipAssets = Array.from(skipAssets);

				window.__PREFETCH_ASSETS__ = prefetchAssets;
				window.__HW_PREFETCH_SKIP_ASSETS__ = prefetchSkipAssets;
				window.__HW_PREFETCH_READY__ = {
					assets: prefetchAssets,
					skipAssets: prefetchSkipAssets,
				};
				return window.__HW_PREFETCH_READY__;
			} catch (err) {
				console.warn("Prefetch map failed:", err);
				window.__HW_PREFETCH_READY__ = emptyState;
				return emptyState;
			}
		})();
	</script>

		{/* Service Worker Prefetch */}
		<script>
			async function unregisterDevServiceWorkers() {
				const regs = await navigator.serviceWorker.getRegistrations();
				await Promise.all(regs.map((reg) => reg.unregister()));

				if ("caches" in window) {
					const cacheKeys = await caches.keys();
					await Promise.all(
						cacheKeys
							.filter((key) => key.startsWith("prefetch-"))
							.map((key) => caches.delete(key))
					);
				}
			}

			if ("serviceWorker" in navigator) {
				if (import.meta.env.DEV) {
					unregisterDevServiceWorkers().catch((err) => {
						console.warn("Service worker cleanup failed:", err);
					});
				} else {
					navigator.serviceWorker.register("/sw.js").then((reg) => {
						const waitForPrefetchAssets = async () =>
							window.__HW_PREFETCH_READY_PROMISE__ ||
							window.__HW_PREFETCH_READY__ || { assets: [], skipAssets: [] };

						navigator.serviceWorker.addEventListener("message", async (event) => {
							if (event.data === "request-prefetch-list") {
								const prefetchState = await waitForPrefetchAssets();
								if (!prefetchState?.assets?.length) return;

								reg.active?.postMessage({
									prefetchAssets: prefetchState.assets,
									skipAssets: prefetchState.skipAssets || [],
								});
							}
						});

						const notifySW = async (worker) => {
							const prefetchState = await waitForPrefetchAssets();
							if (!prefetchState?.assets?.length) return;
							worker.postMessage("prefetch");
						};

						if (reg.active) {
							notifySW(reg.active);
						} else {
							reg.addEventListener("updatefound", () => {
								const w = reg.installing;
								w.addEventListener("statechange", () => {
									if (w.state === "activated") notifySW(w);
								});
							});
						}
					});
				}
			}
		</script>

	<script>
		import "../scripts/smart-image";
	</script>

	<style define:vars={{ wpBaseUrl: `url('${WP_BASE_URL}')` }}>
		:root {
		--wp-base-url: var(--wpBaseUrl);
		}
	</style>

	<script src={headerCriticalUrl} defer></script>

	{!isFloorplansPage && <ClientRouter prefetch="load" />}

	<script
		is:inline
		define:vars={{ floorplansTransitionBypassPaths }}
	>
		(() => {
			const normalizePathname = (pathname) => {
				let normalized = String(pathname || "/").trim();
				if (!normalized) normalized = "/";
				if (!normalized.startsWith("/")) normalized = `/${normalized}`;
				normalized = normalized.replace(/\/+$/, "");
				return normalized ? `${normalized}/` : "/";
			};

			const bypassPaths = new Set(
				(floorplansTransitionBypassPaths || []).map((pathname) =>
					normalizePathname(pathname)
				)
			);

			const shouldBypassFloorplansTransition = (href) => {
				if (!href) return false;
				if (
					href.startsWith("#") ||
					href.startsWith("mailto:") ||
					href.startsWith("tel:") ||
					href.startsWith("javascript:")
				) {
					return false;
				}

				try {
					const url = new URL(href, window.location.href);
					if (url.origin !== window.location.origin) return false;
					return bypassPaths.has(normalizePathname(url.pathname));
				} catch {
					return false;
				}
			};

			const syncFloorplansReloadLinks = (root = document) => {
				root.querySelectorAll("a[href]").forEach((link) => {
					if (!(link instanceof HTMLAnchorElement)) return;
					if (!shouldBypassFloorplansTransition(link.getAttribute("href"))) return;
					link.setAttribute("data-astro-reload", "");
				});
			};

			window.__syncFloorplansReloadLinks = syncFloorplansReloadLinks;

			if (!window.__floorplansReloadLinksInitialized) {
				window.__floorplansReloadLinksInitialized = true;
				document.addEventListener("astro:page-load", () => {
					window.__syncFloorplansReloadLinks?.();
				});
				document.addEventListener("astro:after-swap", () => {
					window.__syncFloorplansReloadLinks?.();
				});
			}

			syncFloorplansReloadLinks();
		})();
	</script>

		<script>
			document.addEventListener("astro:before-swap", (ev) => {
			ev.newDocument.documentElement.classList.remove("first-load");
			ev.newDocument.documentElement.classList.remove("splash-scroll-lock");
			ev.newDocument.documentElement.classList.remove("splash-dismissed");
			window.__hwSplashInitialCandidate = false;
			window.hwSplashActive = false;
			});

			document.addEventListener("astro:after-swap", () => {
			window.__syncHwSplashActive?.();
			});
		</script>

	<script>
	import LocomotiveScroll from "locomotive-scroll";
	import {
		initScrollLock,
		isScrollLocked
	} from "../scripts/scroll-lock";

	// ------------------------------------
	// DEVICE FLAGS
	// ------------------------------------
	const isMobile =
		typeof HW !== "undefined" && HW.isMobile === true;

	const isIpad =
		typeof HW !== "undefined" && HW.isIpad === true;

	const isIOS = isMobile || isIpad;

	// ------------------------------------
	// CONFIGURATION
	// ------------------------------------
	const CONFIG = {
		LOCO_INIT_DELAY: 50,
		ENABLE_LOCO_ON_MOBILE: false,
	};

	// ------------------------------------
	// STATE
	// ------------------------------------
	let locoScroll = null;

	// ------------------------------------
	// HELPERS
	// ------------------------------------
	const isHome = () => document.body.classList.contains("home");
	const isFirstLoad = () => HW.$html.classList.contains("first-load");

	function normalizeRoutePath(pathname = "/") {
		let normalized = String(pathname || "/").trim();
		if (!normalized.startsWith("/")) normalized = `/${normalized}`;
		normalized = normalized.replace(/^\/zh(?=\/|$)/, "") || "/";
		if (!normalized.endsWith("/")) normalized = `${normalized}/`;
		return normalized;
	}

	function shouldResetScrollForRoute(pathname = window.location.pathname) {
		const normalized = normalizeRoutePath(pathname);
		return normalized === "/privacy-policy/" || normalized === "/terms-of-use/";
	}

	function resetScrollToTop() {
		if (locoScroll && shouldUseLocomotiveScroll()) {
			locoScroll.scrollTo(0, {
				duration: 0,
				disableLerp: true,
				immediate: true,
			});
		}

		window.scrollTo({ top: 0, left: 0, behavior: "auto" });
		document.documentElement.scrollTop = 0;
		document.body.scrollTop = 0;
	}

	function shouldUseLocomotiveScroll() {
		if (!isIOS) return true;
		return CONFIG.ENABLE_LOCO_ON_MOBILE;
	}

	// ------------------------------------
	// LOCOMOTIVE SCROLL
	// ------------------------------------
	function initLocoScroll() {
		const el = document.querySelector("main");
		if (!el) return;

		if (!shouldUseLocomotiveScroll()) {
		console.log("[Loco] Disabled on iOS — native scroll");
		initScrollLock();
		return;
		}

		locoScroll?.destroy();

		locoScroll = new LocomotiveScroll({
		el,
		smooth: true,
		lenisOptions: {
			lerp: 0,
			duration: 0.5,
		},
		smartphone: { smooth: true },
		tablet: { smooth: true },
		});

		window.locoScroll = locoScroll;

		document.dispatchEvent(
		new CustomEvent("loco:ready", {
			detail: { instance: locoScroll }
		})
		);

		initScrollLock(locoScroll);
	}

	// ------------------------------------
	// ASTRO LIFECYCLE
	// ------------------------------------
	document.addEventListener("astro:page-load", () => {
		setTimeout(initLocoScroll, CONFIG.LOCO_INIT_DELAY);
	});

	document.addEventListener("astro:before-preparation", () => {
		locoScroll?.stop();
	});

	document.addEventListener("astro:before-swap", (event) => {
		const nextPath = event.newDocument?.location?.pathname || window.location.pathname;
		if (!shouldResetScrollForRoute(nextPath)) return;
		resetScrollToTop();
	});

	document.addEventListener("astro:after-swap", () => {
		if (shouldResetScrollForRoute()) {
			requestAnimationFrame(() => resetScrollToTop());
		}

		if (!locoScroll) return;

		if (!isFirstLoad() || !isScrollLocked()) {
		locoScroll.start();
		} else {
		locoScroll.stop();
		}
	});

	// ------------------------------------
	// ANCHOR LINKS
	// ------------------------------------
	document.addEventListener("click", (e) => {
		const a = e.target.closest('a[href^="#"]');
		if (!a) return;

		const id = a.getAttribute("href");
		if (!id || id === "#") return;

		const target = document.querySelector(id);
		if (!target) return;

		e.preventDefault();

		if (isScrollLocked()) return;

		if (locoScroll && shouldUseLocomotiveScroll()) {
		locoScroll.scrollTo(target);
		} else {
		target.scrollIntoView({ behavior: "smooth" });
		}
	});
	</script>


	</head>

