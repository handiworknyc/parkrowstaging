---
//mainlayout.astro
import { ClientRouter } from "astro:transitions";
import SiteFooter from "../components/SiteFooter.astro";
import SiteNav from "../components/SiteNav.astro";
import PromoPopup from "../components/PromoPopup.astro";    
import videoJsUrl from "/src/scripts/videojs.js?url";

// Critical CSS
import "../styles/global.scss";

// Below-the-fold CSS
import belowCssUrl from "@/styles/below.scss?url";

// URL for critical script
import headerCriticalUrl from "@/scripts/header-critical.js?url";

const WP_BASE_URL = import.meta.env.WP_BASE_URL;

/* ---------------- Props Interface ---------------- */
interface Props {
  title?: string;
  description?: string;
  lcp?: {
    href: string;
    imagesrcset?: string;
    imagesizes?: string;
    type?: string;
  } | null;
  lcpVideo?: {
    href: string; // HLS (.m3u8) URL only
  } | null;
}

const { title = "", description = "", lcp = null, lcpVideo = null } = Astro.props;

const pathname = Astro.url.pathname;
const segments = pathname.split("/").filter(Boolean);
const bodyClasses = segments.length ? segments.join(" ") : "home";

Astro.response.headers.set ( 
    'Cache-Control',
    'public, max-age=2700, s-maxage=2700, stale-while-revalidate=12000',
)

Astro.response.headers.set(
    'Netlify-CDN-Cache-Control',
    'public, max-age=2700, stale-while-revalidate=12000',
)
---

<html lang="en" style="view-transition-name: main-content">
<head>
  <meta charset="utf-8" />
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <meta name="viewport" content="width=device-width" />
  <meta name="generator" content={Astro.generator} />
  <title>{title}</title>

  {description && <meta name="description" content={description} />}

  {/* 🚀 LCP PRELOAD (CURRENT PAGE) */}
  {lcp && (
    <link 
      rel="preload"
      as="image"
      fetchpriority="high"
      href={lcp.href}
      imagesrcset={lcp.imagesrcset}
      imagesizes={lcp.imagesizes}
      type={lcp.type}
    />
  )}

  <link rel="modulepreload" href={videoJsUrl} />

  {/* ────────────────────────────────────────────────────────────────
      LCP VIDEO (HLS WARMUP)
  ───────────────────────────────────────────────────────────────── */}
  {lcpVideo && (
    <>
      <link rel="preconnect"
        href="https://customer-kzf3pwxulwy9bd0t.cloudflarestream.com"
        crossorigin />

      <link rel="dns-prefetch"
        href="https://customer-kzf3pwxulwy9bd0t.cloudflarestream.com" />

      <link rel="prefetch"
        as="fetch"
        href={lcpVideo.href}
        crossorigin="anonymous" />
    </>
  )}

  {/* ────────────────────────────────────────────────────────────────
      PREFETCH MAP LOGIC (SRCSET PARSER)
  ───────────────────────────────────────────────────────────────── */}
  <script is:client>
    (async () => {
      // Helper: Pick the best image from srcset for current device
      function getBestImage(srcset) {
        if (!srcset) return null;

        // 1. Parse "url widthDescriptor"
        const candidates = srcset.split(',').map(s => {
          const parts = s.trim().split(/\s+/);
          // usually: ["https://.../img-800.jpg", "800w"]
          const url = parts[0];
          const wDesc = parts.length > 1 ? parts[1] : null;
          
          let width = 0;
          if (wDesc && wDesc.endsWith('w')) {
            width = parseInt(wDesc, 10);
          }
          
          return { url, width };
        });

        // 2. Sort by width (ascending)
        candidates.sort((a, b) => a.width - b.width);

        // 3. Determine target width (viewport * dpr)
        const targetWidth = window.innerWidth * (window.devicePixelRatio || 1);

        // 4. Find first candidate >= targetWidth
        const best = candidates.find(c => c.width >= targetWidth);

        // 5. Return match, or largest if none match
        return best ? best.url : candidates[candidates.length - 1].url;
      }

      try {
        const req = await fetch("/prefetch-map.json", { cache: "no-store" });
        if (!req.ok) return;

        const map = await req.json();
        const assets = new Set();

        map.forEach((entry) => {
          if (!entry.lcp) return;

          // A. If srcset exists, calculate best fit for THIS device
          if (entry.lcp.imagesrcset) {
            const bestUrl = getBestImage(entry.lcp.imagesrcset);
            if (bestUrl) assets.add(bestUrl);
          } 
          // B. Fallback to standard href
          else if (entry.lcp.href) {
            assets.add(entry.lcp.href);
          }

          // C. Videos (Manifests)
          if (entry.video) {
            assets.add(entry.video);
          }
        });

        window.__PREFETCH_ASSETS__ = Array.from(assets);
        console.log("[Prefetch] Asset list prepared:", window.__PREFETCH_ASSETS__);

      } catch (err) {
        console.warn("Prefetch map failed:", err);
      }
    })();
  </script>

  {/* ────────────────────────────────────────────────────────────────
      SW PREFETCH HANDSHAKE
  ───────────────────────────────────────────────────────────────── */}
  <script is:client>
    if ("serviceWorker" in navigator) {
      navigator.serviceWorker.register("/sw.js").then((reg) => {

        // Listen for requests from SW asking for the list
        navigator.serviceWorker.addEventListener("message", (event) => {
          if (event.data === "request-prefetch-list") {
            if (window.__PREFETCH_ASSETS__?.length) {
              reg.active?.postMessage({
                prefetchAssets: window.__PREFETCH_ASSETS__,
              });
            }
          }
        });

        function notifySW(worker) {
          worker.postMessage("prefetch");
        }

        if (reg.active) {
          notifySW(reg.active);
        } else {
          reg.addEventListener("updatefound", () => {
            const newWorker = reg.installing;
            newWorker.addEventListener("statechange", () => {
              if (newWorker.state === "activated") notifySW(newWorker);
            });
          });
        }
      });
    }
  </script>

  <script>
    import "../scripts/smart-image";
  </script>

  <style define:vars={{ wpBaseUrl: `url('${WP_BASE_URL}')` }}>
    :root {
      --wp-base-url: var(--wpBaseUrl);
    }
  </style>

  <script src={headerCriticalUrl} defer></script>

  <ClientRouter prefetch="load" />

  <script>
    document.addEventListener('astro:before-swap', (ev) => {
      ev.newDocument.body.classList.remove('first-load');
    });
  </script>
</head>

<body class={`first-load ${bodyClasses}`}>
  <main>
    <SiteNav />
    <div class="switcher">
      <slot />
    </div>
  </main>

  <SiteFooter />

  <link rel="stylesheet" href={belowCssUrl} media="print" onload="this.media='all'" />
  
  <script is:client>
    if (window.__isSafari) {
      document.documentElement.classList.add("disable-vt");

      document.addEventListener("click", (e) => {
        const a = e.target.closest("a[href]");
        if (!a) return;

        const url = a.getAttribute("href");
        if (
          (url.startsWith("http") && !url.startsWith(location.origin)) ||
          url.startsWith("#") ||
          url.startsWith("mailto:") ||
          url.startsWith("tel:") ||
          url.startsWith("javascript:")
        ) {
          return;
        }

        e.preventDefault();
        window.location.href = url;
      });
    }
  </script>

  <PromoPopup />

</body>
</html>